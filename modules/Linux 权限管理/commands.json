{
  "module": "Linux 权限管理",
  "version": "2.0",
  "description": "Linux 权限管理命令集合，涵盖Linux 权限管理的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux 权限管理/",
      "name": "chmod 更改权限",
      "keyword": "chmod 权限",
      "description": "更改文件或目录权限。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "chmod %{模式}% %{文件}%",
        "extensions": [
          {
            "name": "递归设置",
            "cmd": "chmod -R %{模式}% %{目录}%",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "权限模式",
                "example": "755",
                "notes": "必填"
              },
              "目录": {
                "type": "string",
                "required": true,
                "description": "目录",
                "example": "/var/www",
                "notes": "必填"
              }
            },
            "keyword": "chmod recursive"
          },
          {
            "name": "添加执行",
            "cmd": "chmod +x %{文件}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件",
                "example": "script.sh",
                "notes": "必填"
              }
            },
            "keyword": "chmod execute"
          }
        ],
        "params": {
          "模式": {
            "type": "string",
            "required": true,
            "description": "权限模式",
            "example": "644",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件路径",
            "example": "file.txt",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Linux 权限管理/",
      "name": "chown 更改所有者",
      "keyword": "chown 所有者",
      "description": "更改文件所有者和组。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "chown %{用户}%:%{组}% %{文件}%",
        "extensions": [
          {
            "name": "递归更改",
            "cmd": "chown -R %{用户}%:%{组}% %{目录}%",
            "params": {
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "www-data",
                "notes": "必填"
              },
              "组": {
                "type": "string",
                "required": true,
                "description": "组名",
                "example": "www-data",
                "notes": "必填"
              },
              "目录": {
                "type": "string",
                "required": true,
                "description": "目录",
                "example": "/var/www",
                "notes": "必填"
              }
            },
            "keyword": "chown recursive"
          }
        ],
        "params": {
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户名",
            "example": "root",
            "notes": "必填"
          },
          "组": {
            "type": "string",
            "required": true,
            "description": "组名",
            "example": "www-data",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件路径",
            "example": "/var/log",
            "notes": "必填"
          }
        }
      }
    }
  ]
}