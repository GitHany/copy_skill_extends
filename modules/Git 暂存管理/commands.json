{
  "module": "Git 暂存管理",
  "version": "2.0",
  "description": "Git 暂存管理命令集合，涵盖Git 暂存管理的常用操作和最佳实践",
  "commands": [
    {
      "cmd": "git stash",
      "extensions": [
        {
          "name": "带消息暂存",
          "cmd": "git stash push -m \"%{消息}%\"",
          "params": {
            "消息": {
              "type": "string",
              "required": true,
              "description": "暂存消息",
              "example": "WIP: feature login",
              "notes": "必填"
            }
          },
          "keyword": "git stash message"
        },
        {
          "name": "暂存未跟踪文件",
          "cmd": "git stash -u",
          "params": {},
          "keyword": "git stash untracked"
        },
        {
          "name": "暂存所有",
          "cmd": "git stash -a",
          "params": {},
          "keyword": "git stash all"
        }
      ],
      "params": {},
      "dirPath": "/Git 暂存管理/",
      "name": "Git 暂存管理 命令",
      "keyword": "Git 暂存管理 命令",
      "description": "Git 暂存管理 命令的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    }
  ]
}