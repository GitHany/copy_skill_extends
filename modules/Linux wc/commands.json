{
  "module": "Linux wc",
  "version": "2.0",
  "description": "Linux wc (word count) 词数统计命令。统计文件的行数、单词数、字符数，是文本分析的基础工具。用于统计代码行数、日志条目数、文件大小评估。常配合管道与其他命令组合使用。",
  "commands": [
    {
      "dirPath": "/Linux wc/",
      "name": "wc 统计",
      "keyword": "wc 统计",
      "description": "统计行数、单词数、字符数。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "wc %{选项}% %{文件}%",
        "extensions": [
          {
            "name": "统计行数",
            "description": "统计文件中的行数",
            "params": {
              "文件": {
                "example": "log.txt",
                "notes": "文件名"
              }
            },
            "cmd": "wc -l %{文件}%"
          },
          {
            "name": "统计单词数",
            "description": "统计文件中的单词数",
            "params": {
              "文件": {
                "example": "document.txt",
                "notes": "文件名"
              }
            },
            "cmd": "wc -w %{文件}%"
          },
          {
            "name": "统计字符数",
            "description": "统计文件中的字符数",
            "params": {
              "文件": {
                "example": "data.txt",
                "notes": "文件名"
              }
            },
            "cmd": "wc -c %{文件}%"
          },
          {
            "name": "显示所有统计",
            "description": "同时显示行数、单词数、字符数",
            "params": {
              "文件": {
                "example": "report.txt",
                "notes": "文件名"
              }
            },
            "cmd": "wc %{文件}%"
          },
          {
            "name": "从管道输入",
            "description": "统计管道传来的文本",
            "params": {
              "文本": {
                "example": "some text here",
                "notes": "输入文本"
              }
            },
            "cmd": "echo \"%{文本}%\" | wc"
          },
          {
            "name": "统计多个文件",
            "description": "同时统计多个文件的行数",
            "params": {
              "文件": {
                "example": "file1.txt file2.txt file3.txt",
                "notes": "文件列表"
              }
            },
            "cmd": "wc -l %{文件}%"
          },
          {
            "name": "只显示行数总计",
            "description": "对多个文件只显示总行数",
            "params": {
              "文件": {
                "example": "*.log",
                "notes": "文件模式"
              }
            },
            "cmd": "wc -l %{文件}% | tail -1"
          },
          {
            "name": "统计代码行数",
            "description": "排除空行和注释统计代码行数",
            "params": {
              "文件": {
                "example": "*.py",
                "notes": "代码文件"
              }
            },
            "cmd": "grep -v '^$\\|^#' %{文件}% | wc -l"
          }
        ],
        "params": {
          "选项": {
            "type": "string",
            "required": true,
            "description": "选项 l/w/c",
            "example": "-l",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件",
            "example": "file.txt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}