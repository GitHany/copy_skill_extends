{
  "module": "数据库/MySQL-客户端 mysql",
  "version": "2.0",
  "description": "MySQL 数据库 mysql 客户端，涵盖MySQL mysql的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/数据库/",
      "name": "mysql 连接数据库",
      "keyword": "mysql 连接",
      "description": "连接 MySQL 数据库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% %{数据库名}%",
        "extensions": [
          {
            "name": "指定端口连接",
            "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% -P %{端口}% %{数据库名}%",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "数据库主机",
                "example": "localhost",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "端口": {
                "type": "string",
                "required": true,
                "description": "端口",
                "example": "3306",
                "notes": "必填"
              },
              "数据库名": {
                "type": "string",
                "required": false,
                "description": "数据库名",
                "example": "mydb",
                "notes": "可选"
              }
            },
            "keyword": "mysql 端口"
          },
          {
            "name": "指定字符集连接",
            "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% --default-character-set=%{字符集}% %{数据库名}%",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "数据库主机",
                "example": "localhost",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "字符集": {
                "type": "string",
                "required": true,
                "description": "字符集",
                "example": "utf8mb4",
                "notes": "必填"
              },
              "数据库名": {
                "type": "string",
                "required": false,
                "description": "数据库名",
                "example": "mydb",
                "notes": "可选"
              }
            },
            "keyword": "mysql 字符集"
          },
          {
            "name": "使用 Socket 连接",
            "cmd": "mysql -u %{用户}% -p%{密码}% -S %{socket路径}% %{数据库名}%",
            "params": {
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "socket路径": {
                "type": "string",
                "required": true,
                "description": "Socket 路径",
                "example": "/tmp/mysql.sock",
                "notes": "必填"
              },
              "数据库名": {
                "type": "string",
                "required": false,
                "description": "数据库名",
                "example": "mydb",
                "notes": "可选"
              }
            },
            "keyword": "mysql socket"
          }
        ],
        "params": {
          "主机": {
            "type": "string",
            "required": true,
            "description": "数据库主机          ",
            "example": "localhost",
            "notes": "必填"
          },
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户名            ",
            "example": "root",
            "notes": "必填"
          },
          "密码": {
            "type": "string",
            "required": true,
            "description": "密码             ",
            "example": "password",
            "notes": "必填"
          },
          "数据库名": {
            "type": "string",
            "required": false,
            "description": "数据库名           ",
            "example": "mydb",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/数据库/",
      "name": "mysql 执行 SQL",
      "keyword": "mysql SQL",
      "description": "执行 SQL 文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% %{数据库}% < %{文件}%",
        "extensions": [
          {
            "name": "指定字符集执行",
            "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% --default-character-set=%{字符集}% %{数据库}% < %{文件}%",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机",
                "example": "localhost",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "字符集": {
                "type": "string",
                "required": true,
                "description": "字符集",
                "example": "utf8mb4",
                "notes": "必填"
              },
              "数据库": {
                "type": "string",
                "required": true,
                "description": "数据库",
                "example": "mydb",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "SQL 文件",
                "example": "script.sql",
                "notes": "必填"
              }
            },
            "keyword": "mysql charset 执行"
          },
          {
            "name": "执行并格式化输出",
            "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% -t %{数据库}% < %{文件}%",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机",
                "example": "localhost",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "数据库": {
                "type": "string",
                "required": true,
                "description": "数据库",
                "example": "mydb",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "SQL 文件",
                "example": "query.sql",
                "notes": "必填"
              }
            },
            "keyword": "mysql table 格式"
          },
          {
            "name": "安静模式执行",
            "cmd": "mysql -h %{主机}% -u %{用户}% -p%{密码}% -s %{数据库}% < %{文件}%",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机",
                "example": "localhost",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户",
                "example": "root",
                "notes": "必填"
              },
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password",
                "notes": "必填"
              },
              "数据库": {
                "type": "string",
                "required": true,
                "description": "数据库",
                "example": "mydb",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "SQL 文件",
                "example": "script.sql",
                "notes": "必填"
              }
            },
            "keyword": "mysql silent"
          }
        ],
        "params": {
          "主机": {
            "type": "string",
            "required": true,
            "description": "主机             ",
            "example": "localhost",
            "notes": "必填"
          },
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户             ",
            "example": "root",
            "notes": "必填"
          },
          "密码": {
            "type": "string",
            "required": true,
            "description": "密码             ",
            "example": "password",
            "notes": "必填"
          },
          "数据库": {
            "type": "string",
            "required": true,
            "description": "数据库            ",
            "example": "mydb",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "SQL 文件         ",
            "example": "script.sql",
            "notes": "必填"
          }
        }
      }
    }
  ]
}