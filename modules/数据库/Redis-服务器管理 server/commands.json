{
  "module": "数据库/Redis-服务器管理 server",
  "version": "1.0",
  "description": "Redis 服务器命令模块，涵盖Redis-服务器命令的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/数据库/",
      "name": "redis-cli 连接",
      "keyword": "redis-cli redis 连接",
      "description": "连接 Redis 服务器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "redis-cli -h %{主机}% -p %{端口}% -a %{密码}%",
        "extensions": [
          {
            "name": "本地默认连接",
            "cmd": "redis-cli",
            "params": {},
            "keyword": "redis-cli 本地"
          },
          {
            "name": "选择数据库",
            "cmd": "redis-cli -n %{数据库号}%",
            "params": {
              "数据库号": {
                "type": "number",
                "required": true,
                "description": "数据库编号          ",
                "example": "0",
                "notes": "常用"
              }
            },
            "keyword": "redis-cli 选择库"
          }
        ],
        "params": {
          "主机": {
            "type": "string",
            "required": false,
            "description": "Redis 主机地址     ",
            "example": "127.0.0.1",
            "notes": "默认 127.0.0.1"
          },
          "端口": {
            "type": "number",
            "required": false,
            "description": "Redis 端口       ",
            "example": "6379",
            "notes": "默认 6379"
          },
          "密码": {
            "type": "string",
            "required": false,
            "description": "Redis 密码       ",
            "example": "yourpassword",
            "notes": "无密码可省略 -a"
          }
        }
      }
    },
