{
  "module": "kubectl port-forward",
  "version": "2.0",
  "description": "kubectl 端口转发，涵盖kubectl port-forward的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl port-forward/",
      "name": "kubectl port-forward 端口转发",
      "keyword": "kubectl port-forward 转发",
      "description": "将本地端口转发到 Pod。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl port-forward %{类型}%/%{名称}% %{本地端口}%:%{目标端口}%",
        "extensions": [],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "资源类型",
            "example": "pod",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "资源名",
            "example": "my-pod",
            "notes": "必填"
          },
          "本地端口": {
            "type": "string",
            "required": true,
            "description": "本地端口",
            "example": "8080",
            "notes": "必填"
          },
          "目标端口": {
            "type": "string",
            "required": true,
            "description": "目标端口",
            "example": "80",
            "notes": "必填"
          }
        }
      }
    }
  ]
}