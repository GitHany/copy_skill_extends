{
  "module": "Linux systemctl",
  "version": "2.0",
  "description": "Systemd 服务管理，涵盖Linux systemctl的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux systemctl/",
      "name": "systemctl 管理服务",
      "keyword": "systemctl 服务",
      "description": "管理系统服务。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "systemctl %{操作}% %{服务}%",
        "extensions": [
          {
            "name": "查看状态",
            "cmd": "systemctl status %{服务}%",
            "params": {
              "服务": {
                "type": "string",
                "required": true,
                "description": "服务",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "systemctl status"
          },
          {
            "name": "启用开机",
            "cmd": "systemctl enable %{服务}%",
            "params": {
              "服务": {
                "type": "string",
                "required": true,
                "description": "服务",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "systemctl enable"
          }
        ],
        "params": {
          "操作": {
            "type": "string",
            "required": true,
            "description": "操作",
            "example": "start",
            "notes": "必填"
          },
          "服务": {
            "type": "string",
            "required": true,
            "description": "服务名",
            "example": "docker",
            "notes": "必填"
          }
        }
      }
    }
  ]
}