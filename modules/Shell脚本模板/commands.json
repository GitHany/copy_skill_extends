{
  "module": "Shell脚本模板",
  "version": "1.0",
  "description": "Shell脚本模板 模块命令集合",
  "commands": [
    {
      "dirPath": "/Shell脚本模板/",
      "name": "find 文件查找",
      "keyword": "find 查找文件 搜索",
      "description": "在目录树中搜索文件",
      "data": {
        "cmd": "find %{路径}% %{选项}% -name \"%{文件名}%\"",
        "extensions": [
          {
            "name": "按名称查找",
            "cmd": "find /path -name \"*.log\"",
            "params": {},
            "keyword": "find 按名称"
          },
          {
            "name": "按类型查找",
            "cmd": "find /path -type f -name \"*.txt\"",
            "params": {},
            "keyword": "find 文件类型"
          },
          {
            "name": "按大小查找",
            "cmd": "find /path -size +100M",
            "params": {},
            "keyword": "find 按大小"
          },
          {
            "name": "按时间查找",
            "cmd": "find /path -mtime -7",
            "params": {},
            "keyword": "find 修改时间"
          },
          {
            "name": "查找并执行",
            "cmd": "find /path -name \"*.log\" -exec gzip {} \\;",
            "params": {},
            "keyword": "find 执行命令"
          },
          {
            "name": "排除目录",
            "cmd": "find /path -not -path \"*/node_modules/*\"",
            "params": {},
            "keyword": "find 排除目录"
          }
        ],
        "params": {
          "路径": {
            "type": "string",
            "required": true,
            "description": "搜索的起始路径",
            "example": "/home/user",
            "notes": ""
          },
          "选项": {
            "type": "string",
            "required": false,
            "description": "find 选项",
            "example": "-type f",
            "notes": "常用"
          },
          "文件名": {
            "type": "string",
            "required": true,
            "description": "要查找的文件名模式",
            "example": "*.log",
            "notes": ""
          }
        }
      }
    },
    {
      "dirPath": "/Shell脚本模板/",
      "name": "grep 文本搜索",
      "keyword": "grep 搜索 查找 内容",
      "description": "在文件中搜索匹配的模式",
      "data": {
        "cmd": "grep %{选项}% \"%{模式}%\" %{文件路径}%",
        "extensions": [
          {
            "name": "递归搜索目录",
            "cmd": "grep -r \"pattern\" /path/to/dir",
            "params": {},
            "keyword": "grep 递归搜索"
          },
          {
            "name": "显示行号",
            "cmd": "grep -n \"pattern\" filename",
            "params": {},
            "keyword": "grep 行号"
          },
          {
            "name": "忽略大小写",
            "cmd": "grep -i \"pattern\" filename",
            "params": {},
            "keyword": "grep 忽略大小写"
          },
          {
            "name": "仅显示文件名",
            "cmd": "grep -l \"pattern\" *.log",
            "params": {},
            "keyword": "grep 文件名"
          },
          {
            "name": "正则表达式搜索",
            "cmd": "grep -E \"regex\" filename",
            "params": {},
            "keyword": "grep 正则"
          },
          {
            "name": "统计匹配行数",
            "cmd": "grep -c \"pattern\" filename",
            "params": {},
            "keyword": "grep 统计"
          }
        ],
        "params": {
          "选项": {
            "type": "string",
            "required": false,
            "description": "grep 选项",
            "example": "-rn",
            "notes": "常用"
          },
          "模式": {
            "type": "string",
            "required": true,
            "description": "要搜索的模式或正则表达式",
            "example": "error",
            "notes": ""
          },
          "文件路径": {
            "type": "string",
            "required": true,
            "description": "要搜索的文件路径",
            "example": "/var/log/syslog",
            "notes": ""
          }
        }
      }
    },
    {
      "dirPath": "/Shell脚本模板/",
      "name": "awk 数据处理",
      "keyword": "awk 数据处理 文本",
      "description": "强大的文本分析和报告生成工具",
      "data": {
        "cmd": "awk '%{模式}%' %{文件路径}%",
        "extensions": [
          {
            "name": "打印指定列",
            "cmd": "awk '{print $1,$3}' filename",
            "params": {},
            "keyword": "awk 打印列"
          },
          {
            "name": "按分隔符提取",
            "cmd": "awk -F',' '{print $2}' filename",
            "params": {},
            "keyword": "awk 分隔符"
          },
          {
            "name": "条件筛选",
            "cmd": "awk '/pattern/ {print $0}' filename",
            "params": {},
            "keyword": "awk 条件"
          },
          {
            "name": "数值计算",
            "cmd": "awk '{sum+=$1} END {print sum}' filename",
            "params": {},
            "keyword": "awk 计算"
          },
          {
            "name": "格式化输出",
            "cmd": "awk 'printf \"%s: %.2f\\n\", $1, $2' filename",
            "params": {},
            "keyword": "awk 格式化"
          },
          {
            "name": "多条件判断",
            "cmd": "awk '$3 > 100 {print $1}' filename",
            "params": {},
            "keyword": "awk 多条件"
          }
        ],
        "params": {
          "模式": {
            "type": "string",
            "required": true,
            "description": "awk 模式和动作",
            "example": "'{print $1}'",
            "notes": ""
          },
          "文件路径": {
            "type": "string",
            "required": true,
            "description": "要处理的文件路径",
            "example": "/home/user/data.txt",
            "notes": ""
          }
        }
      }
    },
    {
      "dirPath": "/Shell脚本模板/",
      "name": "sed 流编辑",
      "keyword": "sed 流编辑 替换",
      "description": "流编辑器，用于文本替换和转换",
      "data": {
        "cmd": "sed %{选项}% 's/%{原字符串}%/%{新字符串}%/%{标志}%' %{文件路径}%",
        "extensions": [
          {
            "name": "全局替换",
            "cmd": "sed 's/old/new/g' filename",
            "params": {},
            "keyword": "sed 全局替换"
          },
          {
            "name": "原地替换",
            "cmd": "sed -i 's/old/new/g' filename",
            "params": {},
            "keyword": "sed 原地编辑"
          },
          {
            "name": "删除行",
            "cmd": "sed '2d' filename",
            "params": {},
            "keyword": "sed 删除行"
          },
          {
            "name": "插入文本",
            "cmd": "sed '1i\\new line' filename",
            "params": {},
            "keyword": "sed 插入"
          },
          {
            "name": "追加文本",
            "cmd": "sed '$a\\new line' filename",
            "params": {},
            "keyword": "sed 追加"
          },
          {
            "name": "正则替换",
            "cmd": "sed -E 's/[0-9]+/NUM/g' filename",
            "params": {},
            "keyword": "sed 正则"
          }
        ],
        "params": {
          "选项": {
            "type": "string",
            "required": false,
            "description": "sed 选项",
            "example": "-i",
            "notes": "-i 原地编辑"
          },
          "原字符串": {
            "type": "string",
            "required": true,
            "description": "要替换的原字符串",
            "example": "old",
            "notes": ""
          },
          "新字符串": {
            "type": "string",
            "required": true,
            "description": "替换后的新字符串",
            "example": "new",
            "notes": ""
          },
          "标志": {
            "type": "string",
            "required": false,
            "description": "替换标志",
            "example": "g",
            "notes": "g 全局替换"
          },
          "文件路径": {
            "type": "string",
            "required": true,
            "description": "要处理的文件路径",
            "example": "/home/user/data.txt",
            "notes": ""
          }
        }
      }
    },
    {
      "dirPath": "/Shell脚本模板/",
      "name": "xargs 参数传递",
      "keyword": "xargs 参数",
      "description": "将标准输入转换为命令行参数",
