            },
            "keyword": "curl verbose 详情",
            "notes": "常用"
          },
          {
            "name": "显示响应头",
            "cmd": "curl -i %{URL}%",
            "params": {
              "URL": { "type": "string", "required": true, "description": "请求 URL", "example": "https://api.example.com", "notes": "常用" }
            },
            "keyword": "curl include 响应头"
          },
          {
            "name": "用户认证",
