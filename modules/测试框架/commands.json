            "params": {
              "URL": { "type": "string", "required": true, "description": "请求 URL", "example": "https://api.example.com/users", "notes": "常用" },
              "JSON数据": { "type": "string", "required": true, "description": "JSON 请求体", "example": "{\"name\":\"test\"}", "notes": "常用" }
            },
            "keyword": "curl POST 请求"
          },
          {
            "name": "带请求头",
            "cmd": "curl -H \"%{请求头}%\" %{URL}%",
            "params": {
              "请求头": { "type": "string", "required": true, "description": "HTTP 请求头", "example": "Authorization: Bearer token123", "notes": "常用" },
              "URL": { "type": "string", "required": true, "description": "请求 URL", "example": "https://api.example.com/users", "notes": "常用" }
            },
            "keyword": "curl header 请求头",
            "notes": "常用"
