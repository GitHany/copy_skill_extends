{
  "module": "Git 标签",
  "version": "2.0",
  "description": "Git 标签命令集合，涵盖Git 标签的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Git 标签/",
      "name": "git tag 创建标签",
      "keyword": "git tag 创建",
      "description": "创建轻量标签。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git tag %{标签名}%",
        "extensions": [
          {
            "name": "创建附注标签",
            "cmd": "git tag -a %{标签}% -m '%{消息}%'",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "标签名",
                "example": "v1.0.0",
                "notes": "必填"
              },
              "消息": {
                "type": "string",
                "required": true,
                "description": "标签消息",
                "example": "Release version 1.0",
                "notes": "必填"
              }
            },
            "keyword": "git tag annotated"
          }
        ],
        "params": {
          "标签名": {
            "type": "string",
            "required": true,
            "description": "标签名",
            "example": "v1.0.0",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Git 标签/",
      "name": "git tag -l 列出标签",
      "keyword": "git tag 列表",
      "description": "列出所有标签。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git tag -l",
        "extensions": [],
        "params": {}
      }
    }
  ]
}