{
  "module": "Git push",
  "version": "2.0",
  "description": "Git 推送更新 — 将本地分支和提交推送到远程仓库。用于与团队共享代码、备份工作、触发 CI/CD 流程。常见场景：功能开发完成后推送到远程、推送新分支供 code review、推送标签发布版本、更新子模块。",
  "commands": [
    {
      "dirPath": "/Git push/",
      "name": "git push 推送",
      "keyword": "git push 推送",
      "description": "推送到远程仓库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git push %{远程}% %{分支}%",
        "extensions": [
          {
            "name": "推送并设置上游分支",
            "cmd": "git push -u %{远程}% %{分支}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "首次推送时使用，关联本地和远程分支"
              }
            },
            "keyword": "git push set upstream track"
          },
          {
            "name": "强制推送（谨慎使用）",
            "cmd": "git push --force %{远程}% %{分支}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "覆盖远程历史，用于修改提交后同步，慎用"
              }
            },
            "keyword": "git push force override"
          },
          {
            "name": "删除远程分支",
            "cmd": "git push %{远程}% --delete %{分支}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "删除远程已不需要的分支"
              }
            },
            "keyword": "git push delete remote branch"
          },
          {
            "name": "推送所有分支",
            "cmd": "git push --all %{远程}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "一次性推送所有本地分支到远程"
              }
            },
            "keyword": "git push all branches"
          },
          {
            "name": "推送标签",
            "cmd": "git push %{远程}% --tags",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "推送所有本地标签到远程"
              }
            },
            "keyword": "git push tags 标签"
          },
          {
            "name": "推送单个标签",
            "cmd": "git push %{远程}% %{标签}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库",
                "example": "origin",
                "notes": "推送指定的标签"
              }
            },
            "keyword": "git push single tag"
          },
          {
            "name": "推送子模块更新",
            "cmd": "git push --recurse-submodules=on-demand",
            "params": {},
            "keyword": "git push submodule 子模块"
          },
          {
            "name": "预演推送（查看将要推送的内容）",
            "cmd": "git push --dry-run",
            "params": {},
            "keyword": "git push dry run preview"
          }
        ],
        "params": {
          "远程": {
            "type": "string",
            "required": false,
            "description": "远程仓库名称",
            "example": "origin",
            "notes": "可选，默认 origin"
          },
          "分支": {
            "type": "string",
            "required": false,
            "description": "要推送的分支名",
            "example": "main",
            "notes": "可选，默认当前分支"
          }
        }
      }
    }
  ]
}