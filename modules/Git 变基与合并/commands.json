          "type": "string",
          "required": true,
          "description": "分支名",
          "example": "feature",
          "notes": "必填"
        }
      },
      "keyword": "git merge noff",
      "dirPath": "/Git 变基与合并/",
      "description": "禁止快进的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    },
    {
