{
  "module": "Docker pull",
  "version": "2.0",
  "description": "从远程仓库下载 Docker 镜像到本地电脑。新手必学！当你看到别人的项目想运行、或者需要初始化一个新环境时就需要用它。就像从应用商店下载 App 一样简单。常见场景：下载别人的项目运行、本地搭建测试环境、获取基础系统镜像。",
  "commands": [
    {
      "dirPath": "/Docker pull/",
      "name": "docker pull 拉取镜像",
      "keyword": "docker pull 拉取",
      "description": "从仓库下载镜像到本地（新手必学）。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker pull %{镜像}%",
        "extensions": [
          {
            "name": "docker pull 拉取指定标签版本",
            "description": "下载镜像的特定版本（不写默认 latest）",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名:标签",
                "example": "nginx:1.25",
                "notes": "必填：如不写标签默认拉 latest"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull 拉取所有标签",
            "description": "下载该镜像的所有可用版本（占用磁盘较多）",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "ubuntu",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull -a 拉取全标签",
            "description": "简写方式，拉取该镜像的所有标签版本",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "node",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull --all-tags 拉取所有标签",
            "description": "完整写法，拉取仓库中该镜像的全部标签",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "python",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull --quiet 静默拉取",
            "description": "不显示下载进度条，适合脚本自动化",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "alpine",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull 私有仓库拉取",
            "description": "从需要登录的私有仓库下载镜像",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "完整镜像路径",
                "example": "myregistry.com/myapp:v1",
                "notes": "必填：需先登录 docker login"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull --disable-content-trust 跳过验证",
            "description": "跳过镜像签名验证（测试环境用）",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "test-image:v1",
                "notes": "生产环境不建议跳过"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker pull 拉取并直接运行",
            "description": "下载完成后自动启动容器（两步合并一步）",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "nginx",
                "notes": "等价于 pull + run"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "镜像": {
            "type": "string",
            "required": true,
            "description": "镜像名",
            "example": "nginx:latest",
            "notes": "必填：如不写标签默认 latest"
          }
        }
      }
    }
  ]
}