      "keyword": "pinia 安装 store 状态",
      "description": "为 Vue 3 项目安装并配置 Pinia 状态管理库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm install pinia",
        "extensions": [
          {
            "name": "创建 Pinia Store",
            "cmd": "cat > src/stores/%{仓库名}%.js << 'EOF'\nimport { defineStore } from 'pinia'\n\nexport const use%{仓库名}% = defineStore('%{仓库名}%', {\n  state: () => ({ count: 0 }),\n  getters: {\n    double: (state) => state.count * 2\n  },\n  actions: {\n    increment() { this.count++ }\n  }\n})\nEOF",
            "params": {
              "仓库名": {
                "type": "string",
                "required": true,
                "description": "Store 名称       ",
                "example": "counter",
                "notes": "常用"
              }
            },
            "keyword": "pinia store"
          },
          {
            "name": "组合式风格 Store",
            "cmd": "cat > src/stores/%{仓库名}%.js << 'EOF'\nimport { defineStore } from 'pinia'\nimport { ref, computed } from 'vue'\n\nexport const use%{仓库名}% = defineStore('%{仓库名}%', () => {\n  const count = ref(0)\n  const double = computed(() => count.value * 2)\n  function increment() { count.value++ }\n  return { count, double, increment }\n})\nEOF",
            "params": {
              "仓库名": {
                "type": "string",
                "required": true,
                "description": "Store 名称       ",
                "example": "counter",
                "notes": "常用"
