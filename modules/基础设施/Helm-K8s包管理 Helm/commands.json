    {
      "dirPath": "/基础设施/",
      "name": "helm lint 检查 Chart",
      "keyword": "helm lint 检查",
      "description": "检查 Chart 的语法和最佳实践。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm lint %{Chart路径}%",
        "extensions": [
          {
            "name": "严格模式检查",
            "cmd": "helm lint %{Chart路径}% --strict",
            "params": {
              "Chart路径": {
                "type": "string",
                "required": true,
                "description": "Chart 目录路径",
                "example": "./my-chart",
                "notes": "必填"
              }
            },
            "keyword": "helm lint strict"
          },
          {
            "name": "带值检查",
            "cmd": "helm lint %{Chart路径}% -f %{值文件}%",
            "params": {
              "Chart路径": {
                "type": "string",
                "required": true,
                "description": "Chart 目录路径",
                "example": "./my-chart",
                "notes": "必填"
              },
              "值文件": {
                "type": "string",
                "required": true,
                "description": "Values 文件路径",
                "example": "values.yaml",
                "notes": "必填"
              }
            },
            "keyword": "helm lint values"
          },
          {
            "name": "检查 Chart 归档",
            "cmd": "helm lint %{Chart路径}%.tgz",
            "params": {
              "Chart路径": {
                "type": "string",
                "required": true,
                "description": "Chart 归档文件路径",
                "example": "./my-chart",
                "notes": "必填"
              }
            },
            "keyword": "helm lint package"
          }
        ],
        "params": {
          "Chart路径": {
            "type": "string",
            "required": true,
            "description": "Chart 目录路径     ",
            "example": "./my-chart",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm package 打包 Chart",
      "keyword": "helm package 打包",
      "description": "将 Chart 打包为可分发的归档文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm package %{Chart路径}%",
        "extensions": [
          {
            "name": "签名打包",
            "cmd": "helm package %{Chart路径}% --sign --key %{密钥}% --keyring %{密钥环}%",
            "params": {
              "Chart路径": {
                "type": "string",
                "required": true,
                "description": "Chart 目录路径",
                "example": "./my-chart",
                "notes": "必填"
              },
              "密钥": {
                "type": "string",
                "required": true,
                "description": "GPG 密钥 ID",
