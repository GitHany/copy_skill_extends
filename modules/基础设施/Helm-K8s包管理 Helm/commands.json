                "notes": "必填"
              },
              "输出目录": {
                "type": "string",
                "required": true,
                "description": "输出目录路径",
                "example": "./charts",
                "notes": "必填"
              }
            },
            "keyword": "helm package directory"
          },
          {
            "name": "验证 Chart",
            "cmd": "helm package %{Chart路径}% --verify",
            "params": {
              "Chart路径": {
                "type": "string",
                "required": true,
                "description": "Chart 目录路径",
                "example": "./my-chart",
                "notes": "必填"
              }
            },
            "keyword": "helm package verify"
          }
        ],
        "params": {
          "Chart路径": {
            "type": "string",
            "required": true,
            "description": "要打包的 Chart 目录  ",
            "example": "./my-chart",
            "notes": "必填"
          }
        }
      }
    },
