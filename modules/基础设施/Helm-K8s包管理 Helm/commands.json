{
  "module": "基础设施/Helm-K8s包管理 Helm",
  "version": "2.0",
  "description": "Helm 模块，提供 Kubernetes 包管理器 Helm 相关命令和工具。适用于开发、测试和生产环境的操作和自动化",
  "commands": [
    {
      "dirPath": "/基础设施/",
      "name": "helm install 安装 Chart",
      "keyword": "helm install 安装",
      "description": "安装 Helm Chart 到 Kubernetes 集群。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm install %{Release名称}% %{Chart名称}%",
        "extensions": [
          {
            "name": "指定命名空间安装",
            "cmd": "helm install %{Release名称}% %{Chart名称}% -n %{命名空间}% --create-namespace",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Helm Release 的唯一名称",
                "example": "my-nginx",
                "notes": "必填"
              },
              "Chart名称": {
                "type": "string",
                "required": true,
                "description": "Chart 名称或仓库引用  ",
                "example": "bitnami/nginx",
                "notes": "必填"
              },
              "命名空间": {
                "type": "string",
                "required": true,
                "description": "Kubernetes 命名空间",
                "example": "production",
                "notes": "必填"
              }
            },
            "keyword": "helm install 命名空间"
          },
          {
            "name": "自定义值安装",
            "cmd": "helm install %{Release名称}% %{Chart名称}% -f %{配置文件}%",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Helm Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "Chart名称": {
                "type": "string",
                "required": true,
                "description": "Chart 名称       ",
                "example": "stable/mysql",
                "notes": "必填"
              },
              "配置文件": {
                "type": "string",
                "required": true,
                "description": "自定义 values YAML 文件",
                "example": "values-prod.yaml",
                "notes": "必填"
              }
            },
            "keyword": "helm install 自定义值"
          },
          {
            "name": "设置值安装",
            "cmd": "helm install %{Release名称}% %{Chart名称}% --set %{键}%=%{值}%",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Helm Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "Chart名称": {
                "type": "string",
                "required": true,
                "description": "Chart 名称       ",
                "example": "bitnami/redis",
                "notes": "必填"
              },
              "键": {
                "type": "string",
                "required": true,
                "description": "要设置的配置键        ",
                "example": "image.tag",
                "notes": "必填"
              },
              "值": {
                "type": "string",
                "required": true,
                "description": "配置值            ",
                "example": "7.0",
                "notes": "必填"
              }
            },
            "keyword": "helm install set"
          }
        ],
        "params": {
          "Release名称": {
            "type": "string",
            "required": true,
            "description": "Helm Release 的唯一名称标识",
            "example": "my-release",
            "notes": "必填。同一命名空间内不能重复"
          },
          "Chart名称": {
            "type": "string",
            "required": true,
            "description": "要安装的 Chart 名称，可以是本地路径或仓库引用",
            "example": "bitnami/nginx",
            "notes": "必填。格式：仓库名/Chart名 或本地路径"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm upgrade 升级 Release",
      "keyword": "helm upgrade 升级",
      "description": "升级已安装的 Helm Release 到新版本的 Chart",
      "data": {
        "cmd": "helm upgrade %{Release名称}% %{Chart名称}%",
        "extensions": [
          {
            "name": "升级并回滚失败",
            "cmd": "helm upgrade %{Release名称}% %{Chart名称}% --atomic --timeout 300s",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "要升级的 Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "Chart名称": {
                "type": "string",
                "required": true,
                "description": "新版本 Chart      ",
                "example": "bitnami/nginx",
                "notes": "必填"
              }
            },
            "keyword": "helm upgrade atomic"
          },
          {
            "name": "使用历史值升级",
            "cmd": "helm upgrade %{Release名称}% %{Chart名称}% --reuse-values",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Release 名称     ",
                "example": "myapp",
                "notes": "必填"
              },
              "Chart名称": {
                "type": "string",
                "required": true,
                "description": "新 Chart 版本     ",
                "example": "bitnami/nginx",
                "notes": "必填"
              }
            },
            "keyword": "helm upgrade reuse-values"
          }
        ],
        "params": {
          "Release名称": {
            "type": "string",
            "required": true,
            "description": "要升级的 Release 名称",
            "example": "my-release",
            "notes": "必填"
          },
          "Chart名称": {
            "type": "string",
            "required": true,
            "description": "升级到的 Chart 版本  ",
            "example": "bitnami/nginx",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm uninstall 卸载 Release",
      "keyword": "helm uninstall 卸载",
      "description": "卸载已安装的 Helm Release 及其所有资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm uninstall %{Release名称}%",
        "extensions": [
          {
            "name": "卸载并保留历史",
            "cmd": "helm uninstall %{Release名称}% --keep-history",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "要卸载的 Release 名称",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "helm uninstall 保留历史"
          }
        ],
        "params": {
          "Release名称": {
            "type": "string",
            "required": true,
            "description": "要卸载的 Release 名称",
            "example": "my-release",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm list 列出 Release",
      "keyword": "helm list 列表",
      "description": "列出当前命名空间中已安装的 Helm Release。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm list",
        "extensions": [
          {
            "name": "列出所有命名空间",
            "cmd": "helm list --all-namespaces",
            "params": {},
            "keyword": "helm list 全部"
          },
          {
            "name": "指定命名空间",
            "cmd": "helm list -n %{命名空间}%",
            "params": {
              "命名空间": {
                "type": "string",
                "required": true,
                "description": "Kubernetes 命名空间",
                "example": "production",
                "notes": "必填"
              }
            },
            "keyword": "helm list 命名空间"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm repo 管理仓库",
      "keyword": "helm repo 仓库",
      "description": "添加、更新和删除 Helm Chart 仓库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm repo add %{仓库名}% %{URL}%",
        "extensions": [
          {
            "name": "更新所有仓库",
            "cmd": "helm repo update",
            "params": {},
            "keyword": "helm repo update"
          },
          {
            "name": "删除仓库",
            "cmd": "helm repo remove %{仓库名}%",
            "params": {
              "仓库名": {
                "type": "string",
                "required": true,
                "description": "仓库名称           ",
                "example": "bitnami",
                "notes": "必填"
              }
            },
            "keyword": "helm repo remove"
          },
          {
            "name": "列出仓库",
            "cmd": "helm repo list",
            "params": {},
            "keyword": "helm repo list"
          }
        ],
        "params": {
          "仓库名": {
            "type": "string",
            "required": true,
            "description": "Helm 仓库的本地名称   ",
            "example": "bitnami",
            "notes": "必填"
          },
          "URL": {
            "type": "string",
            "required": true,
            "description": "仓库的 URL 地址     ",
            "example": "https://charts.bitnami.com/bitnami",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm rollback 回滚 Release",
      "keyword": "helm rollback 回滚",
      "description": "将 Release 回滚到之前的版本。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "helm rollback %{Release名称}% %{版本号}%",
        "extensions": [
          {
            "name": "等待就绪回滚",
            "cmd": "helm rollback %{Release名称}% %{版本号}% --wait --timeout 300s",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "要回滚的 Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "版本号": {
                "type": "string",
                "required": true,
                "description": "目标修订版本号",
                "example": "1",
                "notes": "必填"
              }
            },
            "keyword": "helm rollback wait"
          },
          {
            "name": "指定命名空间回滚",
            "cmd": "helm rollback %{Release名称}% %{版本号}% -n %{命名空间}%",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "版本号": {
                "type": "string",
                "required": true,
                "description": "目标修订版本号",
                "example": "1",
                "notes": "必填"
              },
              "命名空间": {
                "type": "string",
                "required": true,
                "description": "Kubernetes 命名空间",
                "example": "production",
                "notes": "必填"
              }
            },
            "keyword": "helm rollback namespace"
          },
          {
            "name": "原子回滚",
            "cmd": "helm rollback %{Release名称}% %{版本号}% --atomic",
            "params": {
              "Release名称": {
                "type": "string",
                "required": true,
                "description": "Release 名称",
                "example": "myapp",
                "notes": "必填"
              },
              "版本号": {
                "type": "string",
                "required": true,
                "description": "目标修订版本号",
                "example": "1",
                "notes": "必填"
              }
            },
            "keyword": "helm rollback atomic"
          }
        ],
        "params": {
          "Release名称": {
            "type": "string",
            "required": true,
            "description": "要回滚的 Release 名称",
            "example": "my-release",
            "notes": "必填"
          },
          "版本号": {
            "type": "string",
            "required": true,
            "description": "要回滚到的修订版本号     ",
            "example": "2",
            "notes": "必填。使用 helm history 查看历史版本"
          }
        }
      }
    },
    {
      "dirPath": "/基础设施/",
      "name": "helm template 渲染模板",
