    {
      "dirPath": "/基础设施/",
      "name": "terraform init 初始化",
      "keyword": "terraform init 初始化",
      "description": "初始化 Terraform 工作目录。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "terraform init",
        "extensions": [
          {
            "name": "升级插件",
            "cmd": "terraform init -upgrade",
            "params": {},
            "keyword": "terraform init upgrade"
          },
          {
            "name": "获取模块",
            "cmd": "terraform init -get-plugins=false -get-modules=false",
            "params": {},
            "keyword": "terraform init plugins"
          },
          {
            "name": "指定后端",
            "cmd": "terraform init -backend-config=%{配置}%",
            "params": {
              "配置": {
                "type": "string",
                "required": true,
                "description": "后端配置",
                "example": "backend.hcl",
                "notes": "必填"
              }
            },
            "keyword": "terraform init backend"
          },
          {
            "name": "从模块初始化",
            "cmd": "terraform init -from-module=%{模块源}%",
            "params": {
              "模块源": {
                "type": "string",
                "required": true,
                "description": "模块源路径",
                "example": "./module",
                "notes": "必填"
              }
            },
            "keyword": "terraform init module"
          }
        ],
        "params": {}
      }
    },
