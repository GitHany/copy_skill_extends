{
  "module": "kubectl create",
  "version": "2.0",
  "description": "通过 YAML/JSON 配置文件或命令行参数创建 Kubernetes 资源（如 Deployment、Service、ConfigMap 等）。适合快速部署简单资源，或通过文件管理复杂配置。",
  "commands": [
    {
      "dirPath": "/kubectl create/",
      "name": "kubectl create 创建资源",
      "keyword": "kubectl create 创建 部署 配置",
      "description": "通过命令行参数快速创建单个资源，或通过文件创建多个资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl create %{类型}% %{名称}%",
        "extensions": [
          {
            "name": "从 YAML 文件创建资源",
            "cmd": "kubectl create -f %{文件路径}%",
            "params": {
              "文件路径": {
                "type": "string",
                "required": true,
                "description": "YAML/JSON 文件路径",
                "example": "./deployment.yaml",
                "notes": "支持 YAML 和 JSON 格式，可创建单个或多个资源"
              }
            },
            "keyword": "kubectl create 文件部署",
            "description": "通过 YAML 或 JSON 文件创建 Kubernetes 资源，是基础设施即代码（IaC）的常用方式"
          },
          {
            "name": "从 stdin 读取配置创建资源",
            "cmd": "cat %{文件}% | kubectl create -f -",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "配置文件路径",
                "example": "./config.yaml",
                "notes": "常用于管道组合，如 kubectl create -f <(cat config.yaml)"
              }
            },
            "keyword": "kubectl create stdin",
            "description": "通过管道将文件内容传递给 kubectl 创建资源，适用于动态生成配置的场景"
          },
          {
            "name": "创建 Deployment 并指定镜像",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment 名称",
                "example": "myapp",
                "notes": "必填，会创建同名 ReplicaSet"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "容器镜像",
                "example": "nginx:1.25",
                "notes": "推荐指定版本标签，避免使用 latest"
              }
            },
            "keyword": "kubectl create deployment",
            "description": "快速创建 Deployment 并指定容器镜像，适用于快速测试和小规模部署"
          },
          {
            "name": "创建命名空间",
            "cmd": "kubectl create namespace %{命名空间}%",
            "params": {
              "命名空间": {
                "type": "string",
                "required": true,
                "description": "命名空间名称",
                "example": "dev",
                "notes": "命名空间名称不能重复，创建前可先查看现有命名空间"
              }
            },
            "keyword": "kubectl create namespace",
            "description": "创建新的命名空间，用于隔离不同环境或团队的资源"
          },
          {
            "name": "创建 ConfigMap（从文件）",
            "cmd": "kubectl create configmap %{名称}% --from-file=%{文件路径}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "ConfigMap 名称",
                "example": "app-config",
                "notes": "文件名会成为 ConfigMap 中的 key"
              },
              "文件路径": {
                "type": "string",
                "required": true,
                "description": "配置文件路径",
                "example": "./config.properties",
                "notes": "支持多个文件，目录下的所有文件会被包含"
              }
            },
            "keyword": "kubectl create configmap",
            "description": "从本地文件创建 ConfigMap，常用于存储应用配置文件"
          },
          {
            "name": "创建 Secret（密钥对）",
            "cmd": "kubectl create secret generic %{名称}% --from-literal=key=%{值}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Secret 名称",
                "example": "db-credentials",
                "notes": "用于存储敏感信息，如密码、Token 等"
              },
              "值": {
                "type": "string",
                "required": true,
                "description": "密钥值",
                "example": "mysecretpassword",
                "notes": "敏感信息建议使用 --from-env-file 或从文件加载"
              }
            },
            "keyword": "kubectl create secret",
            "description": "创建 Secret 存储敏感配置，如数据库密码、API 密钥等"
          },
          {
            "name": "覆盖已存在资源（幂等创建）",
            "cmd": "kubectl create -f %{文件路径}% --force",
            "params": {
              "文件路径": {
                "type": "string",
                "required": true,
                "description": "YAML/JSON 文件路径",
                "example": "./deployment.yaml",
                "notes": "会先删除已存在的资源再重新创建，可能导致服务中断"
              }
            },
            "keyword": "kubectl create 覆盖",
            "description": "强制创建资源，如果资源已存在则先删除再创建，适用于配置更新的快速迭代"
          },
          {
            "name": "查看已创建资源的详细信息",
            "cmd": "kubectl get %{类型}% %{名称}% -o yaml",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型",
                "example": "deployment",
                "notes": "如 deployment, pod, service 等"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "资源名称",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create 查看资源",
            "description": "查看已创建资源的完整 YAML 配置，常用于导出配置或调试"
          }
        ],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "资源类型",
            "example": "deployment",
            "notes": "必填，支持 deployment, configmap, secret, namespace 等"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "资源名称",
            "example": "myapp",
            "notes": "必填，建议使用有意义的名称"
          }
        }
      }
    }
  ]
}