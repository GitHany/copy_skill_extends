          }
        ],
        "params": {
          "驱动名称": { "type": "string", "required": false, "description": "CSI 驱动名称", "example": "ebs.csi.aws.com", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl get ingress 查看 Ingress",
      "keyword": "kubectl get ingress",
      "description": "查看和管理 Ingress 入口规则",
      "data": {
        "cmd": "kubectl get ingress -n %{命名空间}%",
        "extensions": [
          {
            "name": "查看 IngressClass",
            "cmd": "kubectl get ingressclass",
            "params": {},
            "keyword": "kubectl get ingressclass"
          },
          {
            "name": "设置默认 IngressClass",
            "cmd": "kubectl annotate ingressclass %{类名}% ingressclass.kubernetes.io/is-default-class=\"true\"",
            "params": {
              "类名": { "type": "string", "required": true, "description": "IngressClass 名称", "example": "nginx", "notes": "" }
            },
            "keyword": "kubectl annotate ingressclass"
          },
          {
            "name": "查看 Ingress 详情",
            "cmd": "kubectl describe ingress %{Ingress名称}% -n %{命名空间}%",
            "params": {},
            "keyword": "kubectl describe ingress"
          }
        ],
        "params": {
