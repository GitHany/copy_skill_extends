{
  "module": "Kubernetes 高级操作",
  "version": "1.0",
  "description": "Kubernetes 高级操作命令模块，涵盖 Operators、RBAC、存储、网络、监控和故障排查",
  "commands": [
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "operator-sdk create api 创建 CRD API",
      "keyword": "operator-sdk create api",
      "description": "使用 Operator SDK 创建自定义资源定义和控制器",
      "data": {
        "cmd": "operator-sdk create api --group %{组名}% --version %{版本}% --kind %{类型}% --resource --controller",
        "extensions": [
          {
            "name": "初始化 Operator 项目",
            "cmd": "operator-sdk init --domain %{域名}% --repo %{仓库}%",
            "params": {
              "域名": { "type": "string", "required": true, "description": "域名", "example": "my.domain", "notes": "必填" },
              "仓库": { "type": "string", "required": true, "description": "仓库路径", "example": "github.com/myorg/project", "notes": "必填" }
            },
            "keyword": "operator-sdk init"
          },
          {
            "name": "创建 Webhook",
            "cmd": "operator-sdk create webhook --group %{组名}% --version %{版本}% --kind %{类型}%",
            "params": {
              "组名": { "type": "string", "required": true, "description": "API 组名", "example": "apps", "notes": "" },
              "版本": { "type": "string", "required": true, "description": "API 版本", "example": "v1", "notes": "" },
              "类型": { "type": "string", "required": true, "description": "CRD 类型名", "example": "MyOperator", "notes": "" }
            },
            "keyword": "operator-sdk create webhook"
          },
          {
            "name": "本地运行 Operator",
            "cmd": "operator-sdk run --local --namespace=%{命名空间}%",
            "params": {
              "命名空间": { "type": "string", "required": true, "description": "命名空间", "example": "default", "notes": "" }
            },
            "keyword": "operator-sdk run local"
          },
          {
            "name": "生成 kustomize manifests",
            "cmd": "operator-sdk generate kustomize manifests",
            "params": {},
            "keyword": "operator-sdk generate kustomize"
          },
          {
            "name": "构建 Operator 镜像",
            "cmd": "operator-sdk build %{镜像}%",
            "params": {
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "myorg/my-operator:v1.0.0", "notes": "" }
            },
            "keyword": "operator-sdk build"
          }
        ],
        "params": {
          "组名": { "type": "string", "required": true, "description": "API 组名", "example": "apps", "notes": "" },
          "版本": { "type": "string", "required": true, "description": "API 版本", "example": "v1", "notes": "" },
          "类型": { "type": "string", "required": true, "description": "CRD 类型名", "example": "MyOperator", "notes": "" },
          "域名": { "type": "string", "required": false, "description": "域名", "example": "my.domain", "notes": "" },
          "仓库": { "type": "string", "required": false, "description": "仓库路径", "example": "github.com/myorg/project", "notes": "" },
          "命名空间": { "type": "string", "required": false, "description": "命名空间", "example": "default", "notes": "" },
          "镜像": { "type": "string", "required": false, "description": "镜像名称", "example": "myorg/my-operator:v1.0.0", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubebuilder 创建 API",
      "keyword": "kubebuilder create api",
      "description": "使用 kubebuilder 创建 CRD 和控制器代码",
      "data": {
        "cmd": "kubebuilder create api --group %{组名}% --version %{版本}% --kind %{类型}%",
        "extensions": [
          {
            "name": "初始化 kubebuilder 项目",
            "cmd": "kubebuilder init --domain %{域名}% --repo %{仓库}%",
            "params": {
              "域名": { "type": "string", "required": true, "description": "域名", "example": "my.domain", "notes": "" },
              "仓库": { "type": "string", "required": true, "description": "仓库路径", "example": "github.com/myorg/project", "notes": "" }
            },
            "keyword": "kubebuilder init"
          },
          {
            "name": "创建 Webhook",
            "cmd": "kubebuilder create webhook --group %{组名}% --version %{版本}% --kind %{类型}%",
            "params": {
              "组名": { "type": "string", "required": true, "description": "API 组名", "example": "apps", "notes": "" },
              "版本": { "type": "string", "required": true, "description": "API 版本", "example": "v1", "notes": "" },
              "类型": { "type": "string", "required": true, "description": "CRD 类型名", "example": "MyOperator", "notes": "" }
            },
            "keyword": "kubebuilder create webhook"
          },
          {
            "name": "创建多版本 API",
            "cmd": "kubebuilder create api --group %{组名}% --version %{版本1}% --version %{版本2}% --kind %{类型}%",
            "params": {
              "版本1": { "type": "string", "required": true, "description": "初始版本", "example": "v1", "notes": "" },
              "版本2": { "type": "string", "required": true, "description": "新增版本", "example": "v2", "notes": "" }
            },
            "keyword": "kubebuilder 多版本 API"
          }
        ],
        "params": {
          "组名": { "type": "string", "required": true, "description": "API 组名", "example": "apps", "notes": "" },
          "版本": { "type": "string", "required": true, "description": "API 版本", "example": "v1", "notes": "" },
          "类型": { "type": "string", "required": true, "description": "CRD 类型名", "example": "MyOperator", "notes": "" },
          "域名": { "type": "string", "required": false, "description": "域名", "example": "my.domain", "notes": "" },
          "仓库": { "type": "string", "required": false, "description": "仓库路径", "example": "github.com/myorg/project", "notes": "" },
          "版本1": { "type": "string", "required": false, "description": "初始版本", "example": "v1", "notes": "" },
          "版本2": { "type": "string", "required": false, "description": "新增版本", "example": "v2", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl create role 创建 Role",
      "keyword": "kubectl create role",
      "description": "创建命名空间级别的 RBAC Role",
      "data": {
        "cmd": "kubectl create role %{角色名称}% --verb=%{动作}% --resource=%{资源}% -n %{命名空间}%",
        "extensions": [
          {
            "name": "创建 ClusterRole",
            "cmd": "kubectl create clusterrole %{角色名称}% --verb=%{动作}% --resource=%{资源}%",
            "params": {
              "动作": { "type": "string", "required": true, "description": "操作动词", "example": "get,list", "notes": "" },
              "资源": { "type": "string", "required": true, "description": "资源类型", "example": "pods", "notes": "" }
            },
            "keyword": "kubectl create clusterrole"
          },
          {
            "name": "创建 RoleBinding",
            "cmd": "kubectl create rolebinding %{绑定名称}% --role=%{角色名称}% --user=%{用户名}% -n %{命名空间}%",
            "params": {
              "角色名称": { "type": "string", "required": true, "description": "Role 名称", "example": "pod-reader", "notes": "" },
              "用户名": { "type": "string", "required": true, "description": "用户名", "example": "user1", "notes": "" }
            },
            "keyword": "kubectl create rolebinding"
          },
          {
            "name": "创建 ClusterRoleBinding",
            "cmd": "kubectl create clusterrolebinding %{绑定名称}% --clusterrole=%{ClusterRole名称}% --user=%{用户名}%",
            "params": {
              "ClusterRole名称": { "type": "string", "required": true, "description": "ClusterRole 名称", "example": "cluster-reader", "notes": "" },
              "用户名": { "type": "string", "required": true, "description": "用户名", "example": "user1", "notes": "" }
            },
            "keyword": "kubectl create clusterrolebinding"
          },
          {
            "name": "查看 Roles",
            "cmd": "kubectl get roles -n %{命名空间}%",
            "params": {},
            "keyword": "kubectl get roles"
          },
          {
            "name": "查看 ClusterRoles",
            "cmd": "kubectl get clusterroles",
            "params": {},
            "keyword": "kubectl get clusterroles"
          }
        ],
        "params": {
          "角色名称": { "type": "string", "required": true, "description": "Role 名称", "example": "pod-reader", "notes": "" },
          "动作": { "type": "string", "required": true, "description": "操作动词", "example": "get,list", "notes": "" },
          "资源": { "type": "string", "required": true, "description": "资源类型", "example": "pods", "notes": "" },
          "命名空间": { "type": "string", "required": false, "description": "命名空间", "example": "default", "notes": "" },
          "绑定名称": { "type": "string", "required": false, "description": "绑定名称", "example": "pod-reader-binding", "notes": "" },
          "用户名": { "type": "string", "required": false, "description": "用户名", "example": "user1", "notes": "" },
          "ClusterRole名称": { "type": "string", "required": false, "description": "ClusterRole 名称", "example": "cluster-reader", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl auth can-i 权限检查",
      "keyword": "kubectl auth can-i",
      "description": "检查当前用户或指定用户的权限",
      "data": {
        "cmd": "kubectl auth can-i %{动作}% %{资源}%",
        "extensions": [
          {
            "name": "检查命名空间权限",
            "cmd": "kubectl auth can-i %{动作}% %{资源}% -n %{命名空间}%",
            "params": {},
            "keyword": "kubectl auth can-i 命名空间"
          },
          {
            "name": "以其他用户身份检查",
            "cmd": "kubectl auth can-i %{动作}% %{资源}% --as=%{用户}%",
            "params": {
              "用户": { "type": "string", "required": true, "description": "用户名", "example": "user1", "notes": "" }
            },
            "keyword": "kubectl auth can-i as"
          },
          {
            "name": "检查子资源权限",
            "cmd": "kubectl auth can-i %{动作}% %{资源}%/%{子资源}% --as=%{用户}%",
            "params": {
              "子资源": { "type": "string", "required": true, "description": "子资源", "example": "status", "notes": "" }
            },
            "keyword": "kubectl auth can-i 子资源"
          }
        ],
        "params": {
          "动作": { "type": "string", "required": true, "description": "操作动词", "example": "get", "notes": "" },
          "资源": { "type": "string", "required": true, "description": "资源类型", "example": "pods", "notes": "" },
          "命名空间": { "type": "string", "required": false, "description": "命名空间", "example": "default", "notes": "" },
          "用户": { "type": "string", "required": false, "description": "用户名", "example": "user1", "notes": "" },
          "子资源": { "type": "string", "required": false, "description": "子资源", "example": "status", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl get networkpolicy 查看网络策略",
      "keyword": "kubectl get networkpolicy",
      "description": "查看和管理网络隔离策略",
      "data": {
        "cmd": "kubectl get networkpolicy -n %{命名空间}%",
        "extensions": [
          {
            "name": "查看网络策略详情",
            "cmd": "kubectl describe networkpolicy %{策略名称}% -n %{命名空间}%",
            "params": {
              "策略名称": { "type": "string", "required": true, "description": "网络策略名称", "example": "allow-nginx", "notes": "" }
            },
            "keyword": "kubectl describe networkpolicy"
          },
          {
            "name": "删除网络策略",
            "cmd": "kubectl delete networkpolicy %{策略名称}% -n %{命名空间}%",
            "params": {},
            "keyword": "kubectl delete networkpolicy"
          },
          {
            "name": "查看所有命名空间策略",
            "cmd": "kubectl get networkpolicy --all-namespaces",
            "params": {},
            "keyword": "kubectl get networkpolicy 所有命名空间"
          }
        ],
        "params": {
          "命名空间": { "type": "string", "required": true, "description": "命名空间", "example": "default", "notes": "默认 default" },
          "策略名称": { "type": "string", "required": false, "description": "网络策略名称", "example": "allow-nginx", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "Pod Security Standards 标签命名空间",
      "keyword": "pod security standards label",
      "description": "为命名空间应用 Pod Security Standards 策略",
      "data": {
        "cmd": "kubectl label namespace %{命名空间}% pod-security.kubernetes.io/enforce=%{级别}%",
        "extensions": [
          {
            "name": "应用基线策略",
            "cmd": "kubectl label namespace %{命名空间}% pod-security.kubernetes.io/enforce=baseline",
            "params": {},
            "keyword": "PSS 基线策略"
          },
          {
            "name": "应用受限策略",
            "cmd": "kubectl label namespace %{命名空间}% pod-security.kubernetes.io/enforce=restricted",
            "params": {},
            "keyword": "PSS 受限策略"
          },
          {
            "name": "查看命名空间 PSS 标签",
            "cmd": "kubectl describe namespace %{命名空间}%",
            "params": {},
            "keyword": "kubectl describe namespace"
          }
        ],
        "params": {
          "命名空间": { "type": "string", "required": true, "description": "命名空间", "example": "my-namespace", "notes": "" },
          "级别": { "type": "string", "required": false, "description": "策略级别", "example": "baseline", "notes": "baseline/restricted" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl create secret generic 创建密钥",
      "keyword": "kubectl create secret generic",
      "description": "创建通用类型的 Secret",
      "data": {
        "cmd": "kubectl create secret generic %{密钥名称}% --from-literal=key=%{值}%",
        "extensions": [
          {
            "name": "创建 TLS Secret",
            "cmd": "kubectl create secret tls %{密钥名称}% --cert=%{证书文件}% --key=%{密钥文件}%",
            "params": {
              "证书文件": { "type": "string", "required": true, "description": "证书文件路径", "example": "./tls.crt", "notes": "" },
              "密钥文件": { "type": "string", "required": true, "description": "密钥文件路径", "example": "./tls.key", "notes": "" }
            },
            "keyword": "kubectl create secret tls"
          },
          {
            "name": "从文件创建",
            "cmd": "kubectl create secret generic %{密钥名称}% --from-file=%{文件路径}%",
            "params": {
              "文件路径": { "type": "string", "required": true, "description": "文件路径", "example": "./config.txt", "notes": "" }
            },
            "keyword": "kubectl create secret from-file"
          },
          {
            "name": "查看 Secret 列表",
            "cmd": "kubectl get secrets -n %{命名空间}%",
            "params": {},
            "keyword": "kubectl get secrets"
          }
        ],
        "params": {
          "密钥名称": { "type": "string", "required": true, "description": "密钥名称", "example": "my-secret", "notes": "" },
          "值": { "type": "string", "required": true, "description": "密钥值", "example": "password123", "notes": "" },
          "命名空间": { "type": "string", "required": false, "description": "命名空间", "example": "default", "notes": "" },
          "证书文件": { "type": "string", "required": false, "description": "证书文件路径", "example": "./tls.crt", "notes": "" },
          "密钥文件": { "type": "string", "required": false, "description": "密钥文件路径", "example": "./tls.key", "notes": "" },
          "文件路径": { "type": "string", "required": false, "description": "文件路径", "example": "./config.txt", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl get pvc 查看持久卷声明",
      "keyword": "kubectl get pvc",
      "description": "查看和管理 PersistentVolumeClaim",
      "data": {
        "cmd": "kubectl get pvc -n %{命名空间}%",
        "extensions": [
          {
            "name": "查看所有 PV",
            "cmd": "kubectl get pv",
            "params": {},
            "keyword": "kubectl get pv"
          },
          {
            "name": "查看 PVC 详情",
            "cmd": "kubectl describe pvc %{PVC名称}% -n %{命名空间}%",
            "params": {
              "PVC名称": { "type": "string", "required": true, "description": "PVC 名称", "example": "my-pvc", "notes": "" }
            },
            "keyword": "kubectl describe pvc"
          },
          {
            "name": "删除 PV",
            "cmd": "kubectl delete pv %{PV名称}%",
            "params": {
              "PV名称": { "type": "string", "required": true, "description": "PV 名称", "example": "my-pv", "notes": "" }
            },
            "keyword": "kubectl delete pv"
          },
          {
            "name": "扩展 PVC 大小",
            "cmd": "kubectl patch pvc %{PVC名称}% -p '{\"spec\":{\"resources\":{\"requests\":{\"storage\":\"%{新大小}%\"}}}}' -n %{命名空间}%",
            "params": {
              "新大小": { "type": "string", "required": true, "description": "新大小", "example": "20Gi", "notes": "" }
            },
            "keyword": "kubectl patch pvc"
          }
        ],
        "params": {
          "命名空间": { "type": "string", "required": true, "description": "命名空间", "example": "default", "notes": "默认 default" },
          "PVC名称": { "type": "string", "required": false, "description": "PVC 名称", "example": "my-pvc", "notes": "" },
          "PV名称": { "type": "string", "required": false, "description": "PV 名称", "example": "my-pv", "notes": "" },
          "新大小": { "type": "string", "required": false, "description": "新大小", "example": "20Gi", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl get storageclass 查看存储类",
      "keyword": "kubectl get storageclass",
