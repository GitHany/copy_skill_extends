            "keyword": "kubectl get storageclass yaml"
          },
          {
            "name": "删除存储类",
            "cmd": "kubectl delete storageclass %{存储类名称}%",
            "params": {},
            "keyword": "kubectl delete storageclass"
          }
        ],
        "params": {
          "存储类名称": { "type": "string", "required": false, "description": "存储类名称", "example": "standard", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/Kubernetes 高级操作/",
      "name": "kubectl get csidriver 查看 CSI 驱动",
      "keyword": "kubectl get csidriver",
      "description": "查看 Container Storage Interface 驱动",
