{
  "module": "kubectl logs",
  "version": "2.0",
  "description": "kubectl 容器日志查看，涵盖kubectl logs的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl logs/",
      "name": "kubectl logs 查看日志",
      "keyword": "kubectl logs 日志",
      "description": "查看 Pod 容器日志。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl logs %{Pod}%",
        "extensions": [
          {
            "name": "跟踪日志",
            "cmd": "kubectl logs -f %{Pod}%",
            "params": {
              "Pod": {
                "type": "string",
                "required": true,
                "description": "Pod",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl logs follow"
          },
          {
            "name": "最近行数",
            "cmd": "kubectl logs --tail=%{行}% %{Pod}%",
            "params": {
              "行": {
                "type": "string",
                "required": true,
                "description": "行数",
                "example": "100",
                "notes": "必填"
              },
              "Pod": {
                "type": "string",
                "required": true,
                "description": "Pod",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl logs tail"
          }
        ],
        "params": {
          "Pod": {
            "type": "string",
            "required": true,
            "description": "Pod 名称",
            "example": "my-pod",
            "notes": "必填"
          }
        }
      }
    }
  ]
}