{
  "module": "Linux uname",
  "version": "2.0",
  "description": "Linux uname 系统信息命令。显示系统内核和硬件信息，包括操作系统版本、主机名、处理器类型等。用于编写跨平台脚本、检查系统环境、确认服务器配置。",
  "commands": [
    {
      "dirPath": "/Linux uname/",
      "name": "uname 系统信息",
      "keyword": "uname 系统",
      "description": "显示系统信息。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "uname -a",
        "extensions": [
          {
            "name": "显示所有信息",
            "description": "显示完整的系统信息摘要",
            "params": {},
            "cmd": "uname -a"
          },
          {
            "name": "显示内核名称",
            "description": "只显示内核名称如Linux",
            "params": {},
            "cmd": "uname -s"
          },
          {
            "name": "显示主机名",
            "description": "显示网络上的主机名",
            "params": {},
            "cmd": "uname -n"
          },
          {
            "name": "显示内核版本",
            "description": "显示内核版本号和发布信息",
            "params": {},
            "cmd": "uname -r"
          },
          {
            "name": "显示内核版本详情",
            "description": "显示完整的内核版本字符串",
            "params": {},
            "cmd": "uname -v"
          },
          {
            "name": "显示机器硬件",
            "description": "显示硬件类型如x86_64",
            "params": {},
            "cmd": "uname -m"
          },
          {
            "name": "显示处理器",
            "description": "显示处理器架构",
            "params": {},
            "cmd": "uname -p"
          },
          {
            "name": "显示操作系统",
            "description": "显示操作系统名称",
            "params": {},
            "cmd": "uname -o"
          }
        ],
        "params": {}
      }
    }
  ]
}