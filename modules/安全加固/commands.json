      "keyword": "iptables 防火墙 规则",
      "description": "Linux 内核防火墙规则管理",
      "data": {
        "cmd": "iptables %{选项}%",
        "extensions": [
          {
            "name": "查看所有规则",
            "cmd": "iptables -L -n -v",
            "params": {},
            "keyword": "iptables 查看规则"
          },
          {
            "name": "允许 SSH 入站",
            "cmd": "iptables -A INPUT -p tcp --dport 22 -j ACCEPT",
            "params": {},
            "keyword": "iptables SSH"
          },
          {
            "name": "允许 HTTP/HTTPS",
            "cmd": "iptables -A INPUT -p tcp -m multiport --dports 80,443 -j ACCEPT",
            "params": {},
            "keyword": "iptables HTTP HTTPS"
          },
          {
            "name": "拒绝入站连接",
            "cmd": "iptables -A INPUT -j DROP",
            "params": {},
            "keyword": "iptables 拒绝"
          },
          {
            "name": "允许已建立连接",
            "cmd": "iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT",
            "params": {},
            "keyword": "iptables 已建立连接"
          },
          {
            "name": "删除规则",
            "cmd": "iptables -D INPUT %{规则号}%",
            "params": {},
            "keyword": "iptables 删除规则"
          },
          {
            "name": "保存规则",
            "cmd": "iptables-save > /etc/iptables/rules.v4",
            "params": {},
            "keyword": "iptables 保存"
          }
        ],
        "params": {
          "选项": {
            "type": "string",
            "required": false,
            "description": "iptables 选项",
            "example": "-L -n -v",
            "notes": "常用 -A 添加，-D 删除，-L 列表，-F 清空"
          }
        }
      }
    },
