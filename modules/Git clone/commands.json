{
  "module": "Git clone",
  "version": "2.0",
  "description": "Git clone - Download a complete copy of a remote repository to your local machine. Use when starting a new project from existing code or setting up a development environment.",
  "commands": [
    {
      "dirPath": "/Git clone/",
      "name": "git clone basic",
      "keyword": "git clone repository",
      "description": "Clone a repository to your machine - downloads all files, history, and branches",
      "data": {
        "cmd": "git clone %{url}%",
        "extensions": [
          {
            "name": "git clone to custom folder",
            "description": "Clone into a specific folder instead of default - useful when you want a different project name",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "URL of the repo to clone"
              },
              "directory": {
                "type": "string",
                "required": false,
                "description": "Target folder name",
                "example": "my-project",
                "notes": "Folder will be created if it doesn't exist"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL",
            "example": "https://github.com/user/repo.git",
            "notes": "Use SSH (git@github.com:...) or HTTPS URL"
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone shallow",
      "keyword": "git clone shallow",
      "description": "Clone with limited history - downloads only the latest commit(s), much faster for large repos",
      "data": {
        "cmd": "git clone --depth %{depth}% %{url}%",
        "extensions": [
          {
            "name": "git clone single branch",
            "description": "Clone only one branch - saves even more bandwidth for very large repos",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Repository to clone"
              },
              "branch": {
                "type": "string",
                "required": true,
                "description": "Branch to clone",
                "example": "main",
                "notes": "Only this branch will be downloaded"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "depth": {
            "type": "string",
            "required": true,
            "description": "Number of commits to keep",
            "example": "1",
            "notes": "1 = latest only. Good for CI/testing, not for full development"
          },
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL",
            "example": "https://github.com/user/large-repo.git",
            "notes": "Repository to clone"
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone specific branch",
      "keyword": "git clone branch",
      "description": "Clone and only fetch a specific branch - saves bandwidth and time for large repos",
      "data": {
        "cmd": "git clone --branch %{branch}% --single-branch %{url}%",
        "extensions": [
          {
            "name": "clone branch to custom folder",
            "cmd": "git clone --branch %{branch}% --single-branch %{url}% %{directory}%",
            "params": {
              "branch": {
                "type": "string",
                "required": true,
                "description": "Branch name",
                "example": "develop",
                "notes": "Only this branch history will be downloaded"
              },
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Repository URL"
              },
              "directory": {
                "type": "string",
                "required": false,
                "description": "Target directory",
                "example": "my-project",
                "notes": "Optional custom folder name"
              }
            },
            "keyword": "clone branch to folder"
          },
          {
            "name": "clone branch with depth",
            "cmd": "git clone --branch %{branch}% --single-branch --depth %{depth}% %{url}%",
            "params": {
              "branch": {
                "type": "string",
                "required": true,
                "description": "Branch name",
                "example": "develop",
                "notes": "Branch to clone"
              },
              "depth": {
                "type": "string",
                "required": true,
                "description": "Number of commits",
                "example": "10",
                "notes": "Limited history depth"
              },
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Repository URL"
              }
            },
            "keyword": "clone branch shallow"
          }
        ],
        "params": {
          "branch": {
            "type": "string",
            "required": true,
            "description": "Branch name",
            "example": "develop",
            "notes": "Only this branch history will be downloaded"
          },
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL",
            "example": "https://github.com/user/repo.git",
            "notes": "Repository URL"
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone via SSH",
      "keyword": "git clone ssh",
      "description": "Clone using SSH instead of HTTPS - requires SSH key setup but more secure and convenient",
      "data": {
        "cmd": "git clone git@github.com:%{user}%/%{repo}%.git",
        "extensions": [
          {
            "name": "git clone via SSH custom port",
            "description": "Clone via SSH on a custom port - for servers running SSH on non-default port",
            "params": {
              "user": {
                "type": "string",
                "required": true,
                "description": "GitHub username or organization",
                "example": "octocat",
                "notes": "Owner of the repository"
              },
              "repo": {
                "type": "string",
                "required": true,
                "description": "Repository name",
                "example": "Hello-World",
                "notes": "Name of the repository"
              },
              "port": {
                "type": "string",
                "required": true,
                "description": "SSH port",
                "example": "2222",
                "notes": "Custom SSH port if not default 22"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "user": {
            "type": "string",
            "required": true,
            "description": "GitHub username or organization",
            "example": "octocat",
            "notes": "Owner of the repository"
          },
          "repo": {
            "type": "string",
            "required": true,
            "description": "Repository name",
            "example": "Hello-World",
            "notes": "Name of the repository"
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone recurse submodules",
      "keyword": "git clone submodules",
      "description": "Clone including all submodules - needed for projects that use nested repositories",
      "data": {
        "cmd": "git clone --recurse-submodules %{url}%",
        "extensions": [
          {
            "name": "git clone submodules in parallel",
            "description": "Clone with submodules fetched in parallel - faster for projects with many submodules",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Clones main repo and all submodules"
              },
              "jobs": {
                "type": "string",
                "required": false,
                "description": "Number of parallel jobs",
                "example": "4",
                "notes": "How many submodules to fetch simultaneously"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL",
            "example": "https://github.com/user/repo.git",
            "notes": "Clones main repo and initializes/fetches each submodule"
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone with git protocol",
      "keyword": "git clone git protocol",
      "description": "Clone using the git:// protocol - read-only, sometimes works when HTTP is blocked",
      "data": {
        "cmd": "git clone git://%{url}%",
        "extensions": [
          {
            "name": "git protocol with specific branch",
            "cmd": "git clone --branch %{branch}% git://%{url}%",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL in git protocol format",
                "example": "github.com/user/repo.git",
                "notes": "No authentication. Read-only access."
              },
              "branch": {
                "type": "string",
                "required": true,
                "description": "Branch name",
                "example": "main",
                "notes": "Clone specific branch"
              }
            },
            "keyword": "git protocol branch"
          },
          {
            "name": "git protocol to custom folder",
            "cmd": "git clone git://%{url}% %{directory}%",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL in git protocol format",
                "example": "github.com/user/repo.git",
                "notes": "No authentication. Read-only access."
              },
              "directory": {
                "type": "string",
                "required": false,
                "description": "Target folder",
                "example": "my-repo",
                "notes": "Custom directory name"
              }
            },
            "keyword": "git protocol folder"
          }
        ],
        "params": {
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL in git protocol format",
            "example": "github.com/user/repo.git",
            "notes": "No authentication. Read-only access."
          }
        }
      }
    },
    {
      "dirPath": "/Git clone/",
      "name": "git clone bare",
      "keyword": "git clone bare",
      "description": "Clone as a bare repository - no working directory, used primarily for sharing or as a remote",
      "data": {
        "cmd": "git clone --bare %{url}% %{directory}%.git",
        "extensions": [
          {
            "name": "bare clone with branches",
            "cmd": "git clone --bare --mirror %{url}% %{directory}%.git",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Repository to clone"
              },
              "directory": {
                "type": "string",
                "required": true,
                "description": "Directory name",
                "example": "my-repo",
                "notes": "By convention ends in .git for bare repos"
              }
            },
            "keyword": "bare mirror clone"
          },
          {
            "name": "bare clone to local repo",
            "cmd": "git clone --bare %{url}% %{directory}%.git && cd %{directory}%.git && git remote rename origin old-origin",
            "params": {
              "url": {
                "type": "string",
                "required": true,
                "description": "Repository URL",
                "example": "https://github.com/user/repo.git",
                "notes": "Repository to clone"
              },
              "directory": {
                "type": "string",
                "required": true,
                "description": "Directory name",
                "example": "my-repo",
                "notes": "By convention ends in .git for bare repos"
              }
            },
            "keyword": "bare clone setup"
          }
        ],
        "params": {
          "url": {
            "type": "string",
            "required": true,
            "description": "Repository URL",
            "example": "https://github.com/user/repo.git",
            "notes": "Repository to clone"
          },
          "directory": {
            "type": "string",
            "required": true,
            "description": "Directory name",
            "example": "my-repo",
            "notes": "By convention ends in .git for bare repos"
          }
        }
      }
    }
  ]
}