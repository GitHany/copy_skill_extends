{
  "module": "ORM框架",
  "version": "1.0",
  "description": "ORM 框架命令模块集合，涵盖 SQLAlchemy、Alembic、Prisma、TypeORM、Django ORM",
  "commands": [
    {
      "dirPath": "/ORM框架/",
      "name": "create_engine 创建数据库引擎",
      "keyword": "create_engine SQLAlchemy",
      "description": "创建 SQLAlchemy 数据库引擎",
      "data": {
        "cmd": "create_engine(\"%{数据库URL}%\", %{参数}%)",
        "extensions": [
          {
            "name": "连接 SQLite",
            "cmd": "create_engine(\"sqlite:///mydb.db\")",
            "params": {},
            "keyword": "create_engine SQLite"
          },
          {
            "name": "连接 MySQL",
            "cmd": "create_engine(\"mysql+pymysql://user:pass@localhost:3306/mydb\")",
            "params": {},
            "keyword": "create_engine MySQL"
          },
          {
            "name": "连接 PostgreSQL",
            "cmd": "create_engine(\"postgresql://user:pass@localhost:5432/mydb\")",
            "params": {},
            "keyword": "create_engine PostgreSQL"
          },
          {
            "name": "连接池配置",
            "cmd": "create_engine(\"sqlite:///mydb.db\", pool_size=%{连接池大小}%, max_overflow=%{最大溢出}%)",
            "params": {
              "连接池大小": { "type": "number", "required": false, "description": "连接池大小", "example": "10", "notes": "" },
              "最大溢出": { "type": "number", "required": false, "description": "最大溢出连接数", "example": "20", "notes": "" }
            },
            "keyword": "create_engine 连接池"
          },
          {
            "name": "Echo SQL 调试",
            "cmd": "create_engine(\"sqlite:///mydb.db\", echo=%{是否输出}%)\n",
            "params": {
              "是否输出": { "type": "boolean", "required": false, "description": "是否输出所有 SQL 语句", "example": "True", "notes": "True 调试用，False 生产用" }
            },
            "keyword": "create_engine echo"
          },
          {
            "name": "连接池回收时间",
            "cmd": "create_engine(\"mysql://user:pass@localhost/mydb\", pool_recycle=%{回收秒数}%)\n",
            "params": {
              "回收秒数": { "type": "number", "required": false, "description": "连接回收时间（秒）", "example": "3600", "notes": "防止 MySQL 空闲连接超时" }
            },
            "keyword": "create_engine pool_recycle"
          },
          {
            "name": "echo False 静默模式",
            "cmd": "create_engine(\"sqlite:///mydb.db\", echo=False)",
            "params": {},
            "keyword": "create_engine 静默"
          }
        ],
        "params": {
          "数据库URL": { "type": "string", "required": true, "description": "数据库连接 URL", "example": "sqlite:///mydb.db", "notes": "格式：dialect+driver://user:pass@host:port/database" },
          "参数": { "type": "string", "required": false, "description": "额外参数", "example": "pool_size=10, echo=True", "notes": "可选，如 pool_size, echo, pool_recycle 等" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "Session 会话管理",
      "keyword": "Session SQLAlchemy 会话",
      "description": "SQLAlchemy ORM 会话管理",
      "data": {
        "cmd": "session = Session(bind=%{引擎}%)\nsession.add(%{对象}%)\nsession.commit()",
        "extensions": [
          {
            "name": "创建会话",
            "cmd": "from sqlalchemy.orm import Session\\nsession = Session(bind=engine)",
            "params": {},
            "keyword": "Session 创建"
          },
          {
            "name": "创建会话工厂",
            "cmd": "from sqlalchemy.orm import sessionmaker\\nSession = sessionmaker(bind=engine)",
            "params": {},
            "keyword": "sessionmaker"
          },
          {
            "name": "开启事务",
            "cmd": "with session.begin():\\n    session.add(user_obj)",
            "params": {},
            "keyword": "session begin"
          },
          {
            "name": "添加对象",
            "cmd": "session.add(%{对象}%)",
            "params": {
              "对象": { "type": "object", "required": true, "description": "要添加的 ORM 对象", "example": "user_instance", "notes": "常用" }
            },
            "keyword": "session.add"
          },
          {
            "name": "提交事务",
            "cmd": "session.commit()",
            "params": {},
            "keyword": "session commit"
          },
          {
            "name": "回滚事务",
            "cmd": "session.rollback()",
            "params": {},
            "keyword": "session rollback"
          },
          {
            "name": "关闭会话",
            "cmd": "session.close()",
            "params": {},
            "keyword": "session close"
          },
          {
            "name": "查询对象",
            "cmd": "session.query(%{模型}%).filter_by(%{条件}%).all()",
            "params": {
              "模型": { "type": "object", "required": true, "description": "ORM 模型类", "example": "User", "notes": "常用" },
              "条件": { "type": "string", "required": true, "description": "查询条件", "example": "id=1", "notes": "常用" }
            },
            "keyword": "session.query"
          },
          {
            "name": "删除对象",
            "cmd": "session.delete(%{对象}%)",
            "params": {
              "对象": { "type": "object", "required": true, "description": "要删除的 ORM 对象", "example": "user_instance", "notes": "常用" }
            },
            "keyword": "session.delete"
          }
        ],
        "params": {
          "引擎": { "type": "object", "required": true, "description": "数据库引擎", "example": "engine", "notes": "常用" },
          "对象": { "type": "object", "required": true, "description": "ORM 对象实例", "example": "User(name='张三')", "notes": "" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "Base.metadata.create_all 创建所有表",
      "keyword": "create_all SQLAlchemy 创建表",
      "description": "根据模型类创建数据库所有表",
      "data": {
        "cmd": "Base.metadata.create_all(bind=%{引擎}%)",
        "extensions": [
          {
            "name": "创建所有表",
            "cmd": "Base.metadata.create_all(bind=engine)",
            "params": {},
            "keyword": "create_all 所有表"
          },
          {
            "name": "仅创建特定表",
            "cmd": "Base.metadata.create_all(bind=engine, tables=[%{表列表}%])",
            "params": {
              "表列表": { "type": "array", "required": true, "description": "表对象列表", "example": "[users_table, orders_table]", "notes": "常用" }
            },
            "keyword": "create_all 特定表"
          },
          {
            "name": "检查表存在",
            "cmd": "engine.dialect.has_table(engine, \"%{表名}%\")",
            "params": {
              "表名": { "type": "string", "required": true, "description": "表名", "example": "users", "notes": "常用" }
            },
            "keyword": "has_table 检查表"
          },
          {
            "name": "删除所有表",
            "cmd": "Base.metadata.drop_all(bind=engine)",
            "params": {},
            "keyword": "drop_all 删除表"
          },
          {
            "name": "元数据检视",
            "cmd": "Base.metadata.tables",
            "params": {},
            "keyword": "metadata.tables"
          },
          {
            "name": "反射表结构",
            "cmd": "Table(\"%{表名}%\", Base.metadata, autoload=True, autoload_with=engine)",
            "params": {
              "表名": { "type": "string", "required": true, "description": "表名", "example": "users", "notes": "常用" }
            },
            "keyword": "Table autoload"
          }
        ],
        "params": {
          "引擎": { "type": "object", "required": true, "description": "数据库引擎", "example": "engine", "notes": "常用" },
          "表列表": { "type": "array", "required": false, "description": "要创建的表列表", "example": "[users_table]", "notes": "可选" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "alembic init 初始化迁移环境",
      "keyword": "alembic init 初始化",
      "description": "初始化 Alembic 迁移环境",
      "data": {
        "cmd": "alembic init %{目录名}%",
        "extensions": [
          {
            "name": "初始化迁移目录",
            "cmd": "alembic init alembic",
            "params": {},
            "keyword": "alembic init"
          },
          {
            "name": "指定模板初始化",
            "cmd": "alembic init %{目录名}% -t %{模板}%",
            "params": {
              "目录名": { "type": "string", "required": true, "description": "迁移目录名", "example": "alembic", "notes": "" },
              "模板": { "type": "string", "required": false, "description": "模板名称", "example": "generic", "notes": "" }
            },
            "keyword": "alembic init 模板"
          },
          {
            "name": "初始化并指定数据库",
            "cmd": "alembic init %{目录名}% -x sqlalchemy.url=%{数据库URL}%",
            "params": {
              "目录名": { "type": "string", "required": true, "description": "迁移目录名", "example": "alembic", "notes": "" },
              "数据库URL": { "type": "string", "required": true, "description": "数据库连接 URL", "example": "postgresql://user:pass@localhost/mydb", "notes": "" }
            },
            "keyword": "alembic init 数据库URL"
          }
        ],
        "params": {
          "目录名": { "type": "string", "required": true, "description": "迁移目录名称", "example": "alembic", "notes": "" },
          "模板": { "type": "string", "required": false, "description": "初始化模板", "example": "generic", "notes": "可选，默认 generic" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "alembic revision 创建迁移版本",
      "keyword": "alembic revision 创建迁移",
      "description": "创建 Alembic 迁移版本文件",
      "data": {
        "cmd": "alembic revision -m \"%{消息}%\"",
        "extensions": [
          {
            "name": "创建空迁移",
            "cmd": "alembic revision -m \"%{消息}%\"",
            "params": {
              "消息": { "type": "string", "required": true, "description": "迁移描述信息", "example": "add users table", "notes": "常用" }
            },
            "keyword": "alembic revision"
          },
          {
            "name": "自动生成迁移",
            "cmd": "alembic revision --autogenerate -m \"%{消息}%\"",
            "params": {
              "消息": { "type": "string", "required": true, "description": "迁移描述信息", "example": "add email column", "notes": "常用" }
            },
            "keyword": "alembic autogenerate"
          },
          {
            "name": "指定依赖版本",
            "cmd": "alembic revision -m \"%{消息}%\" --depends-on %{上一个版本}%",
            "params": {
              "消息": { "type": "string", "required": true, "description": "迁移描述", "example": "v2", "notes": "" },
              "上一个版本": { "type": "string", "required": true, "description": "依赖的上一个版本 ID", "example": "abc1234", "notes": "" }
            },
            "keyword": "alembic depends-on"
          }
        ],
        "params": {
          "消息": { "type": "string", "required": true, "description": "迁移版本描述", "example": "add users table", "notes": "常用" },
          "上一个版本": { "type": "string", "required": false, "description": "依赖的上一个版本 ID", "example": "abc1234", "notes": "可选" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "alembic upgrade 执行迁移升级",
      "keyword": "alembic upgrade 迁移升级",
      "description": "执行 Alembic 迁移升级",
      "data": {
        "cmd": "alembic upgrade %{目标版本}%",
        "extensions": [
          {
            "name": "升级到最新版本",
            "cmd": "alembic upgrade head",
            "params": {},
            "keyword": "alembic upgrade head"
          },
          {
            "name": "升级一步",
            "cmd": "alembic upgrade +1",
            "params": {},
            "keyword": "alembic upgrade +1"
          },
          {
            "name": "升级到指定版本",
            "cmd": "alembic upgrade %{版本ID}%",
            "params": {
              "版本ID": { "type": "string", "required": true, "description": "迁移版本 ID", "example": "abc1234", "notes": "常用" }
            },
            "keyword": "alembic upgrade 指定版本"
          },
          {
            "name": "升级多步",
            "cmd": "alembic upgrade +%{步数}%",
            "params": {
              "步数": { "type": "number", "required": true, "description": "向上迁移的步数", "example": "3", "notes": "" }
            },
            "keyword": "alembic upgrade 多步"
          },
          {
            "name": "离线升级输出 SQL",
            "cmd": "alembic upgrade head --sql > %{输出文件}%",
            "params": {
              "输出文件": { "type": "string", "required": true, "description": "输出 SQL 脚本文件", "example": "upgrade.sql", "notes": "" }
            },
            "keyword": "alembic upgrade sql"
          }
        ],
        "params": {
          "目标版本": { "type": "string", "required": true, "description": "目标版本", "example": "head", "notes": "常用: head, +1, 版本ID" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "alembic downgrade 执行迁移降级",
      "keyword": "alembic downgrade 迁移降级",
      "description": "执行 Alembic 迁移降级",
      "data": {
        "cmd": "alembic downgrade %{目标版本}%",
        "extensions": [
          {
            "name": "降一级",
            "cmd": "alembic downgrade -1",
            "params": {},
            "keyword": "alembic downgrade -1"
          },
          {
            "name": "降级到最初",
            "cmd": "alembic downgrade base",
            "params": {},
            "keyword": "alembic downgrade base"
          },
          {
            "name": "降级到指定版本",
            "cmd": "alembic downgrade %{版本ID}%",
            "params": {
              "版本ID": { "type": "string", "required": true, "description": "迁移版本 ID", "example": "abc1234", "notes": "常用" }
            },
            "keyword": "alembic downgrade 指定版本"
          },
          {
            "name": "降级多步",
            "cmd": "alembic downgrade -%{步数}%",
            "params": {
              "步数": { "type": "number", "required": true, "description": "向下迁移的步数", "example": "3", "notes": "" }
            },
            "keyword": "alembic downgrade 多步"
          }
        ],
        "params": {
          "目标版本": { "type": "string", "required": true, "description": "目标版本", "example": "base", "notes": "常用: base, -1, 版本ID" }
        }
      }
    },
    {
      "dirPath": "/ORM框架/",
      "name": "alembic migrate 迁移管理",
      "keyword": "alembic history current stamp",
      "description": "Alembic 迁移查看和管理命令",
