              "迁移名称": { "type": "string", "required": true, "description": "迁移名称", "example": "init", "notes": "常用" }
            },
            "keyword": "prisma migrate dev create-only"
          },
          {
            "name": "迁移跳过生成",
            "cmd": "npx prisma migrate dev --name %{迁移名称}% --skip-generate",
            "params": {
              "迁移名称": { "type": "string", "required": true, "description": "迁移名称", "example": "init", "notes": "" }
            },
            "keyword": "prisma migrate dev skip-generate"
