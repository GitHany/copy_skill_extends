{
  "module": "Linux mount",
  "version": "2.0",
  "description": "Linux mount 挂载文件系统命令。将存储设备或网络共享挂载到目录树中的指定位置，使其可访问。用于访问硬盘分区、挂载U盘、连接NFS/SMB网络共享。挂载后即可像访问本地文件一样访问存储设备。",
  "commands": [
    {
      "dirPath": "/Linux mount/",
      "name": "mount 挂载",
      "keyword": "mount 挂载",
      "description": "挂载文件系统。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "mount %{设备}% %{目录}%",
        "extensions": [
          {
            "name": "挂载文件系统",
            "description": "将设备挂载到指定目录",
            "params": {
              "设备": {
                "example": "/dev/sdb1",
                "notes": "设备名"
              },
              "目录": {
                "example": "/mnt/usb",
                "notes": "挂载点"
              }
            },
            "cmd": "mount %{设备}% %{目录}%"
          },
          {
            "name": "以只读模式挂载",
            "description": "以只读权限挂载设备",
            "params": {
              "设备": {
                "example": "/dev/sdc1",
                "notes": "设备"
              },
              "目录": {
                "example": "/mnt/readonly",
                "notes": "挂载点"
              }
            },
            "cmd": "mount -r %{设备}% %{目录}%"
          },
          {
            "name": "指定文件系统类型",
            "description": "明确指定要挂载的文件系统类型",
            "params": {
              "类型": {
                "example": "ntfs",
                "notes": "文件系统类型"
              },
              "设备": {
                "example": "/dev/sdb1",
                "notes": "设备"
              },
              "目录": {
                "example": "/mnt/windows",
                "notes": "挂载点"
              }
            },
            "cmd": "mount -t %{类型}% %{设备}% %{目录}%"
          },
          {
            "name": "重新挂载",
            "description": "重新挂载已挂载的设备，如修改挂载选项",
            "params": {
              "目录": {
                "example": "/",
                "notes": "挂载点"
              }
            },
            "cmd": "mount -o remount %{目录}%"
          },
          {
            "name": "绑定挂载目录",
            "description": "将一个目录绑定到另一个位置",
            "params": {
              "源目录": {
                "example": "/home/user/project",
                "notes": "源目录"
              },
              "目标目录": {
                "example": "/mnt/bind",
                "notes": "目标目录"
              }
            },
            "cmd": "mount --bind %{源目录}% %{目标目录}%"
          },
          {
            "name": "显示所有挂载",
            "description": "显示当前所有已挂载的文件系统",
            "params": {},
            "cmd": "mount"
          },
          {
            "name": "卸载设备",
            "description": "卸载已挂载的设备",
            "params": {
              "目录": {
                "example": "/mnt/usb",
                "notes": "挂载点"
              }
            },
            "cmd": "umount %{目录}%"
          },
          {
            "name": "强制卸载",
            "description": "强制卸载正在使用的设备",
            "params": {
              "目录": {
                "example": "/mnt/busy",
                "notes": "挂载点"
              }
            },
            "cmd": "umount -f %{目录}%"
          }
        ],
        "params": {
          "设备": {
            "type": "string",
            "required": true,
            "description": "设备",
            "example": "/dev/sdb1",
            "notes": "必填"
          },
          "目录": {
            "type": "string",
            "required": true,
            "description": "目录",
            "example": "/mnt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}