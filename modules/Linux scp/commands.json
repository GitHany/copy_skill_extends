{
  "module": "Linux scp",
  "version": "2.0",
  "description": "SSH 安全文件复制，涵盖Linux scp的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux scp/",
      "name": "scp 复制文件",
      "keyword": "scp 复制",
      "description": "通过 SSH 复制文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "scp %{源}% %{目标}%",
        "extensions": [
          {
            "name": "递归复制",
            "cmd": "scp -r %{源}% %{目标}%",
            "params": {
              "源": {
                "type": "string",
                "required": true,
                "description": "源",
                "example": "./data/",
                "notes": "必填"
              },
              "目标": {
                "type": "string",
                "required": true,
                "description": "目标",
                "example": "user@host:/path/",
                "notes": "必填"
              }
            },
            "keyword": "scp recursive"
          }
        ],
        "params": {
          "源": {
            "type": "string",
            "required": true,
            "description": "源路径",
            "example": "file.txt",
            "notes": "必填"
          },
          "目标": {
            "type": "string",
            "required": true,
            "description": "目标路径",
            "example": "user@server:/path/",
            "notes": "必填"
          }
        }
      }
    }
  ]
}