{
  "module": "Docker start",
  "version": "2.0",
  "description": "Docker 容器启动命令（Start Containers）。启动一个或多个已停止（但未删除）的容器，使其恢复运行状态。入门提示：docker start 用于重新启动已存在的容器，而 docker run 是创建并启动新容器。新手常见错误：用 docker run 启动已存在的容器（会创建新的而非启动旧的）。",
  "commands": [
    {
      "dirPath": "/Docker start/",
      "name": "docker start 启动容器",
      "keyword": "docker start 启动",
      "description": "启动已停止的容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker start %{容器}%",
        "extensions": [
          {
            "name": "docker start -i 交互式启动",
            "description": "启动容器并进入交互模式，自动附加到容器的标准输入（适合调试命令行的容器）",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "myapp",
                "notes": "必填：启动后会看到容器的输出"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker start -a 附加到容器输出",
            "description": "启动并将容器的输出附加到终端（查看日志输出）",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "webapp",
                "notes": "必填：容器会在前台运行并输出日志"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker start -a -i 完整交互模式",
            "description": "启动并同时附加到容器输入输出（完全交互模式）",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "ubuntu-container",
                "notes": "必填：相当于 docker attach"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker start 批量启动多个容器",
            "description": "同时启动多个容器（适合开发环境一键启动）",
            "params": {
              "容器列表": {
                "type": "string",
                "required": true,
                "description": "多个容器名（空格分隔）",
                "example": "nginx postgres redis app",
                "notes": "必填：按顺序启动"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker start --checkpoint 恢复检查点（实验性）",
            "description": "从检查点恢复容器（需要启用实验功能，适合有状态服务）",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "myapp",
                "notes": "必填：需要配合 docker checkpoint create 使用"
              },
              "检查点名": {
                "type": "string",
                "required": false,
                "description": "检查点名称",
                "example": "before-update",
                "notes": "可选：指定从哪个检查点恢复"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker ps -a 查看所有容器状态",
            "description": "查看所有容器（包括已停止的），确认哪些需要启动",
            "params": {
              "过滤条件": {
                "type": "string",
                "required": false,
                "description": "按名称或状态过滤",
                "example": "status=exited",
                "notes": "可选：如只看已停止的容器"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器名或ID",
            "example": "myapp",
            "notes": "必填：可以用 Tab 补全或 docker ps -a 查看"
          }
        }
      }
    }
  ]
}