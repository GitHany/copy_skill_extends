{
  "module": "Docker ps",
  "version": "2.0",
  "description": "Docker 容器列表查询模块，用于查看本地运行的 Docker 容器状态。是容器管理的基础命令，适用于监控容器运行状态、排查问题、日志查看等日常运维场景",
  "commands": [
    {
      "dirPath": "/Docker ps/",
      "name": "docker ps 列出容器",
      "keyword": "docker ps 列表",
      "description": "列出当前运行的 Docker 容器 - 显示容器ID、镜像名、端口映射、状态等信息。用于快速查看哪些容器正在运行，监控系统状态",
      "data": {
        "cmd": "docker ps",
        "extensions": [
          {
            "name": "全部容器",
            "cmd": "docker ps -a",
            "params": {},
            "keyword": "docker ps all"
          },
          {
            "name": "仅显示容器ID",
            "cmd": "docker ps -q",
            "params": {},
            "keyword": "docker ps quiet"
          },
          {
            "name": "显示完整命令",
            "cmd": "docker ps --no-trunc",
            "params": {},
            "keyword": "docker ps full"
          },
          {
            "name": "最新容器",
            "cmd": "docker ps -l",
            "params": {},
            "keyword": "docker ps latest"
          },
          {
            "name": "显示容器大小",
            "cmd": "docker ps -s",
            "params": {},
            "keyword": "docker ps size"
          },
          {
            "name": "按名称过滤",
            "cmd": "docker ps --filter \"name=%{名称}%\"",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "容器名称",
                "example": "nginx-web",
                "notes": "必填。容器名称，支持部分匹配"
              }
            },
            "keyword": "docker ps filter name"
          }
        ],
        "params": {}
      }
    }
  ]
}