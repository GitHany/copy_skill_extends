{
  "module": "Docker cp",
  "version": "2.0",
  "description": "Docker cp命令集合，涵盖Docker cp的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Docker cp/",
      "name": "docker cp 从容器复制",
      "keyword": "docker cp 复制",
      "description": "从容器复制文件到主机。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker cp %{容器}%:%{路径}% %{目标}%",
        "extensions": [],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器",
            "example": "myapp",
            "notes": "必填"
          },
          "路径": {
            "type": "string",
            "required": true,
            "description": "容器内路径",
            "example": "/app/logs/",
            "notes": "必填"
          },
          "目标": {
            "type": "string",
            "required": true,
            "description": "目标路径",
            "example": "./logs/",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Docker cp/",
      "name": "docker cp 复制到容器",
      "keyword": "docker cp 到容器",
      "description": "从主机复制文件到容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker cp %{源}% %{容器}%:%{路径}%",
        "extensions": [],
        "params": {
          "源": {
            "type": "string",
            "required": true,
            "description": "源路径",
            "example": "./config/",
            "notes": "必填"
          },
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器",
            "example": "myapp",
            "notes": "必填"
          },
          "路径": {
            "type": "string",
            "required": true,
            "description": "容器路径",
            "example": "/app/",
            "notes": "必填"
          }
        }
      }
    }
  ]
}