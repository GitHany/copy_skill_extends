{
  "module": "kubectl cp",
  "version": "2.0",
  "description": "kubectl 文件复制，涵盖kubectl cp的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl cp/",
      "name": "kubectl cp 复制文件",
      "keyword": "kubectl cp 复制",
      "description": "在本地和 Pod 之间复制文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl cp %{Pod}%:%{源}% %{目标}%",
        "extensions": [],
        "params": {
          "Pod": {
            "type": "string",
            "required": true,
            "description": "Pod 名",
            "example": "my-pod",
            "notes": "必填"
          },
          "源": {
            "type": "string",
            "required": true,
            "description": "源路径",
            "example": "/app/logs/",
            "notes": "必填"
          },
          "目标": {
            "type": "string",
            "required": true,
            "description": "目标路径",
            "example": "./logs/",
            "notes": "必填"
          }
        }
      }
    }
  ]
}