{
  "module": "AWS s3 mb",
  "version": "2.0",
  "description": "AWS S3 mb (make bucket) 创建存储桶命令。在 S3 上创建新的存储桶，用于存放文件和数据。创建前需注意桶名全局唯一、选择合适的区域。适用于新建项目存储、上传静态网站、搭建数据湖等场景。",
  "commands": [
    {
      "dirPath": "/AWS s3 mb/",
      "name": "aws s3 mb 创建桶",
      "keyword": "aws s3 mb 创建",
      "description": "创建 S3 存储桶。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "aws s3 mb s3://%{桶名}%",
        "extensions": [
          {
            "name": "在指定区域创建桶",
            "description": "在特定AWS区域创建桶，可以降低延迟和成本",
            "params": {
              "桶名": {
                "example": "my-bucket-123",
                "notes": "桶名"
              },
              "区域": {
                "example": "ap-northeast-1",
                "notes": "AWS区域代码"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --region %{区域}%"
          },
          {
            "name": "创建桶时启用ACL",
            "description": "创建桶并设置访问控制列表",
            "params": {
              "桶名": {
                "example": "my-bucket-123",
                "notes": "桶名"
              },
              "ACL": {
                "example": "public-read",
                "notes": "ACL设置"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --acl %{ACL}%"
          },
          {
            "name": "创建桶启用加密",
            "description": "创建启用服务器端加密的桶，保护数据安全",
            "params": {
              "桶名": {
                "example": "secure-bucket",
                "notes": "桶名"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --sse AES256"
          },
          {
            "name": "创建桶启用版本控制",
            "description": "创建支持版本控制的桶，可以恢复误删文件",
            "params": {
              "桶名": {
                "example": "versioned-bucket",
                "notes": "桶名"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --object-lock-enabled"
          },
          {
            "name": "创建桶配置生命周期",
            "description": "创建桶并设置自动归档或删除策略",
            "params": {
              "桶名": {
                "example": "archive-bucket",
                "notes": "桶名"
              },
              "天数": {
                "example": "30",
                "notes": "过渡天数"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --transition-days %{天数}%"
          },
          {
            "name": "检查桶是否已存在",
            "description": "尝试创建桶，处理已存在的错误",
            "params": {
              "桶名": {
                "example": "my-bucket-123",
                "notes": "桶名"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% 2>&1 || echo \"桶可能已存在或无权限\""
          },
          {
            "name": "创建桶并设置标签",
            "description": "创建桶时添加标签便于成本分摊和分类",
            "params": {
              "桶名": {
                "example": "my-bucket-123",
                "notes": "桶名"
              },
              "标签": {
                "example": "Environment=Production",
                "notes": "标签键值对"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --tagging \"%{标签}%\""
          },
          {
            "name": "使用双辣横线格式",
            "description": "对于特殊字符的桶名，使用特殊语法创建",
            "params": {
              "桶名": {
                "example": "my.bucket.with.dots",
                "notes": "含点号的桶名"
              }
            },
            "cmd": "aws s3 mb s3://%{桶名}% --force"
          }
        ],
        "params": {
          "桶名": {
            "type": "string",
            "required": true,
            "description": "桶名",
            "example": "my-bucket-123",
            "notes": "必填"
          }
        }
      }
    }
  ]
}