{
  "module": "微服务架构/微服务架构",
  "version": "1.0",
  "description": "微服务架构核心组件命令行集合，涵盖服务发现、API网关、服务网格、分布式追踪、断路器、负载均衡等",
  "commands": [
    {
      "dirPath": "/微服务架构/",
      "name": "Consul Agent 启动",
      "keyword": "consul agent",
      "description": "启动 Consul Agent 开发模式。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "consul agent -dev -ui",
        "extensions": [
          {
            "name": "以服务端模式启动",
            "cmd": "consul agent -server -bootstrap-expect=3 -data-dir=/tmp/consul",
            "params": {},
            "keyword": "consul agent server"
          },
          {
            "name": "指定数据中心",
            "cmd": "consul agent -datacenter=dc1",
            "params": {},
            "keyword": "consul datacenter"
          },
          {
            "name": "加入已有集群",
            "cmd": "consul agent -retry-join=%{集群地址}%",
            "params": {
              "集群地址": {
                "type": "string",
                "required": true,
                "description": "集群节点地址         ",
                "example": "192.168.1.10",
                "notes": "必填"
              }
            },
            "keyword": "consul join"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Consul Services 注册与查询",
      "keyword": "consul services",
      "description": "服务注册到 Consul 并查询。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "consul services register -name=%{服务名}% -address=%{地址}% -port=%{端口}%",
        "extensions": [
          {
            "name": "查看所有注册服务",
            "cmd": "curl localhost:8500/v1/catalog/services",
            "params": {},
            "keyword": "consul catalog services"
          },
          {
            "name": "查看特定服务实例",
            "cmd": "curl localhost:8500/v1/health/service/%{服务名}%",
            "params": {
              "服务名": {
                "type": "string",
                "required": true,
                "description": "服务名称           ",
                "example": "payment",
                "notes": "必填"
              }
            },
            "keyword": "consul health service"
          },
          {
            "name": " deregister 服务",
            "cmd": "consul services deregister -id=%{服务ID}%",
            "params": {
              "服务ID": {
                "type": "string",
                "required": true,
                "description": "服务 ID          ",
                "example": "payment-001",
                "notes": "必填"
              }
            },
            "keyword": "consul deregister"
          }
        ],
        "params": {
          "服务名": {
            "type": "string",
            "required": true,
            "description": "服务名称           ",
            "example": "payment",
            "notes": "必填"
          },
          "地址": {
            "type": "string",
            "required": true,
            "description": "服务地址           ",
            "example": "127.0.0.1",
            "notes": "必填"
          },
          "端口": {
            "type": "string",
            "required": true,
            "description": "服务端口           ",
            "example": "8080",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "etcdctl 集群健康检查",
      "keyword": "etcdctl cluster-health",
      "description": "检查 etcd 集群健康状态。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "etcdctl cluster-health",
        "extensions": [
          {
            "name": "查看成员列表",
            "cmd": "etcdctl member list",
            "params": {},
            "keyword": "etcdctl member list"
          },
          {
            "name": "写入 Key-Value",
            "cmd": "etcdctl put %{key}% %{value}%",
            "params": {
              "key": {
                "type": "string",
                "required": true,
                "description": "键名             ",
                "example": "config/service",
                "notes": "必填"
              },
              "value": {
                "type": "string",
                "required": true,
                "description": "值              ",
                "example": "localhost:8080",
                "notes": "必填"
              }
            },
            "keyword": "etcdctl put"
          },
          {
            "name": "读取 Key",
            "cmd": "etcdctl get %{key}%",
            "params": {
              "key": {
                "type": "string",
                "required": true,
                "description": "键名             ",
                "example": "config/service",
                "notes": "必填"
              }
            },
            "keyword": "etcdctl get"
          },
          {
            "name": "监听 Key 变化",
            "cmd": "etcdctl watch %{key}%",
            "params": {
              "key": {
                "type": "string",
                "required": true,
                "description": "键名             ",
                "example": "config/service",
                "notes": "必填"
              }
            },
            "keyword": "etcdctl watch"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Eureka Maven 依赖",
      "keyword": "eureka server maven",
      "description": "Eureka 服务端 Maven 依赖配置（Java Spring Boot）",
      "data": {
        "cmd": "<!-- Eureka Server 依赖 -->\n<dependency>\n    <groupId>org.springframework.cloud</groupId>\n    <artifactId>spring-cloud-starter-netflix-eureka-server</artifactId>\n</dependency>\n\n<!-- Eureka Client 依赖 -->\n<dependency>\n    <groupId>org.springframework.cloud</groupId>\n    <artifactId>spring-cloud-starter-netflix-eureka-client</artifactId>\n</dependency>",
        "extensions": [
          {
            "name": "Eureka Server 配置（application.yml）",
            "cmd": "server:\n  port: 8761\neureka:\n  instance:\n    hostname: localhost\n  client:\n    register-with-eureka: false\n    fetch-registry: false",
            "params": {},
            "keyword": "eureka server config"
          },
          {
            "name": "Eureka Client 配置（application.yml）",
            "cmd": "eureka:\n  client:\n    service-url:\n      defaultZone: http://localhost:8761/eureka/\n  instance:\n    prefer-ip-address: true",
            "params": {},
            "keyword": "eureka client config"
          },
          {
            "name": "启用服务发现注解",
            "cmd": "@EnableDiscoveryClient",
            "params": {},
            "keyword": "EnableDiscoveryClient"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Nacos 服务注册",
      "keyword": "nacos service register",
      "description": "Nacos 服务注册与发现操作。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "curl -X POST 'http://%{NACOS_HOST}%:8848/nacos/v1/ns/instance' \\\n  -d 'serviceName=%{服务名}%' \\\n  -d 'ip=%{IP地址}%' \\\n  -d 'port=%{端口}%'",
        "extensions": [
          {
            "name": "查询服务实例列表",
            "cmd": "curl 'http://%{NACOS_HOST}%:8848/nacos/v1/ns/instance/list?serviceName=%{服务名}%'",
            "params": {
              "NACOS_HOST": {
                "type": "string",
                "required": false,
                "description": "Nacos 服务器地址    ",
                "example": "localhost",
                "notes": "默认 localhost"
              },
              "服务名": {
                "type": "string",
                "required": true,
                "description": "服务名称           ",
                "example": "order-service",
                "notes": "必填"
              }
            },
            "keyword": "nacos query service"
          },
          {
            "name": "发布配置",
            "cmd": "curl -X POST 'http://%{NACOS_HOST}%:8848/nacos/v1/cs/configs' \\\n  -d 'dataId=%{配置ID}%' \\\n  -d 'group=%{分组}%' \\\n  -d 'content=%{内容}%'",
            "params": {
              "NACOS_HOST": {
                "type": "string",
                "required": false,
                "description": "Nacos 服务器地址    ",
                "example": "localhost",
                "notes": "默认 localhost"
              },
              "配置ID": {
                "type": "string",
                "required": true,
                "description": "配置 ID          ",
                "example": "application.yml",
                "notes": "必填"
              },
              "分组": {
                "type": "string",
                "required": false,
                "description": "配置分组           ",
                "example": "DEFAULT_GROUP",
                "notes": "默认 DEFAULT_GROUP"
              },
              "内容": {
                "type": "string",
                "required": true,
                "description": "配置内容           ",
                "example": "server.port=8080",
                "notes": "必填"
              }
            },
            "keyword": "nacos publish config"
          },
          {
            "name": "获取配置",
            "cmd": "curl 'http://%{NACOS_HOST}%:8848/nacos/v1/cs/configs?dataId=%{配置ID}%&group=%{分组}%'",
            "params": {
              "NACOS_HOST": {
                "type": "string",
                "required": false,
                "description": "Nacos 服务器地址    ",
                "example": "localhost",
                "notes": "默认 localhost"
              },
              "配置ID": {
                "type": "string",
                "required": true,
                "description": "配置 ID          ",
                "example": "application.yml",
                "notes": "必填"
              },
              "分组": {
                "type": "string",
                "required": false,
                "description": "配置分组           ",
                "example": "DEFAULT_GROUP",
                "notes": "默认 DEFAULT_GROUP"
              }
            },
            "keyword": "nacos get config"
          }
        ],
        "params": {
          "NACOS_HOST": {
            "type": "string",
            "required": false,
            "description": "Nacos 服务器地址    ",
            "example": "localhost",
            "notes": "默认 localhost"
          },
          "服务名": {
            "type": "string",
            "required": true,
            "description": "服务名称           ",
            "example": "order-service",
            "notes": "必填"
          },
          "IP地址": {
            "type": "string",
            "required": true,
            "description": "服务 IP 地址       ",
            "example": "192.168.1.100",
            "notes": "必填"
          },
          "端口": {
            "type": "string",
            "required": true,
            "description": "服务端口           ",
            "example": "8080",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Kong API Gateway 启动管理",
      "keyword": "kong start",
      "description": "Kong API 网关启动与管理命令。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kong start",
        "extensions": [
          {
            "name": "重新加载配置",
            "cmd": "kong reload",
            "params": {},
            "keyword": "kong reload"
          },
          {
            "name": "停止 Kong",
            "cmd": "kong stop",
            "params": {},
            "keyword": "kong stop"
          },
          {
            "name": "检查配置语法",
            "cmd": "kong config parse /etc/kong/kong.yml",
            "params": {},
            "keyword": "kong config parse"
          },
          {
            "name": "查看节点状态",
            "cmd": "curl http://localhost:8001/",
            "params": {},
            "keyword": "kong status"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Kong Route 与 Service 管理",
      "keyword": "kong route service",
      "description": "Kong 路由与服务配置。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "# 创建 Upstream（上游服务）\ncurl -i -X POST http://localhost:8001/upstreams \\\n  -d 'name=%{上游名}%' \\\n  -d 'healthchecks.active.url=http://%{上游名}%/health'\n\n# 创建 Target（后端实例）\ncurl -X POST http://localhost:8001/upstreams/%{上游名}%/targets \\\n  -d 'target=%{目标地址}%:%{目标端口}%'",
        "extensions": [
          {
            "name": "创建 Service",
            "cmd": "curl -i -X POST http://localhost:8001/services \\\n  -d 'name=%{服务名}%' \\\n  -d 'url=http://%{上游名}%/'",
            "params": {
              "服务名": {
                "type": "string",
                "required": true,
                "description": "服务名称           ",
                "example": "order-service",
                "notes": "必填"
              },
              "上游名": {
                "type": "string",
                "required": true,
                "description": "上游名称           ",
                "example": "order-upstream",
                "notes": "必填"
              }
            },
            "keyword": "kong create service"
          },
          {
            "name": "创建 Route",
            "cmd": "curl -i -X POST http://localhost:8001/routes \\\n  -d 'name=%{路由名}%' \\\n  -d 'service.name=%{服务名}%' \\\n  -d 'paths[]=/%{路径}%'",
            "params": {
              "路由名": {
                "type": "string",
                "required": true,
                "description": "路由名称           ",
                "example": "order-route",
                "notes": "必填"
              },
              "服务名": {
                "type": "string",
                "required": true,
                "description": "服务名称           ",
                "example": "order-service",
                "notes": "必填"
              },
              "路径": {
                "type": "string",
                "required": true,
                "description": "路由路径           ",
                "example": "api/orders",
                "notes": "必填"
              }
            },
            "keyword": "kong create route"
          },
          {
            "name": "启用限流插件",
            "cmd": "curl -X POST http://localhost:8001/services/%{服务名}%/plugins \\\n  -d 'name=rate-limiting' \\\n  -d 'config.minute=100'",
            "params": {
              "服务名": {
                "type": "string",
                "required": true,
                "description": "服务名称           ",
                "example": "order-service",
                "notes": "必填"
              }
            },
            "keyword": "kong rate limiting"
          }
        ],
        "params": {
          "上游名": {
            "type": "string",
            "required": true,
            "description": "上游服务名称         ",
            "example": "order-upstream",
            "notes": "必填"
          },
          "目标地址": {
            "type": "string",
            "required": true,
            "description": "后端实例地址         ",
            "example": "192.168.1.101",
            "notes": "必填"
          },
          "目标端口": {
            "type": "string",
            "required": true,
            "description": "后端实例端口         ",
            "example": "8080",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "Nginx 网关配置",
      "keyword": "nginx upstream",
      "description": "Nginx upstream 负载均衡与网关配置。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "upstream %{上游名}% {\n    server %{后端1}% weight=5;\n    server %{后端2}% weight=5;\n    keepalive 32;\n}\n\nserver {\n    listen 80;\n    server_name %{域名}%;\n\n    location / {\n        proxy_pass http://%{上游名}%;\n        proxy_set_header Host $host;\n        proxy_set_header X-Real-IP $remote_addr;\n        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n    }\n}",
        "extensions": [
          {
            "name": "Nginx 健康检查",
            "cmd": "nginx -t",
            "params": {},
            "keyword": "nginx config test"
          },
          {
            "name": "重新加载配置",
            "cmd": "nginx -s reload",
            "params": {},
            "keyword": "nginx reload"
          },
          {
            "name": "平滑升级",
            "cmd": "nginx -s upgrade",
            "params": {},
            "keyword": "nginx upgrade"
          }
        ],
        "params": {
          "上游名": {
            "type": "string",
            "required": true,
            "description": "上游服务名称         ",
            "example": "order_backend",
            "notes": "必填"
          },
          "后端1": {
            "type": "string",
            "required": true,
            "description": "后端服务器地址        ",
            "example": "192.168.1.101:8080",
            "notes": "必填"
          },
          "后端2": {
            "type": "string",
            "required": true,
            "description": "后端服务器地址        ",
            "example": "192.168.1.102:8080",
            "notes": "必填"
          },
          "域名": {
            "type": "string",
            "required": true,
            "description": "服务域名           ",
            "example": "api.example.com",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/微服务架构/",
      "name": "AWS API Gateway REST API",
      "keyword": "aws apigateway restapi",
      "description": "AWS API Gateway REST API 创建与管理",
      "data": {
        "cmd": "aws apigateway create-rest-api --name '%{API名称}%'",
        "extensions": [
          {
            "name": "创建资源",
            "cmd": "aws apigateway create-resource --rest-api-id %{API_ID}% --parent-id %{父资源ID}% --path-part '%{路径}%'",
            "params": {
              "API_ID": {
                "type": "string",
                "required": true,
                "description": "API ID         ",
                "example": "abc123def",
                "notes": "必填"
              },
              "父资源ID": {
                "type": "string",
                "required": true,
                "description": "父资源 ID         ",
                "example": "abc123",
                "notes": "必填"
              },
              "路径": {
                "type": "string",
                "required": true,
                "description": "资源路径           ",
                "example": "orders",
                "notes": "必填"
              }
            },
            "keyword": "aws apigateway create-resource"
          },
          {
            "name": "创建方法",
            "cmd": "aws apigateway put-method --rest-api-id %{API_ID}% --resource-id %{资源ID}% --http-method GET --authorization-type NONE",
            "params": {
              "API_ID": {
                "type": "string",
                "required": true,
                "description": "API ID         ",
                "example": "abc123def",
                "notes": "必填"
              },
              "资源ID": {
                "type": "string",
                "required": true,
                "description": "资源 ID          ",
                "example": "xyz789",
                "notes": "必填"
              }
            },
            "keyword": "aws apigateway put-method"
          },
          {
            "name": "部署 API",
            "cmd": "aws apigateway create-deployment --rest-api-id %{API_ID}% --stage-name '%{阶段名}%'",
            "params": {
              "API_ID": {
                "type": "string",
                "required": true,
                "description": "API ID         ",
                "example": "abc123def",
                "notes": "必填"
              },
              "阶段名": {
                "type": "string",
                "required": true,
                "description": "部署阶段名          ",
                "example": "prod",
                "notes": "必填"
              }
            },
            "keyword": "aws apigateway deploy"
          },
          {
            "name": "创建 Usage Plan",
            "cmd": "aws apigateway create-usage-plan --name '%{计划名}%' --throttle burstLimit=100 --throttle rateLimit=50",
            "params": {
              "计划名": {
                "type": "string",
                "required": true,
                "description": "使用计划名称         ",
                "example": "basic-plan",
                "notes": "必填"
              }
            },
            "keyword": "aws apigateway usage plan"
          }
        ],
        "params": {
          "API名称": {
            "type": "string",
            "required": true,
            "description": "API Gateway 名称 ",
            "example": "OrderServiceAPI",
            "notes": "必填"
          }
        }
      }
    },
