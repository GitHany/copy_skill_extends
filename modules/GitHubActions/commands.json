                "example": "hello-world",
                "notes": "可选"
              }
            },
            "keyword": "gh run watch 仓库"
          },
          {
            "name": "间隔时间（秒）",
            "cmd": "gh run watch %{run_id}% --interval %{seconds}%",
            "params": {
              "run_id": {
                "type": "number",
                "required": false,
                "description": "运行 ID",
                "example": "123456789",
                "notes": ""
              },
              "seconds": {
                "type": "number",
                "required": false,
                "description": "轮询间隔（秒）",
                "example": "10",
                "notes": "可选，默认 5 秒"
              }
            },
            "keyword": "gh run watch 间隔"
          }
        ],
        "params": {
          "run_id": {
            "type": "number",
            "required": true,
            "description": "运行 ID",
            "example": "123456789",
            "notes": ""
          },
          "owner": {
            "type": "string",
