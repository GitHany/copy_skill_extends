{
  "module": "GitHubActions",
  "version": "1.0",
  "description": "GitHub Actions workflow management commands",
  "commands": [
    {
      "dirPath": "/GitHubActions/",
      "name": "gh run list 查看运行列表",
      "keyword": "gh run list",
      "description": "列出 GitHub Actions 工作流运行记录",
      "data": {
        "cmd": "gh run list",
        "extensions": [
          {
            "name": "限制返回数量",
            "cmd": "gh run list --limit %{number}%",
            "params": {
              "number": {
                "type": "number",
                "required": false,
                "description": "返回数量上限",
                "example": "20",
                "notes": "常用，可选"
              }
            },
            "keyword": "gh run list 数量"
          },
          {
            "name": "按状态筛选",
            "cmd": "gh run list --status %{status}%",
            "params": {
              "status": {
                "type": "string",
                "required": false,
                "description": "运行状态",
                "example": "success",
                "notes": "可选: queued/in_progress/success/failure/cancelled"
              }
            },
            "keyword": "gh run list 状态"
          },
          {
            "name": "按分支筛选",
            "cmd": "gh run list --branch %{branch}%",
            "params": {
              "branch": {
                "type": "string",
                "required": false,
                "description": "分支名称",
                "example": "main",
                "notes": "可选"
              }
            },
            "keyword": "gh run list 分支"
          },
          {
            "name": "按工作流筛选",
            "cmd": "gh run list --workflow %{workflow}%",
            "params": {
              "workflow": {
                "type": "string",
                "required": false,
                "description": "工作流名称或 ID",
                "example": "CI",
                "notes": "可选"
              }
            },
            "keyword": "gh run list 工作流"
          },
          {
            "name": "监控运行状态",
            "cmd": "gh run list --watch",
            "params": {},
            "keyword": "gh run list 监控"
          }
        ],
        "params": {
          "number": {
            "type": "number",
            "required": false,
            "description": "返回数量上限",
            "example": "20",
            "notes": "常用，可选"
          },
          "status": {
            "type": "string",
            "required": false,
            "description": "运行状态",
            "example": "success",
            "notes": "可选: queued/in_progress/success/failure/cancelled"
          },
          "branch": {
            "type": "string",
            "required": false,
            "description": "分支名称",
            "example": "main",
            "notes": "可选"
          },
          "workflow": {
            "type": "string",
            "required": false,
            "description": "工作流名称或 ID",
            "example": "CI",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/GitHubActions/",
      "name": "gh run watch 监控运行",
      "keyword": "gh run watch",
      "description": "实时监控 GitHub Actions 工作流运行状态",
      "data": {
        "cmd": "gh run watch %{run_id}%",
        "extensions": [
          {
            "name": "监控指定仓库运行",
            "cmd": "gh run watch %{run_id}% --repo %{owner}/%{repo}%",
            "params": {
              "run_id": {
                "type": "number",
                "required": false,
                "description": "运行 ID",
                "example": "123456789",
                "notes": ""
