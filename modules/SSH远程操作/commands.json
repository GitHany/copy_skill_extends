    {
      "dirPath": "/SSH远程操作/",
      "name": "ssh-keygen 生成SSH密钥对",
      "keyword": "ssh-keygen 生成密钥",
      "description": "生成、管理SSH密钥对。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ssh-keygen -t rsa -b 4096",
        "extensions": [
          {
            "name": "生成RSA密钥对",
            "cmd": "ssh-keygen -t rsa -b %{位数}% -C \"%{注释}%\"",
            "params": {
              "位数": {
                "type": "string",
                "required": true,
                "description": "密钥位数",
                "example": "4096",
                "notes": "常用"
              },
              "注释": {
                "type": "string",
                "required": false,
                "description": "密钥注释(邮箱)",
                "example": "user@example.com",
                "notes": "可选"
              }
            },
            "keyword": "ssh-keygen rsa"
          },
          {
            "name": "生成Ed25519密钥对",
            "cmd": "ssh-keygen -t ed25519 -C \"%{注释}%\"",
            "params": {
              "注释": {
                "type": "string",
                "required": false,
                "description": "密钥注释(邮箱)",
                "example": "user@example.com",
                "notes": "可选"
              }
            },
            "keyword": "ssh-keygen ed25519"
          },
          {
            "name": "指定密钥保存路径",
            "cmd": "ssh-keygen -t %{类型}% -f %{密钥路径}%",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "密钥类型",
