{
  "module": "SSH远程操作",
  "version": "1.0",
  "description": "SSH远程操作命令模块集合，涵盖SSH远程操作的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/SSH远程操作/",
      "name": "ssh 远程连接",
      "keyword": "ssh 远程连接",
      "description": "通过SSH协议连接到远程主机。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ssh %{用户}%@%{主机}%",
        "extensions": [
          {
            "name": "指定端口连接",
            "cmd": "ssh -p %{端口}% %{用户}%@%{主机}%",
            "params": {
              "端口": {
                "type": "string",
                "required": true,
                "description": "SSH端口号",
                "example": "2222",
                "notes": "可选"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "常用"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机地址",
                "example": "192.168.1.100",
                "notes": "常用"
              }
            },
            "keyword": "ssh 端口"
          },
          {
            "name": "使用密钥文件连接",
            "cmd": "ssh -i %{密钥文件}% %{用户}%@%{主机}%",
            "params": {
              "密钥文件": {
                "type": "string",
                "required": true,
                "description": "私钥文件路径",
                "example": "~/.ssh/id_rsa",
                "notes": "可选"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "常用"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机地址",
                "example": "192.168.1.100",
                "notes": "常用"
              }
            },
            "keyword": "ssh 密钥"
          },
          {
            "name": "指定用户身份文件并指定端口",
            "cmd": "ssh -p %{端口}% -i %{密钥文件}% %{用户}%@%{主机}%",
            "params": {
              "端口": {
                "type": "string",
                "required": true,
                "description": "SSH端口号",
                "example": "2222",
                "notes": "可选"
              },
              "密钥文件": {
                "type": "string",
                "required": true,
                "description": "私钥文件路径",
                "example": "~/.ssh/id_rsa",
                "notes": "可选"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "常用"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机地址",
                "example": "192.168.1.100",
                "notes": "常用"
              }
            },
            "keyword": "ssh 密钥端口"
          },
          {
            "name": "跳板机连接",
            "cmd": "ssh -J %{跳板用户}%@%{跳板主机}% %{用户}%@%{主机}%",
            "params": {
              "跳板用户": {
                "type": "string",
                "required": true,
                "description": "跳板机用户名",
                "example": "admin",
                "notes": "可选"
              },
              "跳板主机": {
                "type": "string",
                "required": true,
                "description": "跳板机地址",
                "example": "bastion.example.com",
                "notes": "可选"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "目标用户名",
                "example": "root",
                "notes": "常用"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "目标主机地址",
                "example": "192.168.1.100",
                "notes": "常用"
              }
            },
            "keyword": "ssh 跳板"
          },
          {
            "name": "后台保持连接",
            "cmd": "ssh -o ServerAliveInterval=60 %{用户}%@%{主机}%",
            "params": {
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "常用"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机地址",
                "example": "192.168.1.100",
                "notes": "常用"
              }
            },
            "keyword": "ssh 保活"
          }
        ],
        "params": {
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户名",
            "example": "root",
            "notes": "常用"
          },
          "主机": {
            "type": "string",
            "required": true,
            "description": "主机地址或域名",
            "example": "192.168.1.100",
            "notes": "常用"
          }
        }
      }
    },
