{
  "dirPath": "/DockerCompose/",
  "name": "Docker Compose Commands",
  "keyword": "docker-compose",
  "description": "Docker Compose 容器编排命令集合，包含服务启停、状态查看、日志管理、构建拉取、运行执行、扩缩容、配置验证等常用操作。",
  "commands": [
    {
      "name": "docker-compose up",
      "keyword": "docker compose up",
      "description": "启动 Docker Compose 服务（前台或后台）",
      "data": {
        "cmd": "docker-compose up%{detached}% %{project_name}%",
        "params": [
          { "name": "detached", "type": "flag", "default": "", "description": "-d 后台运行模式", "example": "-d" },
          { "name": "project_name", "type": "string", "default": "", "description": "指定项目名称（-p 参数）", "example": "-p myproject" }
        ],
        "extensions": [
          { "name": "重建启动", "keyword": "docker-compose up --build", "description": "强制重新构建并启动服务", "cmd": "docker-compose up --build%{detached}%" },
          { "name": "强制重建", "keyword": "docker-compose up --force-recreate", "description": "强制重新创建容器", "cmd": "docker-compose up --force-recreate%{detached}%" },
          { "name": "指定文件", "keyword": "docker-compose -f", "description": "使用指定的 compose 文件", "cmd": "docker-compose -f %{file}% up%{detached}%" }
        ]
      }
    },
    {
      "name": "docker-compose down",
      "keyword": "docker compose down",
      "description": "停止并移除 Docker Compose 服务",
      "data": {
        "cmd": "docker-compose down%{volumes}% %{project_name}%",
        "params": [
          { "name": "volumes", "type": "flag", "default": "", "description": "-v 同时移除数据卷", "example": "-v" },
          { "name": "project_name", "type": "string", "default": "", "description": "指定项目名称（-p 参数）", "example": "-p myproject" }
        ],
        "extensions": [
          { "name": "清除镜像", "keyword": "docker-compose down --rmi", "description": "同时移除相关镜像", "cmd": "docker-compose down --rmi %{all_local}% %{volumes}%" },
          { "name": "清除全部", "keyword": "docker-compose down -v --rmi all", "description": "停止服务、移除容器、数据卷、镜像", "cmd": "docker-compose down -v --rmi all" }
        ]
      }
    },
    {
      "name": "docker-compose ps",
      "keyword": "docker compose ps",
      "description": "查看容器状态",
      "data": {
        "cmd": "docker-compose ps%{service}%",
        "params": [
          { "name": "service", "type": "string", "default": "", "description": "指定服务名称", "example": "web" }
        ],
        "extensions": [
          { "name": "详细状态", "keyword": "docker-compose ps -a", "description": "显示所有容器（包括已停止）", "cmd": "docker-compose ps -a%{service}%" },
          { "name": "格式化输出", "keyword": "docker-compose ps --format", "description": "格式化输出（json/table)", "cmd": "docker-compose ps --format %{format}%" }
        ]
      }
    },
    {
      "name": "docker-compose logs",
      "keyword": "docker compose logs",
      "description": "查看容器日志",
      "data": {
        "cmd": "docker-compose logs%{follow}% %{service}%",
        "params": [
          { "name": "follow", "type": "flag", "default": "", "description": "-f 实时跟踪日志", "example": "-f" },
          { "name": "service", "type": "string", "default": "", "description": "指定服务名称", "example": "web" }
        ],
        "extensions": [
          { "name": "尾随行数", "keyword": "docker-compose logs --tail", "description": "显示最后 N 行日志", "cmd": "docker-compose logs --tail %{lines}% %{service}%" },
          { "name": "时间戳", "keyword": "docker-compose logs -t", "description": "显示时间戳", "cmd": "docker-compose logs -t%{service}%" },
          { "name": "最近时间", "keyword": "docker-compose logs --since", "description": "显示最近时间内的日志", "cmd": "docker-compose logs --since %{time}% %{service}%" }
        ]
      }
    },
    {
      "name": "docker-compose build",
      "keyword": "docker compose build",
      "description": "构建服务镜像",
      "data": {
        "cmd": "docker-compose build%{service}%",
        "params": [
          { "name": "service", "type": "string", "default": "", "description": "指定服务名称（留空则构建全部）", "example": "web" }
        ],
        "extensions": [
          { "name": "强制构建", "keyword": "docker-compose build --no-cache", "description": "不使用缓存强制构建", "cmd": "docker-compose build --no-cache%{service}%" },
          { "name": "并行构建", "keyword": "docker-compose build --parallel", "description": "并行构建多个服务", "cmd": "docker-compose build --parallel%{service}%" },
          { "name": "强制拉取", "keyword": "docker-compose build --pull", "description": "总是拉取基础镜像", "cmd": "docker-compose build --pull%{service}%" }
        ]
      }
    },
    {
      "name": "docker-compose pull",
      "keyword": "docker compose pull",
      "description": "拉取服务镜像",
      "data": {
        "cmd": "docker-compose pull%{service}%",
        "params": [
          { "name": "service", "type": "string", "default": "", "description": "指定服务名称（留空则拉取全部）", "example": "web" }
        ],
        "extensions": [
          { "name": "忽略失败", "keyword": "docker-compose pull --ignore-pull-failures", "description": "忽略拉取失败继续执行", "cmd": "docker-compose pull --ignore-pull-failures%{service}%" },
          { "name": "并行拉取", "keyword": "docker-compose pull --parallel", "description": "并行拉取多个镜像", "cmd": "docker-compose pull --parallel%{service}%" },
          { "name": "静默模式", "keyword": "docker-compose pull -q", "description": "静默模式拉取", "cmd": "docker-compose pull -q%{service}%" }
        ]
      }
    },
    {
      "name": "docker-compose run",
      "keyword": "docker compose run",
      "description": "在服务容器中运行命令",
      "data": {
        "cmd": "docker-compose run%{detach}% %{service}% %{command}%",
        "params": [
          { "name": "detach", "type": "flag", "default": "", "description": "-d 后台运行", "example": "-d" },
          { "name": "service", "type": "string", "default": "", "description": "服务名称", "example": "web" },
          { "name": "command", "type": "string", "default": "", "description": "要执行的命令", "example": "bash" }
        ],
        "extensions": [
          { "name": "覆盖命令", "keyword": "docker-compose run --rm", "description": "命令执行完毕后删除容器", "cmd": "docker-compose run --rm %{service}% %{command}%" },
          { "name": "交互式", "keyword": "docker-compose run -it", "description": "交互式终端模式", "cmd": "docker-compose run -it %{service}% %{command}%" },
          { "name": "指定入口点", "keyword": "docker-compose run --entrypoint", "description": "覆盖默认入口点", "cmd": "docker-compose run --entrypoint %{entrypoint}% %{service}% %{command}%" }
        ]
      }
    },
    {
      "name": "docker-compose exec",
      "keyword": "docker compose exec",
      "description": "在运行中的容器内执行命令",
      "data": {
        "cmd": "docker-compose exec%{service}% %{command}%",
        "params": [
          { "name": "service", "type": "string", "default": "", "description": "服务名称", "example": "web" },
          { "name": "command", "type": "string", "default": "", "description": "要执行的命令", "example": "bash" }
        ],
        "extensions": [
          { "name": "交互式", "keyword": "docker-compose exec -it", "description": "交互式终端模式", "cmd": "docker-compose exec -it %{service}% %{command}%" },
          { "name": "指定用户", "keyword": "docker-compose exec -u", "description": "以指定用户身份执行", "cmd": "docker-compose exec -u %{user}% %{service}% %{command}%" },
          { "name": "工作目录", "keyword": "docker-compose exec -w", "description": "指定工作目录", "cmd": "docker-compose exec -w %{dir}% %{service}% %{command}%" }
        ]
      }
    },
    {
      "name": "docker-compose scale",
      "keyword": "docker compose scale",
      "description": "扩缩容服务实例数量",
      "data": {
        "cmd": "docker-compose scale%{service}=%{num}%",
        "params": [
          { "name": "service", "type": "string", "default": "", "description": "服务名称", "example": "web" },
          { "name": "num", "type": "number", "default": "", "description": "实例数量", "example": "3" }
        ],
        "extensions": [
          { "name": "多服务扩缩", "keyword": "docker-compose scale multiple", "description": "同时扩缩多个服务", "cmd": "docker-compose scale %{service1}%=%{num1}% %{service2}%=%{num2}%" },
          { "name": "扩展约束", "keyword": "docker-compose up --scale", "description": "启动时设置服务副本数", "cmd": "docker-compose up -d --scale %{service}%=%{num}%" }
        ]
      }
    },
    {
      "name": "docker-compose config",
      "keyword": "docker compose config",
      "description": "验证并查看 Compose 配置",
      "data": {
        "cmd": "docker-compose config%{quiet}%",
        "params": [
          { "name": "quiet", "type": "flag", "default": "", "description": "-q 只输出验证结果", "example": "-q" }
        ],
        "extensions": [
          { "name": "服务列表", "keyword": "docker-compose config --services", "description": "列出配置中的服务", "cmd": "docker-compose config --services" },
          { "name": "卷列表", "keyword": "docker-compose config --volumes", "description": "列出配置中的卷", "cmd": "docker-compose config --volumes" },
          { "name": "转换格式", "keyword": "docker-compose -f convert", "description": "转换为指定格式输出", "cmd": "docker-compose -f %{file}% convert" }
        ]
      }
    }
  ]
}