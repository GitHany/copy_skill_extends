{
  "module": "Dockerfile 构建",
  "version": "2.0",
  "description": "Docker 镜像构建相关命令，涵盖Dockerfile 构建的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Dockerfile 构建/",
      "name": "docker build 构建镜像",
      "keyword": "docker build 构建",
      "description": "从 Dockerfile 构建镜像。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker build -t %{镜像名}% .",
        "extensions": [
          {
            "name": "带构建参数",
            "cmd": "docker build --build-arg %{参数}%=%{值}% -t %{镜像}% .",
            "params": {
              "参数": {
                "type": "string",
                "required": true,
                "description": "构建参数名",
                "example": "NODE_ENV",
                "notes": "必填"
              },
              "值": {
                "type": "string",
                "required": true,
                "description": "参数值",
                "example": "production",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "myapp:latest",
                "notes": "必填"
              }
            },
            "keyword": "docker build arg"
          },
          {
            "name": "无缓存构建",
            "cmd": "docker build --no-cache -t %{镜像}% .",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名",
                "example": "myapp:latest",
                "notes": "必填"
              }
            },
            "keyword": "docker build no-cache"
          }
        ],
        "params": {
          "镜像名": {
            "type": "string",
            "required": true,
            "description": "镜像名称和标签",
            "example": "myapp:1.0",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Dockerfile 构建/",
      "name": "docker tag 标记镜像",
      "keyword": "docker tag 标记",
      "description": "给镜像打标签。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker tag %{源镜像}% %{目标镜像}%",
        "extensions": [],
        "params": {
          "源镜像": {
            "type": "string",
            "required": true,
            "description": "源镜像",
            "example": "myapp:latest",
            "notes": "必填"
          },
          "目标镜像": {
            "type": "string",
            "required": true,
            "description": "目标镜像",
            "example": "registry.com/myapp:v1",
            "notes": "必填"
          }
        }
      }
    }
  ]
}