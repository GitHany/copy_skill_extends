  "description": "容器安全命令模块 - 涵盖镜像扫描、运行时安全、容器强化、密钥扫描、合规检查和镜像签名",
  "commands": [
    {
      "dirPath": "/安全/",
      "name": "trivy image 镜像漏洞扫描",
      "keyword": "trivy scan 漏洞扫描",
      "description": "使用 Trivy 扫描容器镜像中的安全漏洞。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "trivy image %{镜像名称}%",
        "extensions": [
          {
            "name": "按严重性过滤",
            "cmd": "trivy image --severity HIGH,CRITICAL %{镜像名称}%",
            "params": {
              "镜像名称": {
                "type": "string",
                "required": true,
                "description": "镜像名称或 ID       ",
                "example": "nginx:latest",
                "notes": "常用"
              }
            },
            "keyword": "trivy 严重性过滤"
          },
          {
            "name": "JSON格式输出",
            "cmd": "trivy image -f json -o results.json %{镜像名称}%",
