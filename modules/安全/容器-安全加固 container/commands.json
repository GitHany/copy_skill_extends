              "镜像名称": {
                "type": "string",
                "required": true,
                "description": "镜像名称           ",
                "example": "nginx:latest",
                "notes": "常用"
              }
            },
            "keyword": "trivy JSON输出"
          },
          {
            "name": "忽略未修复漏洞",
            "cmd": "trivy image --ignore-unfixed %{镜像名称}%",
            "params": {
              "镜像名称": {
                "type": "string",
                "required": true,
                "description": "镜像名称           ",
                "example": "nginx:latest",
                "notes": "可选"
