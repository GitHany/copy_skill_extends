{
  "module": "kubectl exec",
  "version": "2.0",
  "description": "kubectl 容器内命令执行，涵盖kubectl exec的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl exec/",
      "name": "kubectl exec 执行命令",
      "keyword": "kubectl exec 执行",
      "description": "在 Pod 中执行命令。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl exec %{Pod}% -- %{命令}%",
        "extensions": [
          {
            "name": "交互式",
            "cmd": "kubectl exec -it %{Pod}% -- /bin/bash",
            "params": {
              "Pod": {
                "type": "string",
                "required": true,
                "description": "Pod",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl exec it"
          }
        ],
        "params": {
          "Pod": {
            "type": "string",
            "required": true,
            "description": "Pod 名称",
            "example": "my-pod",
            "notes": "必填"
          },
          "命令": {
            "type": "string",
            "required": true,
            "description": "命令",
            "example": "ls -la",
            "notes": "必填"
          }
        }
      }
    }
  ]
}