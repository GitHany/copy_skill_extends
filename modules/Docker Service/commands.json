{
  "module": "Docker Service",
  "version": "2.0",
  "description": "Docker Service命令集合，涵盖Docker Service的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Docker Service/",
      "name": "docker service create 创建服务",
      "keyword": "docker service create 创建",
      "description": "创建 Swarm 服务。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker service create --name %{名称}% %{镜像}%",
        "extensions": [
          {
            "name": "指定副本数",
            "cmd": "docker service create --name %{名称}% --replicas %{数量}% %{镜像}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "服务名",
                "example": "web",
                "notes": "必填"
              },
              "数量": {
                "type": "string",
                "required": true,
                "description": "副本数",
                "example": "3",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "docker service replicas"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "服务名称",
            "example": "myapp",
            "notes": "必填"
          },
          "镜像": {
            "type": "string",
            "required": true,
            "description": "容器镜像",
            "example": "nginx:latest",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Docker Service/",
      "name": "docker service ls 列出服务",
      "keyword": "docker service ls 列表",
      "description": "列出 Swarm 服务。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker service ls",
        "extensions": [],
        "params": {}
      }
    }
  ]
}