{
  "module": "监控可观测性/Prometheus-监控系统 Prometheus",
  "version": "2.0",
  "description": "Prometheus 监控系统命令行工具",
  "commands": [
    {
      "dirPath": "/监控可观测性/",
      "name": "promtool 检查配置",
      "keyword": "promtool 检查",
      "description": "检查 Prometheus 配置。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "promtool check config %{配置文件}%",
        "extensions": [
          {
            "name": "检查配置并输出友好错误信息",
            "cmd": "promtool check config %{配置文件}% --format=pretty",
            "params": {
              "配置文件": {
                "type": "string",
                "required": true,
                "description": "配置文件路径",
                "example": "prometheus.yml",
                "notes": "必填"
              }
            },
            "keyword": "promtool check config pretty"
          },
          {
            "name": "检查配置并显示详细输出",
            "cmd": "promtool check config %{配置文件}% --verbose",
            "params": {
              "配置文件": {
                "type": "string",
                "required": true,
                "description": "配置文件路径",
                "example": "prometheus.yml",
                "notes": "必填"
              }
            },
            "keyword": "promtool check config verbose"
          },
          {
            "name": "检查多个配置文件",
            "cmd": "promtool check config %{配置文件1}% %{配置文件2}%",
            "params": {
              "配置文件1": {
                "type": "string",
                "required": true,
                "description": "第一个配置文件",
                "example": "prometheus.yml",
                "notes": "必填"
              },
              "配置文件2": {
                "type": "string",
                "required": true,
                "description": "第二个配置文件",
                "example": "alerts.yml",
                "notes": "必填"
              }
            },
            "keyword": "promtool check multiple config"
          }
        ],
        "params": {
          "配置文件": {
            "type": "string",
            "required": true,
            "description": "配置文件路径",
            "example": "prometheus.yml",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/监控可观测性/",
      "name": "promtool 规则验证",
      "keyword": "promtool 规则",
      "description": "验证 Prometheus 规则文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "promtool check rules %{规则文件}%",
        "extensions": [
          {
            "name": "验证规则文件并输出友好格式",
            "cmd": "promtool check rules %{规则文件}% --format=pretty",
            "params": {
              "规则文件": {
                "type": "string",
                "required": true,
                "description": "规则文件路径",
                "example": "rules.yml",
                "notes": "必填"
              }
            },
            "keyword": "promtool check rules pretty"
          },
          {
            "name": "验证规则并显示警告",
            "cmd": "promtool check rules %{规则文件}% --warnings",
            "params": {
              "规则文件": {
                "type": "string",
                "required": true,
                "description": "规则文件路径",
                "example": "rules.yml",
                "notes": "必填"
              }
            },
            "keyword": "promtool check rules warnings"
          },
          {
            "name": "验证整个规则目录",
            "cmd": "promtool check rules %{规则目录}%/*.yml",
            "params": {
              "规则目录": {
                "type": "string",
                "required": true,
                "description": "规则文件所在目录",
                "example": "/etc/prometheus/rules",
                "notes": "必填"
              }
            },
            "keyword": "promtool check rules directory"
          }
        ],
        "params": {
          "规则文件": {
            "type": "string",
            "required": true,
            "description": "规则文件路径",
            "example": "rules.yml",
            "notes": "必填"
          }
        }
      }
    }
  ]
}