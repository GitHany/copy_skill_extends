{
  "module": "Docker Inspect",
  "version": "2.0",
  "description": "Docker Inspect命令集合，涵盖Docker Inspect的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Docker Inspect/",
      "name": "docker inspect 检查容器",
      "keyword": "docker inspect 检查",
      "description": "查看容器详细信息。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker inspect %{容器}%",
        "extensions": [],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Docker Inspect/",
      "name": "docker inspect 格式化输出",
      "keyword": "docker inspect 格式",
      "description": "格式化检查输出。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker inspect -f '{{.State.Status}}' %{容器}%",
        "extensions": [],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}