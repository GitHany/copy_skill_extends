{
  "module": "后端开发/Rust-包管理 Cargo",
  "version": "2.0",
  "description": "Rust Cargo命令集合，涵盖Rust Cargo的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/后端开发/",
      "name": "cargo new 创建项目",
      "keyword": "cargo new 创建",
      "description": "创建新的 Rust 项目。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "cargo new %{项目名}%",
        "extensions": [
          {
            "name": "创建库项目",
            "cmd": "cargo new --lib %{项目名}%",
            "params": {
              "项目名": {
                "type": "string",
                "required": true,
                "description": "项目名            ",
                "example": "my_project",
                "notes": "必填"
              }
            },
            "keyword": "cargo new lib"
          }
        ],
        "params": {
          "项目名": {
            "type": "string",
            "required": true,
            "description": "项目名称           ",
            "example": "hello_world",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/后端开发/",
      "name": "cargo build 编译项目",
      "keyword": "cargo build 编译",
      "description": "编译 Rust 项目。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "cargo build",
        "extensions": [
          {
            "name": "发布编译",
            "cmd": "cargo build --release",
            "params": {},
            "keyword": "cargo build release"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/后端开发/",
      "name": "cargo run 运行程序",
      "keyword": "cargo run 运行",
      "description": "编译并运行项目。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "cargo run",
        "extensions": [
          {
            "name": "带参数运行",
            "cmd": "cargo run -- %{参数}%",
            "params": {
              "参数": {
                "type": "string",
                "required": true,
                "description": "程序参数           ",
                "example": "arg1 arg2",
                "notes": "必填"
              }
            },
            "keyword": "cargo run args"
          }
        ],
        "params": {}
      }
    }
  ]
}