{
  "module": "Yarn",
  "version": "2.0",
  "description": "Yarn JavaScript 包管理器",
  "commands": [
    {
      "dirPath": "/Yarn/",
      "name": "yarn install 安装依赖",
      "keyword": "yarn install 安装",
      "description": "安装项目依赖。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "yarn install",
        "extensions": [
          {
            "name": "生产依赖",
            "cmd": "yarn install --production",
            "params": {},
            "keyword": "yarn prod"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/Yarn/",
      "name": "yarn add 添加包",
      "keyword": "yarn add 添加",
      "description": "添加依赖包。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "yarn add %{包名}%",
        "extensions": [],
        "params": {
          "包名": {
            "type": "string",
            "required": true,
            "description": "包名",
            "example": "lodash",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Yarn/",
      "name": "yarn remove 移除包",
      "keyword": "yarn remove 移除",
      "description": "移除依赖包。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "yarn remove %{包名}%",
        "extensions": [],
        "params": {
          "包名": {
            "type": "string",
            "required": true,
            "description": "包名",
            "example": "lodash",
            "notes": "必填"
          }
        }
      }
    }
  ]
}