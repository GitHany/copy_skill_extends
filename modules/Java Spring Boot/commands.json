{
  "module": "Java Spring Boot",
  "version": "1.0",
  "description": "Java Spring Boot 全栈开发命令模块，涵盖初始化、核心开发、数据访问、安全配置、监控运维及构建部署",
  "commands": [
    {
      "dirPath": "/Java Spring Boot/",
      "name": "spring init 项目初始化",
      "keyword": "spring init 初始化",
      "description": "使用 Spring Initializr 初始化 Spring Boot 项目",
      "data": {
        "cmd": "curl https://start.spring.io/starter.tgz -d type=maven-project -d language=java -d bootVersion=3.2.0 -d baseDir=%{项目名称}% -d groupId=%{组ID}% -d artifactId=%{制品ID}% -d name=%{项目名称}% -d packageName=%{包名}% -d javaVersion=17 -d dependencies=web,data-jpa | tar -xzf -",
        "extensions": [
          {
            "name": "Maven 项目",
            "cmd": "spring init --name=%{名称}% --type=maven-project --java-version=%{Java版本}% %{目录}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "项目名称",
                "example": "myapp",
                "notes": "常用"
              },
              "Java版本": {
                "type": "string",
                "required": false,
                "description": "Java版本",
                "example": "17",
                "notes": "可选"
              },
              "目录": {
                "type": "string",
                "required": true,
                "description": "项目目录",
                "example": "myapp",
                "notes": "常用"
              }
            },
            "keyword": "spring init maven"
          },
          {
            "name": "Gradle 项目",
            "cmd": "spring init --type=gradle-project --dependencies=web,data-jpa %{目录}%",
            "params": {
              "目录": {
                "type": "string",
                "required": true,
                "description": "项目目录",
                "example": "myapp",
                "notes": "常用"
              }
            },
            "keyword": "spring init gradle"
          },
          {
            "name": "添加依赖",
            "cmd": "spring init --dependencies=web,actuator,security %{目录}%",
            "params": {
              "目录": {
                "type": "string",
                "required": true,
                "description": "项目目录",
                "example": "myapp",
                "notes": "常用"
              }
            },
            "keyword": "spring init 添加依赖"
          },
          {
            "name": "交互式初始化",
            "cmd": "spring init",
            "params": {},
            "keyword": "spring init 交互"
          }
        ],
        "params": {
          "项目名称": {
            "type": "string",
            "required": true,
            "description": "项目名称/目录名",
            "example": "myapp",
            "notes": "常用"
          },
          "组ID": {
            "type": "string",
            "required": true,
            "description": "Maven GroupId",
            "example": "com.example",
            "notes": "常用"
          },
          "制品ID": {
            "type": "string",
            "required": true,
            "description": "Maven ArtifactId",
            "example": "myapp",
            "notes": "常用"
          },
          "包名": {
            "type": "string",
            "required": true,
            "description": "基础包名",
            "example": "com.example.myapp",
            "notes": "常用"
          }
        }
      }
    },
    {
