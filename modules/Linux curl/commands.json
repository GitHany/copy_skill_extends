{
  "module": "Linux curl",
  "version": "2.0",
  "description": "Curl HTTP 客户端工具，涵盖Linux curl的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux curl/",
      "name": "curl 发送请求",
      "keyword": "curl 请求",
      "description": "发送 HTTP 请求。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "curl -X %{方法}% %{URL}%",
        "extensions": [
          {
            "name": "带数据",
            "cmd": "curl -X POST -d '%{数据}%' %{URL}%",
            "params": {
              "方法": {
                "type": "string",
                "required": true,
                "description": "方法",
                "example": "POST",
                "notes": "必填"
              },
              "数据": {
                "type": "string",
                "required": true,
                "description": "数据",
                "example": "{\name\\:\test\\}",
                "notes": "必填"
              },
              "URL": {
                "type": "string",
                "required": true,
                "description": "URL",
                "example": "https://api.example.com",
                "notes": "必填"
              }
            },
            "keyword": "curl post"
          }
        ],
        "params": {
          "方法": {
            "type": "string",
            "required": true,
            "description": "HTTP 方法",
            "example": "GET",
            "notes": "必填"
          },
          "URL": {
            "type": "string",
            "required": true,
            "description": "目标 URL",
            "example": "https://api.example.com/data",
            "notes": "必填"
          }
        }
      }
    }
  ]
}