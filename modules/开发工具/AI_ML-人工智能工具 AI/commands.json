      "dirPath": "/开发工具/",
      "name": "pgvector SQL 命令",
      "keyword": "pgvector postgres postgresql vector embedding",
      "description": "PostgreSQL pgvector 扩展的向量数据库 SQL 命令",
      "data": {
        "cmd": "CREATE EXTENSION IF NOT EXISTS vector;",
        "extensions": [
          {
            "name": "创建向量列",
            "cmd": "CREATE TABLE items (id bigserial PRIMARY KEY, embedding vector(%{维度}%));",
            "params": {
              "维度": {
                "type": "string",
                "required": true,
                "description": "向量维度           ",
                "example": "1536",
                "notes": "可选"
              }
            },
            "keyword": "pgvector CREATE TABLE"
          },
          {
            "name": "插入向量",
            "cmd": "INSERT INTO items (embedding) VALUES ('[%{值}%]');",
            "params": {
              "值": {
                "type": "string",
                "required": true,
                "description": "向量值            ",
                "example": "0.1,0.2",
                "notes": "可选"
              }
            },
            "keyword": "pgvector INSERT"
          },
          {
            "name": "L2 距离最近邻搜索",
            "cmd": "SELECT * FROM items ORDER BY embedding <-> '[%{查询向量}%]' LIMIT %{数量}%;",
            "params": {
              "查询向量": {
                "type": "string",
                "required": true,
                "description": "查询向量           ",
                "example": "0.1,0.2",
                "notes": "可选"
              },
              "数量": {
                "type": "string",
                "required": true,
                "description": "返回数量           ",
                "example": "5",
                "notes": "可选"
              }
            },
            "keyword": "pgvector 搜索 L2"
          },
          {
            "name": "余弦距离搜索",
