  "commands": [
    {
      "dirPath": "/开发工具/",
      "name": "regex 邮箱验证",
      "keyword": "/regex 邮箱",
      "description": "验证邮箱格式。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "/regex email %{内容}%",
        "extensions": [
          {
            "name": "全局匹配",
            "cmd": "/regex email %{内容}% --global",
            "params": {
              "内容": {
                "type": "string",
                "required": true,
                "description": "要验证的内容         ",
                "example": "test@example.com",
                "notes": "必填"
              }
            },
            "keyword": "regex email global"
          },
          {
            "name": "忽略大小写",
            "cmd": "/regex email %{内容}% --ignore-case",
            "params": {
              "内容": {
                "type": "string",
                "required": true,
                "description": "要验证的内容         ",
                "example": "TEST@EXAMPLE.COM",
                "notes": "必填"
              }
            },
            "keyword": "regex email ignore-case"
          },
          {
            "name": "验证并提取",
            "cmd": "/regex email %{内容}% --extract",
            "params": {
              "内容": {
                "type": "string",
                "required": true,
                "description": "要验证的内容         ",
                "example": "contact: test@example.com",
                "notes": "必填"
              }
            },
            "keyword": "regex email extract"
          },
          {
            "name": "严格模式",
            "cmd": "/regex email %{内容}% --strict",
            "params": {
              "内容": {
                "type": "string",
                "required": true,
                "description": "要验证的内容         ",
                "example": "test@example.com",
                "notes": "必填"
              }
            },
            "keyword": "regex email strict"
          }
        ],
        "params": {
          "内容": {
            "type": "string",
            "required": true,
            "description": "要验证的内容         ",
            "example": "test@example.com",
            "notes": "必填"
          }
        }
      }
    },
