{
  "module": "kubectl delete",
  "version": "2.0",
  "description": "kubectl 删除资源，涵盖kubectl delete的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl delete/",
      "name": "kubectl delete 删除资源",
      "keyword": "kubectl delete 删除",
      "description": "删除 Kubernetes 资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl delete %{类型}% %{名称}%",
        "extensions": [
          {
            "name": "强制删除",
            "cmd": "kubectl delete %{类型}% %{名称}% --grace-period=0",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "类型",
                "example": "pod",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "名称",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete force"
          },
          {
            "name": "删除全部",
            "cmd": "kubectl delete %{类型}% --all",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "类型",
                "example": "pods",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete all"
          }
        ],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "资源类型",
            "example": "deployment",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "资源名称",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}