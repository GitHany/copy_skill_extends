{
  "module": "Docker 命令",
  "version": "1.0",
  "description": "Docker 命令 模块命令集合",
  "commands": [
    {
      "dirPath": "/Docker 命令/",
      "name": "docker run 运行容器",
      "keyword": "docker run 启动",
      "description": "创建并启动一个新容器",
      "data": {
        "cmd": "docker run -d --name %{容器名称}% -p %{主机端口}%:%{容器端口}% %{镜像名称}%",
        "extensions": [
          {
            "name": "挂载卷",
            "cmd": "docker run -d --name %{容器名称}% -v %{主机路径}%:%{容器路径}% %{镜像}%",
            "params": {
              "容器名称": { "type": "string", "required": true, "description": "容器名称", "example": "myapp", "notes": "常用" },
              "主机路径": { "type": "string", "required": true, "description": "宿主机目录", "example": "/data/logs", "notes": "" },
              "容器路径": { "type": "string", "required": true, "description": "容器内目录", "example": "/app/logs", "notes": "" },
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "nginx", "notes": "常用" }
            },
            "keyword": "docker run 挂载卷"
          },
          {
            "name": "环境变量",
            "cmd": "docker run -d --name %{容器名称}% -e %{环境变量}%=%{变量值}% %{镜像}%",
            "params": {
              "容器名称": { "type": "string", "required": true, "description": "容器名称", "example": "myapp", "notes": "常用" },
              "环境变量": { "type": "string", "required": true, "description": "环境变量名", "example": "MYSQL_ROOT_PASSWORD", "notes": "" },
              "变量值": { "type": "string", "required": true, "description": "环境变量值", "example": "password123", "notes": "" },
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "mysql", "notes": "" }
            },
            "keyword": "docker run 环境变量"
          },
          {
            "name": "连接网络",
            "cmd": "docker run -d --name %{容器名称}% --network %{网络名称}% %{镜像}%",
            "params": {
              "容器名称": { "type": "string", "required": true, "description": "容器名称", "example": "myapp", "notes": "常用" },
              "网络名称": { "type": "string", "required": true, "description": "Docker网络名称", "example": "my_network", "notes": "" },
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "nginx", "notes": "" }
            },
            "keyword": "docker run 连接网络"
          },
          {
            "name": "交互模式",
            "cmd": "docker run -it %{镜像}% /bin/bash",
            "params": {
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "ubuntu", "notes": "常用" }
            },
            "keyword": "docker run 交互模式"
          },
          {
            "name": "后台运行",
            "cmd": "docker run -d %{镜像}%",
            "params": {
              "镜像": { "type": "string", "required": true, "description": "镜像名称", "example": "nginx", "notes": "常用" }
            },
            "keyword": "docker run 后台运行"
          }
        ],
        "params": {
          "容器名称": { "type": "string", "required": true, "description": "容器名称", "example": "myapp", "notes": "常用" },
          "主机端口": { "type": "string", "required": true, "description": "宿主机端口", "example": "8080", "notes": "常用" },
          "容器端口": { "type": "string", "required": true, "description": "容器端口", "example": "80", "notes": "常用" },
          "镜像名称": { "type": "string", "required": true, "description": "镜像名称", "example": "nginx", "notes": "常用" }
        }
      }
    },
    {
      "dirPath": "/Docker 命令/",
      "name": "docker ps 查看容器",
      "keyword": "docker ps 查看",
      "description": "列出运行中的容器",
      "data": {
