            },
            "keyword": "docker start 启动"
          },
          {
            "name": "重启容器",
            "cmd": "docker restart %{容器名称或ID}%",
            "params": {
              "容器名称或ID": { "type": "string", "required": true, "description": "容器名称或ID", "example": "myapp", "notes": "常用" }
            },
            "keyword": "docker restart 重启"
          },
          {
            "name": "强制停止",
            "cmd": "docker kill %{容器名称或ID}%",
            "params": {
              "容器名称或ID": { "type": "string", "required": true, "description": "容器名称或ID", "example": "myapp", "notes": "" }
            },
            "keyword": "docker kill 强制停止"
          }
        ],
        "params": {
          "容器名称或ID": { "type": "string", "required": true, "description": "容器名称或ID", "example": "myapp", "notes": "常用" }
        }
      }
    },
