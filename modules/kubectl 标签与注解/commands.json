{
  "module": "kubectl 标签与注解",
  "version": "2.0",
  "description": "kubectl 标签与注解命令集合，涵盖kubectl 标签与注解的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl 标签与注解/",
      "name": "kubectl label 设置标签",
      "keyword": "kubectl label 标签",
      "description": "设置资源标签。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl label %{资源类型}% %{名称}% %{键}%=%{值}%",
        "extensions": [
          {
            "name": "覆盖标签",
            "cmd": "kubectl label --overwrite %{资源类型}% %{名称}% %{键}%=%{值}%",
            "params": {
              "资源类型": {
                "type": "string",
                "required": true,
                "description": "类型",
                "example": "pod",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "名",
                "example": "my-pod",
                "notes": "必填"
              },
              "键": {
                "type": "string",
                "required": true,
                "description": "标签键",
                "example": "environment",
                "notes": "必填"
              },
              "值": {
                "type": "string",
                "required": true,
                "description": "标签值",
                "example": "production",
                "notes": "必填"
              }
            },
            "keyword": "kubectl label overwrite"
          }
        ],
        "params": {
          "资源类型": {
            "type": "string",
            "required": true,
            "description": "资源类型",
            "example": "deployment",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "资源名称",
            "example": "myapp",
            "notes": "必填"
          },
          "键": {
            "type": "string",
            "required": true,
            "description": "标签键名",
            "example": "tier",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "标签值",
            "example": "frontend",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/kubectl 标签与注解/",
      "name": "kubectl annotate 设置注解",
      "keyword": "kubectl annotate 注解",
      "description": "设置资源注解。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl annotate %{资源类型}% %{名称}% %{键}%=\"%{值}%\"",
        "extensions": [],
        "params": {
          "资源类型": {
            "type": "string",
            "required": true,
            "description": "类型",
            "example": "pod",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "名",
            "example": "my-pod",
            "notes": "必填"
          },
          "键": {
            "type": "string",
            "required": true,
            "description": "注解键",
            "example": "description",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "注解值",
            "example": "Production web server",
            "notes": "必填"
          }
        }
      }
    }
  ]
}