{
  "module": "Linux ssh-keygen",
  "version": "2.0",
  "description": "SSH 密钥生成管理，涵盖Linux ssh-keygen的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux ssh-keygen/",
      "name": "ssh-keygen 生成密钥",
      "keyword": "ssh-keygen 密钥",
      "description": "生成 SSH 密钥对。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ssh-keygen -t %{类型}% -f %{文件}% -C %{注释}%",
        "extensions": [],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "密钥类型",
            "example": "rsa",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件路径",
            "example": "~/.ssh/id_rsa",
            "notes": "必填"
          },
          "注释": {
            "type": "string",
            "required": true,
            "description": "注释",
            "example": "user@email.com",
            "notes": "必填"
          }
        }
      }
    }
  ]
}