{
  "module": "kubectl annotate",
  "version": "2.0",
  "description": "kubectl 注解管理，涵盖kubectl annotate的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl annotate/",
      "name": "kubectl annotate 设置注解",
      "keyword": "kubectl annotate 注解",
      "description": "给资源添加注解。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl annotate %{类型}% %{名称}% %{键}%=\"%{值}%\"",
        "extensions": [],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "类型",
            "example": "pod",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "名",
            "example": "my-pod",
            "notes": "必填"
          },
          "键": {
            "type": "string",
            "required": true,
            "description": "键",
            "example": "description",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "值",
            "example": "Production app",
            "notes": "必填"
          }
        }
      }
    }
  ]
}