{
  "module": "Git 历史与版本",
  "version": "2.0",
  "description": "Git 历史与版本命令集合，涵盖Git 历史与版本的常用操作和最佳实践",
  "commands": [
    {
      "cmd": "git log",
      "extensions": [
        {
          "name": "单行格式",
          "cmd": "git log --oneline",
          "params": {},
          "keyword": "git log oneline"
        },
        {
          "name": "图形视图",
          "cmd": "git log --graph --oneline --all",
          "params": {},
          "keyword": "git log graph"
        },
        {
          "name": "显示文件历史",
          "cmd": "git log --follow %{文件}%",
          "params": {
            "文件": {
              "type": "string",
              "required": true,
              "description": "文件路径",
              "example": "README.md",
              "notes": "必填"
            }
          },
          "keyword": "git log file"
        },
        {
          "name": "限制条数",
          "cmd": "git log -n %{数量}%",
          "params": {
            "数量": {
              "type": "string",
              "required": true,
              "description": "显示条数",
              "example": "10",
              "notes": "必填"
            }
          },
          "keyword": "git log limit"
        }
      ],
      "params": {},
      "dirPath": "/Git 历史与版本/",
      "name": "Git 历史与版本 命令",
      "keyword": "Git 历史与版本 命令",
      "description": "Git 历史与版本 命令的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    }
  ]
}