{
  "module": "Linux alias",
  "version": "2.0",
  "description": "Linux alias 命令别名。创建命令的快捷方式，让长命令变短、常用命令更便捷。每次终端会话重启后失效，需写入配置文件永久保存。适用于简化 Git 命令、设置编译选项、创建常用操作快捷键。",
  "commands": [
    {
      "dirPath": "/Linux alias/",
      "name": "alias 设置别名",
      "keyword": "alias 别名",
      "description": "创建命令别名。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "alias %{名称}%='%{命令}%'",
        "extensions": [
          {
            "name": "创建简单别名",
            "description": "为常用命令创建短别名",
            "params": {
              "名称": {
                "example": "ll",
                "notes": "别名名称"
              },
              "命令": {
                "example": "ls -la",
                "notes": "原命令"
              }
            },
            "cmd": "alias %{名称}%='%{命令}%'"
          },
          {
            "name": "创建带参数的别名",
            "description": "创建带默认参数的别名，如自动加git分支",
            "params": {
              "名称": {
                "example": "gitst",
                "notes": "别名"
              },
              "命令": {
                "example": "git status",
                "notes": "原命令带参数"
              }
            },
            "cmd": "alias %{名称}%='%{命令}%'"
          },
          {
            "name": "查看所有别名",
            "description": "列出当前会话中所有已定义的别名",
            "params": {},
            "cmd": "alias"
          },
          {
            "name": "删除别名",
            "description": "移除一个已定义的别名",
            "params": {
              "名称": {
                "example": "ll",
                "notes": "要删除的别名"
              }
            },
            "cmd": "unalias %{名称}%"
          },
          {
            "name": "永久保存别名",
            "description": "将别名写入bashrc，每次启动自动加载",
            "params": {
              "名称": {
                "example": "ll",
                "notes": "别名"
              },
              "命令": {
                "example": "ls -la",
                "notes": "命令"
              },
              "配置路径": {
                "example": "~/.bashrc",
                "notes": "配置文件"
              }
            },
            "cmd": "echo \"alias %{名称}%='%{命令}%'\" >> %{配置路径}%"
          },
          {
            "name": "创建别名覆盖命令",
            "description": "用别名覆盖原有的命令，如安全删除确认",
            "params": {
              "名称": {
                "example": "rm",
                "notes": "别名名"
              },
              "命令": {
                "example": "rm -i",
                "notes": "带确认的命令"
              }
            },
            "cmd": "alias %{名称}%='%{命令}%'"
          },
          {
            "name": "创建递进别名",
            "description": "别名引用另一个别名，形成递进",
            "params": {
              "名称": {
                "example": "la",
                "notes": "别名"
              },
              "命令": {
                "example": "ls -A",
                "notes": "命令"
              }
            },
            "cmd": "alias %{名称}%='%{命令}%'"
          },
          {
            "name": "查看特定别名",
            "description": "查看单个别名的定义",
            "params": {
              "名称": {
                "example": "ll",
                "notes": "别名名称"
              }
            },
            "cmd": "alias %{名称}%"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "别名",
            "example": "ll",
            "notes": "必填"
          },
          "命令": {
            "type": "string",
            "required": true,
            "description": "命令",
            "example": "ls -la",
            "notes": "必填"
          }
        }
      }
    }
  ]
}