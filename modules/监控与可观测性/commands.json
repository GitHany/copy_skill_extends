                "example": "dashboard-id",
                "notes": "可选"
              }
            },
            "keyword": "kibana 导出仪表板"
          },
          {
            "name": "导入仪表板",
            "cmd": "curl -X POST \"http://localhost:5601/api/saved_objects/_import\" -H \"kbn-xsrf: reporting\" --form file=@dashboard.ndjson",
            "params": {},
            "keyword": "kibana 导入仪表板"
          },
          {
            "name": "查看 Spaces",
            "cmd": "curl -X GET \"http://localhost:5601/api/spaces/space\" -H \"kbn-xsrf: reporting\"",
            "params": {},
            "keyword": "kibana spaces"
          },
          {
            "name": "创建 Space",
            "cmd": "curl -X POST \"http://localhost:5601/api/spaces/space\" -H \"kbn-xsrf: reporting\" -H \"Content-Type: application/json\" -d '{\"id\":\"%{空间ID}\",\"name\":\"%{空间名称}%\"}'",
            "params": {
              "空间ID": {
                "type": "string",
                "required": true,
                "description": "空间唯一标识",
                "example": "prod",
                "notes": "可选"
              },
              "空间名称": {
                "type": "string",
                "required": true,
                "description": "空间显示名称",
                "example": "生产环境",
                "notes": "可选"
              }
            },
            "keyword": "kibana 创建 space"
          }
        ],
        "params": {}
      }
    },
    {
