{
  "module": "监控与可观测性",
  "version": "1.0",
  "description": "监控与可观测性命令模块 - 涵盖日志、指标、追踪、告警和基础设施监控",
  "commands": [
    {
      "dirPath": "/监控与可观测性/",
      "name": "Elasticsearch 日志搜索",
      "keyword": "elk elasticsearch 日志搜索",
      "description": "通过 Elasticsearch REST API 搜索和分析日志",
      "data": {
        "cmd": "curl -X POST \"http://localhost:9200/%{索引}%/_search\" -H \"Content-Type: application/json\" -d '%{查询JSON}%'",
        "extensions": [
          {
            "name": "搜索错误日志",
            "cmd": "curl -X POST \"http://localhost:9200/logs-*/_search\" -H \"Content-Type: application/json\" -d '{\"query\":{\"match\":{\"message\":\"ERROR\"}}}'",
            "params": {},
            "keyword": "ES 搜索 ERROR 日志"
          },
          {
            "name": "时间范围查询",
            "cmd": "curl -X POST \"http://localhost:9200/logs-*/_search\" -H \"Content-Type: application/json\" -d '{\"query\":{\"range\":{\"@timestamp\":{\"gte\":\"now-1h\",\"lte\":\"now\"}}},\"sort\":[{\"@timestamp\":\"desc\"}]}'",
            "params": {},
            "keyword": "ES 时间范围 日志"
          },
          {
            "name": "聚合错误统计",
            "cmd": "curl -X POST \"http://localhost:9200/logs-*/_search\" -H \"Content-Type: application/json\" -d '{\"aggs\":{\"error_count\":{\"filter\":{\"match\":{\"message\":\"error\"}},\"aggs\":{\"by_level\":{\"terms\":{\"field\":\"level.keyword\"}}}}}'",
            "params": {},
            "keyword": "ES 聚合统计"
          },
          {
            "name": "集群健康状态",
            "cmd": "curl -X GET \"http://localhost:9200/_cluster/health?pretty\"",
            "params": {},
            "keyword": "ES 集群健康"
          },
          {
            "name": "查看节点状态",
            "cmd": "curl -X GET \"http://localhost:9200/_cat/nodes?v\"",
            "params": {},
            "keyword": "ES 节点列表"
          },
          {
            "name": "查看所有索引",
            "cmd": "curl -X GET \"http://localhost:9200/_cat/indices?v\"",
            "params": {},
            "keyword": "ES 索引列表"
          }
        ],
        "params": {
          "索引": {
            "type": "string",
            "required": false,
            "description": "索引名",
            "example": "logs-*",
            "notes": "支持通配符"
          },
          "查询JSON": {
            "type": "string",
            "required": false,
            "description": "查询 JSON",
            "example": "{\"query\":{\"match_all\":{}}}",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/监控与可观测性/",
      "name": "Logstash 管道管理",
      "keyword": "logstash 管道 配置",
      "description": "Logstash 管道配置测试、启动和管理。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "logstash -t -f %{配置文件}%",
        "extensions": [
          {
            "name": "测试 Logstash 配置",
            "cmd": "logstash -t -f /etc/logstash/conf.d/pipeline.conf",
            "params": {},
            "keyword": "logstash 测试配置"
          },
          {
            "name": "后台启动 Logstash",
            "cmd": "nohup /usr/share/logstash/bin/logstash -f /etc/logstash/conf.d/pipeline.conf &",
            "params": {},
            "keyword": "logstash 后台启动"
          },
          {
            "name": "查看 Logstash 状态",
            "cmd": "curl -X GET \"localhost:9600/_node/stats\"",
            "params": {},
            "keyword": "logstash 状态 API"
          },
          {
            "name": "查看 Logstash 节点",
            "cmd": "curl -X GET \"localhost:9600/_node?pretty\"",
            "params": {},
            "keyword": "logstash 节点信息"
          },
          {
            "name": "停止 Logstash",
            "cmd": "pkill -f logstash",
            "params": {},
            "keyword": "logstash 停止"
          },
          {
            "name": "监控 Logstash 日志",
            "cmd": "tail -f /var/log/logstash/logstash-plain.log",
            "params": {},
            "keyword": "logstash 日志"
          }
        ],
        "params": {
          "配置文件": {
            "type": "string",
            "required": false,
            "description": "配置文件路径",
            "example": "/etc/logstash/conf.d/pipeline.conf",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/监控与可观测性/",
      "name": "Kibana API 操作",
      "keyword": "kibana api dashboard",
      "description": "Kibana REST API 操作 - 仪表板管理、状态检查",
      "data": {
        "cmd": "curl -X GET \"http://localhost:5601/api/status\"",
        "extensions": [
          {
            "name": "Kibana 健康检查",
            "cmd": "curl -X GET \"http://localhost:5601/api/status\"",
            "params": {},
            "keyword": "kibana 健康检查"
          },
          {
            "name": "列出所有可视化",
            "cmd": "curl -X GET \"http://localhost:5601/api/saved_objects/visualization\" -H \"kbn-xsrf: reporting\"",
            "params": {},
            "keyword": "kibana 可视化列表"
          },
          {
            "name": "导出仪表板",
            "cmd": "curl -X POST \"http://localhost:5601/api/saved_objects/_export?type=dashboard\" -H \"kbn-xsrf: reporting\" -d '{\"objects\":[{\"type\":\"dashboard\",\"id\":\"%{仪表板ID}%\"}]}' > dashboard.ndjson",
            "params": {
              "仪表板ID": {
                "type": "string",
                "required": true,
