{
  "dirPath": "/DockerCompose-Advanced/",
  "name": "Docker Compose Advanced Patterns",
  "keyword": "docker-compose 网络 卷 多环境",
  "description": "Docker Compose 高级模式命令集合，涵盖多文件编排、自定义网络、数据卷管理、多环境部署、健康检查配置、服务编排与资源清理等进阶用法。",
  "commands": [
    {
      "name": "多文件编排",
      "keyword": "docker-compose -f",
      "description": "合并多个 Docker Compose 配置文件进行编排",
      "data": {
        "cmd": "docker-compose -f %{file1}% -f %{file2}% up -d",
        "params": [
          {
            "name": "file1",
            "type": "string",
            "default": "docker-compose.yml",
            "description": "基础配置文件路径",
            "example": "docker-compose.yml"
          },
          {
            "name": "file2",
            "type": "string",
            "default": "docker-compose.prod.yml",
            "description": "覆盖配置文件路径",
            "example": "docker-compose.prod.yml"
          }
        ],
        "extensions": [
          {
            "name": "三文件合并",
            "keyword": "docker-compose -f base -f app -f override",
            "description": "三个配置文件按顺序合并，后者覆盖前者",
            "cmd": "docker-compose -f %{file1}% -f %{file2}% -f %{file3}% up -d",
            "params": {
              "file1": {
                "type": "string",
                "required": false,
                "description": "基础配置文件路径",
                "example": "docker-compose.yml",
                "notes": ""
              },
              "file2": {
                "type": "string",
                "required": false,
                "description": "覆盖配置文件路径",
                "example": "docker-compose.prod.yml",
                "notes": ""
              },
              "file3": {
                "type": "string",
                "required": false,
                "description": "",
                "example": "",
                "notes": ""
              }
            }
          },
          {
            "name": "跨目录引用",
            "keyword": "docker-compose -f ../common/base.yml",
            "description": "引用上级目录的配置文件",
            "cmd": "docker-compose -f ../common/base.yml -f prod.yml up -d"
          },
          {
            "name": "指定 env 文件",
            "keyword": "docker-compose --env-file",
            "description": "指定环境变量文件路径",
            "cmd": "docker-compose --env-file %{env_file}% up -d",
            "params": {
              "env_file": {
                "type": "string",
                "required": false,
                "description": "",
                "example": "",
                "notes": ""
              }
            }
          },
          {
            "name": "查看合并配置",
            "keyword": "docker-compose config",
            "description": "验证并输出合并后的配置",
            "cmd": "docker-compose -f %{file1}% -f %{file2}% config",
            "params": {
              "file1": {
                "type": "string",
                "required": false,
                "description": "基础配置文件路径",
                "example": "docker-compose.yml",
                "notes": ""
              },
              "file2": {
                "type": "string",
                "required": false,
                "description": "覆盖配置文件路径",
                "example": "docker-compose.prod.yml",
                "notes": ""
              }
            }
          }
        ]
      }
    },
    {
      "name": "构建与部署",
      "keyword": "docker-compose build up",
      "description": "构建镜像并启动服务",
      "data": {
        "cmd": "docker-compose build%{no_cache}% %{service}% && docker-compose up%{detached}% %{service}%",
        "params": [
          {
            "name": "no_cache",
            "type": "flag",
            "default": "",
            "description": "--no-cache 禁用构建缓存",
            "example": "--no-cache"
          },
          {
            "name": "detached",
            "type": "flag",
            "default": "",
            "description": "-d 后台运行",
            "example": "-d"
          },
          {
            "name": "service",
            "type": "string",
            "default": "",
            "description": "指定服务名称（留空构建全部）",
            "example": "web"
          }
        ],
        "extensions": [
          {
            "name": "强制重建启动",
            "keyword": "docker-compose up --build",
            "description": "强制重新构建并启动",
            "cmd": "docker-compose up --build%{detached}%",
            "params": {
              "detached": {
                "type": "flag",
                "required": false,
                "description": "-d 后台运行",
                "example": "-d",
                "notes": ""
              }
            }
          },
          {
            "name": "并行构建",
            "keyword": "docker-compose build --parallel",
            "description": "并行构建多个服务镜像",
            "cmd": "docker-compose build --parallel%{service}%",
            "params": {
              "service": {
                "type": "string",
                "required": false,
                "description": "指定服务名称（留空构建全部）",
                "example": "web",
                "notes": ""
              }
            }
          },
          {
            "name": "构建时拉取最新",
            "keyword": "docker-compose build --pull",
            "description": "每次构建前拉取最新基础镜像",
            "cmd": "docker-compose build --pull%{service}%",
            "params": {
              "service": {
                "type": "string",
                "required": false,
                "description": "指定服务名称（留空构建全部）",
                "example": "web",
                "notes": ""
              }
            }
          }
        ]
      }
    },
