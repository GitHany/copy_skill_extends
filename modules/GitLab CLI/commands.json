{
  "module": "GitLab CLI",
  "version": "2.0",
  "description": "GitLab 命令行工具模块 - glab 是 GitLab 官方 CLI，用于管理项目、合并请求、问题、流水线、CI/CD 等。适用于自动化脚本、DevOps 流程、团队协作",
  "commands": [
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab auth login 登录认证",
      "keyword": "glab auth 登录",
      "description": "登录 GitLab 账户 - 通过 glab CLI 登录 GitLab，支持 GitLab.com 和自托管实例。登录后可执行项目、MR、Issue 等操作",
      "data": {
        "cmd": "glab auth login --hostname %{主机}%",
        "extensions": [
          {
            "name": "使用 Token 登录",
            "cmd": "glab auth login --token %{令牌}% --hostname %{主机}%",
            "params": {
              "令牌": {
                "type": "string",
                "required": true,
                "description": "GitLab Personal Access Token",
                "example": "glpat-xxx",
                "notes": "必填。在 GitLab Settings > Access Tokens 创建"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "GitLab 主机地址",
                "example": "gitlab.com",
                "notes": "必填"
              }
            },
            "keyword": "glab auth token"
          },
          {
            "name": "检查认证状态",
            "cmd": "glab auth status",
            "params": {},
            "keyword": "glab auth status"
          },
          {
            "name": "登录 GitLab.com",
            "cmd": "glab auth login",
            "params": {},
            "keyword": "glab auth gitlab.com"
          }
        ],
        "params": {
          "主机": {
            "type": "string",
            "required": false,
            "description": "GitLab 主机名",
            "example": "gitlab.com",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab repo create 创建仓库",
      "keyword": "glab repo 创建",
      "description": "创建新的 GitLab 仓库 - 在 GitLab 上创建新项目，支持设置描述、可见性（公开/内部/私有）",
      "data": {
        "cmd": "glab repo create %{项目名称}% --description %{描述}%",
        "extensions": [
          {
            "name": "创建私有仓库",
            "cmd": "glab repo create %{项目名称}% --private",
            "params": {
              "项目名称": {
                "type": "string",
                "required": true,
                "description": "项目名称",
                "example": "my-project",
                "notes": "必填"
              }
            },
            "keyword": "glab repo private"
          },
          {
            "name": "克隆已有仓库",
            "cmd": "glab repo clone %{项目路径}%",
            "params": {
              "项目路径": {
                "type": "string",
                "required": true,
                "description": "项目路径",
                "example": "username/project",
                "notes": "必填。格式：username/project 或 group/subgroup/project"
              }
            },
            "keyword": "glab repo clone"
          },
          {
            "name": "查看仓库信息",
            "cmd": "glab repo view",
            "params": {},
            "keyword": "glab repo view"
          }
        ],
        "params": {
          "项目名称": {
            "type": "string",
            "required": true,
            "description": "项目名称",
            "example": "my-project",
            "notes": "必填"
          },
          "描述": {
            "type": "string",
            "required": false,
            "description": "项目描述",
            "example": "My awesome project",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab mr create 创建合并请求",
      "keyword": "glab mr 创建",
      "description": "创建 Merge Request (合并请求) - 将分支代码合并到目标分支，是 GitLab 代码评审和工作流的核心功能",
      "data": {
        "cmd": "glab mr create --title %{标题}% --source-branch %{源分支}% --target-branch %{目标分支}%",
        "extensions": [
          {
            "name": "创建并分配 Reviewer",
            "cmd": "glab mr create --title %{标题}% --assignee @%{用户}%",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "MR 标题",
                "example": "Add new feature",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "被分配的 Reviewer 用户名",
                "example": "username",
                "notes": "必填"
              }
            },
            "keyword": "glab mr assign"
          },
          {
            "name": "创建带描述的 MR",
            "cmd": "glab mr create --title %{标题}% --description \"%{描述}%\" --source-branch %{源分支}%",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "MR 标题",
                "example": "Feature: User API",
                "notes": "必填"
              },
              "描述": {
                "type": "string",
                "required": true,
                "description": "MR 详细描述",
                "example": "实现用户管理 API",
                "notes": "必填"
              },
              "源分支": {
                "type": "string",
                "required": true,
                "description": "源分支",
                "example": "feature/user-api",
                "notes": "必填"
              }
            },
            "keyword": "glab mr describe"
          },
          {
            "name": "创建 Draft MR",
            "cmd": "glab mr create --title %{标题}% --source-branch %{源分支}% --draft",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "MR 标题",
                "example": "WIP: Feature",
                "notes": "必填"
              },
              "源分支": {
                "type": "string",
                "required": true,
                "description": "源分支",
                "example": "feature/wip",
                "notes": "必填"
              }
            },
            "keyword": "glab mr draft"
          }
        ],
        "params": {
          "标题": {
            "type": "string",
            "required": true,
            "description": "Merge Request 标题",
            "example": "Add login feature",
            "notes": "必填"
          },
          "源分支": {
            "type": "string",
            "required": false,
            "description": "源分支名",
            "example": "feature/login",
            "notes": "可选。默认为当前分支"
          },
          "目标分支": {
            "type": "string",
            "required": false,
            "description": "目标分支名",
            "example": "main",
            "notes": "可选。默认为仓库默认分支"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab mr list 列出合并请求",
      "keyword": "glab mr 列表",
      "description": "列出 Merge Request - 查看项目中符合筛选条件的 MR 列表，如按状态、作者、标签筛选",
      "data": {
        "cmd": "glab mr list",
        "extensions": [
          {
            "name": "按状态筛选",
            "cmd": "glab mr list --state %{状态}%",
            "params": {
              "状态": {
                "type": "string",
                "required": true,
                "description": "MR 状态",
                "example": "opened",
                "notes": "必填。opened/closed/merged/all"
              }
            },
            "keyword": "glab mr state"
          },
          {
            "name": "按标签筛选",
            "cmd": "glab mr list --label %{标签}%",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "标签名称",
                "example": "bug",
                "notes": "必填"
              }
            },
            "keyword": "glab mr label"
          },
          {
            "name": "查看我相关的 MR",
            "cmd": "glab mr list --author=@me",
            "params": {},
            "keyword": "glab mr mine"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab mr view 查看合并请求",
      "keyword": "glab mr 查看",
      "description": "查看 Merge Request 详情 - 显示 MR 的完整信息，包括描述、审查者、评论、流水线状态、变更文件列表",
      "data": {
        "cmd": "glab mr view %{编号}%",
        "extensions": [
          {
            "name": "显示 MR 变更统计",
            "cmd": "glab mr view %{编号}% --outputs=json | jq '.stats'",
            "params": {
              "编号": {
                "type": "string",
                "required": true,
                "description": "MR 编号",
                "example": "42",
                "notes": "必填"
              }
            },
            "keyword": "glab mr stats"
          }
        ],
        "params": {
          "编号": {
            "type": "string",
            "required": true,
            "description": "Merge Request 编号",
            "example": "42",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab mr merge 合并请求",
      "keyword": "glab mr 合并",
      "description": "合并 Merge Request - 将源分支合并到目标分支。需注意 MR 状态必须为 opened，且需有足够权限",
      "data": {
        "cmd": "glab mr merge %{编号}%",
        "extensions": [
          {
            "name": "合并前 Squash",
            "cmd": "glab mr merge %{编号}% --squash",
            "params": {
              "编号": {
                "type": "string",
                "required": true,
                "description": "MR 编号",
                "example": "42",
                "notes": "必填"
              }
            },
            "keyword": "glab mr squash"
          },
          {
            "name": "删除源分支",
            "cmd": "glab mr merge %{编号}% --remove-source-branch",
            "params": {
              "编号": {
                "type": "string",
                "required": true,
                "description": "MR 编号",
                "example": "42",
                "notes": "必填"
              }
            },
            "keyword": "glab mr remove source"
          }
        ],
        "params": {
          "编号": {
            "type": "string",
            "required": true,
            "description": "Merge Request 编号",
            "example": "42",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab issue create 创建议题",
      "keyword": "glab issue 创建",
      "description": "创建 GitLab Issue - 用于跟踪任务、Bug、功能请求等。Issue 是项目管理和团队协作的基本单位",
      "data": {
        "cmd": "glab issue create --title %{标题}% --description %{描述}%",
        "extensions": [
          {
            "name": "创建带标签的 Issue",
            "cmd": "glab issue create --title %{标题}% --labels %{标签}%",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "议题标题",
                "example": "Bug report",
                "notes": "必填"
              },
              "标签": {
                "type": "string",
                "required": true,
                "description": "标签列表（逗号分隔）",
                "example": "bug,urgent",
                "notes": "必填"
              }
            },
            "keyword": "glab issue labels"
          },
          {
            "name": "创建 Issue 并分配",
            "cmd": "glab issue create --title %{标题}% --assignee @%{用户}%",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "议题标题",
                "example": "Fix bug",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "被分配的用户",
                "example": "developer",
                "notes": "必填"
              }
            },
            "keyword": "glab issue assign"
          },
          {
            "name": "创建里程碑 Issue",
            "cmd": "glab issue create --title %{标题}% --milestone %{里程碑}%",
            "params": {
              "标题": {
                "type": "string",
                "required": true,
                "description": "议题标题",
                "example": "Complete v1.0",
                "notes": "必填"
              },
              "里程碑": {
                "type": "string",
                "required": true,
                "description": "里程碑标题",
                "example": "v1.0",
                "notes": "必填"
              }
            },
            "keyword": "glab issue milestone"
          }
        ],
        "params": {
          "标题": {
            "type": "string",
            "required": true,
            "description": "议题标题",
            "example": "Bug found",
            "notes": "必填"
          },
          "描述": {
            "type": "string",
            "required": false,
            "description": "议题详细描述",
            "example": "Detailed description",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab issue list 列出议题",
      "keyword": "glab issue 列表",
      "description": "列出所有 Issues - 查看项目中符合筛选条件的 Issue 列表",
      "data": {
        "cmd": "glab issue list",
        "extensions": [
          {
            "name": "按状态筛选",
            "cmd": "glab issue list --state %{状态}%",
            "params": {
              "状态": {
                "type": "string",
                "required": true,
                "description": "Issue 状态",
                "example": "opened",
                "notes": "必填"
              }
            },
            "keyword": "glab issue state"
          },
          {
            "name": "按标签筛选",
            "cmd": "glab issue list --label %{标签}%",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "标签",
                "example": "enhancement",
                "notes": "必填"
              }
            },
            "keyword": "glab issue by label"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab ci run 运行流水线",
      "keyword": "glab ci 运行",
      "description": "触发 CI 流水线 - 手动触发 GitLab CI/CD 流水线，用于测试、部署等场景",
      "data": {
        "cmd": "glab ci run --branch %{分支名}%",
        "extensions": [
          {
            "name": "运行最新流水线",
            "cmd": "glab ci run",
            "params": {},
            "keyword": "glab ci run latest"
          },
          {
            "name": "带变量运行",
            "cmd": "glab ci run --branch %{分支}% --var %{键}=%{值}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "分支名",
                "example": "main",
                "notes": "必填"
              },
              "键": {
                "type": "string",
                "required": true,
                "description": "变量名",
                "example": "ENV",
                "notes": "必填"
              },
              "值": {
                "type": "string",
                "required": true,
                "description": "变量值",
                "example": "production",
                "notes": "必填"
              }
            },
            "keyword": "glab ci run var"
          }
        ],
        "params": {
          "分支名": {
            "type": "string",
            "required": false,
            "description": "分支名称",
            "example": "main",
            "notes": "可选。默认为当前分支"
          }
        }
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab ci view 查看流水线",
      "keyword": "glab ci 查看",
      "description": "查看流水线状态 - 显示流水线的详细信息，包括各个 job 的状态、日志",
      "data": {
        "cmd": "glab ci view",
        "extensions": [
          {
            "name": "查看流水线作业日志",
            "cmd": "glab ci trace %{作业名}%",
            "params": {
              "作业名": {
                "type": "string",
                "required": true,
                "description": "作业名称",
                "example": "build",
                "notes": "必填"
              }
            },
            "keyword": "glab ci trace"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab ci list 列出流水线",
      "keyword": "glab ci 列表",
      "description": "列出最近流水线 - 查看项目的流水线历史记录。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "glab ci list",
        "extensions": [
          {
            "name": "按分支筛选",
            "cmd": "glab ci list --branch %{分支}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "分支名",
                "example": "main",
                "notes": "必填"
              }
            },
            "keyword": "glab ci list branch"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab pipeline status 查看状态",
      "keyword": "glab pipeline 状态",
      "description": "查看当前分支的流水线状态 - 快速查看正在运行或最近的流水线状态",
      "data": {
        "cmd": "glab pipeline status",
        "extensions": [
          {
            "name": "等待流水线完成",
            "cmd": "glab pipeline wait",
            "params": {},
            "keyword": "glab pipeline wait"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/GitLab CLI/",
      "name": "glab release create 创建发布",
      "keyword": "glab release 创建",
      "description": "创建 GitLab Release - 在项目中创建发布版本，通常配合标签（tag）使用。Release 可以包含发布说明和附件",
      "data": {
        "cmd": "glab release create %{标签名}% --name %{标题}% --notes %{描述}%",
        "extensions": [
          {
            "name": "从文件读取发布说明",
            "cmd": "glab release create %{标签}% --name %{标题}% --notes-from-file %{文件}%",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "发布标签",
                "example": "v1.0.0",
                "notes": "必填"
              },
              "标题": {
                "type": "string",
                "required": true,
                "description": "发布标题",
                "example": "Version 1.0.0",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "发布说明文件",
                "example": "CHANGELOG.md",
                "notes": "必填"
              }
            },
            "keyword": "glab release notes file"
          },
          {
            "name": "列出所有 Release",
            "cmd": "glab release list",
            "params": {},
            "keyword": "glab release list"
          },
          {
            "name": "下载 Release 附件",
            "cmd": "glab release download %{标签}%",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "发布标签",
                "example": "v1.0.0",
                "notes": "必填"
              }
            },
            "keyword": "glab release download"
          }
        ],
        "params": {
          "标签名": {
            "type": "string",
            "required": true,
            "description": "发布标签",
            "example": "v1.0.0",
            "notes": "必填。需先创建 git tag"
          },
          "标题": {
            "type": "string",
            "required": true,
            "description": "发布标题",
            "example": "Version 1.0.0",
            "notes": "必填"
          },
          "描述": {
            "type": "string",
            "required": false,
            "description": "发布说明",
            "example": "Release notes",
            "notes": "可选"
          }
        }
      }
    }
  ]
}