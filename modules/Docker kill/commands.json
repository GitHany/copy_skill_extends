{
  "module": "Docker kill",
  "version": "2.0",
  "description": "Docker 容器强制终止命令。向容器发送 SIGKILL 信号，立即终止运行中的容器。\n\n【与 docker stop 的区别】：\n- docker stop：发送 SIGTERM 信号，给容器 10 秒优雅退出时间，然后发送 SIGKILL\n- docker kill：直接发送 SIGKILL，无等待，立即终止\n\n【适用场景】：\n- 强制停止卡住、无响应的容器\n- 紧急停止失控或占用过多资源的进程\n- 容器无法正常停止时的最后手段\n- 清理处于 zombie 状态的容器\n\n【警告】：强制终止可能导致数据丢失（未写入磁盘的数据），仅在其他方式无法停止时使用。",
  "commands": [
    {
      "dirPath": "/Docker kill/",
      "name": "docker kill 终止",
      "keyword": "docker kill 终止",
      "description": "强制终止运行中的容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker kill %{容器}%",
        "extensions": [
          {
            "name": "docker kill 发送指定信号",
            "description": "向容器发送特定信号而非默认的 SIGKILL。可发送 SIGTERM、SIGINT、SIGUSR1 等。适用于让容器优雅处理退出信号。",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "myapp",
                "notes": "必填"
              },
              "信号": {
                "type": "string",
                "required": false,
                "description": "信号名称或编号",
                "example": "SIGTERM",
                "notes": "可选：SIGTERM(优雅终止), SIGINT(Ctrl+C), SIGUSR1(用户自定义)"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker kill 批量终止多个容器",
            "description": "同时终止多个容器。一次性清理多个无响应的容器。",
            "params": {
              "容器列表": {
                "type": "string",
                "required": true,
                "description": "多个容器名（空格分隔）",
                "example": "container1 container2 container3",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker kill --signal 自定义信号",
            "description": "使用完整信号名或信号编号发送。信号编号如 15 表示 SIGTERM，9 表示 SIGKILL。",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "webapp",
                "notes": "必填"
              },
              "信号": {
                "type": "string",
                "required": false,
                "description": "信号名称或编号",
                "example": "SIGHUP",
                "notes": "可选：SIGHUP(挂起), SIGTERM(终止), SIGKILL(强制杀死)"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker ps -q 批量终止已停止容器",
            "description": "结合 docker ps 查找并终止容器。先用 docker ps 找到目标容器，再执行 kill。",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker kill 清理失控容器",
            "description": "强制终止占用大量 CPU 或内存的容器。配合 docker stats 查看资源使用。",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "heavy-app",
                "notes": "必填"
              }
            },
            "cmd": ""
          },
          {
            "name": "docker kill 停止无响应服务",
            "description": "终止无法接收正常停止指令的容器。服务卡死无法 graceful shutdown 时使用。",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名或ID",
                "example": "stuck-service",
                "notes": "必填"
              }
            },
            "cmd": ""
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器名或ID",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}