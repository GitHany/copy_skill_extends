{
  "module": "Linux ulimit",
  "version": "2.0",
  "description": "Shell 资源限制管理，涵盖Linux ulimit的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux ulimit/",
      "name": "ulimit 设置限制",
      "keyword": "ulimit 限制",
      "description": "设置 shell 资源限制。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ulimit -%{选项}% %{值}%",
        "extensions": [],
        "params": {
          "选项": {
            "type": "string",
            "required": true,
            "description": "选项",
            "example": "n",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "值",
            "example": "1024",
            "notes": "必填"
          }
        }
      }
    }
  ]
}