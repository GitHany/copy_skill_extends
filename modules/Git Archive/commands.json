{
  "module": "Git Archive",
  "version": "2.0",
  "description": "Git Archive命令集合，涵盖Git Archive的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Git Archive/",
      "name": "git archive 创建归档",
      "keyword": "git archive 归档",
      "description": "创建归档文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git archive --format=%{格式}% -o %{文件}% %{分支}%",
        "extensions": [],
        "params": {
          "格式": {
            "type": "string",
            "required": true,
            "description": "格式",
            "example": "zip",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "输出文件",
            "example": "release.zip",
            "notes": "必填"
          },
          "分支": {
            "type": "string",
            "required": true,
            "description": "分支",
            "example": "main",
            "notes": "必填"
          }
        }
      }
    }
  ]
}