{
  "module": "Git Revert",
  "version": "2.0",
  "description": "Git 撤销提交命令，涵盖Git Revert的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Git Revert/",
      "name": "git revert 撤销提交",
      "keyword": "git revert 撤销",
      "description": "创建一个新提交来撤销指定提交。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git revert %{提交}%",
        "extensions": [],
        "params": {
          "提交": {
            "type": "string",
            "required": true,
            "description": "提交哈希",
            "example": "abc123",
            "notes": "必填"
          }
        }
      }
    }
  ]
}