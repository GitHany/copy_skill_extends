                "notes": "必填"
              }
            },
            "keyword": "kubectl create multiple files"
          },
          {
            "name": "从 URL 创建资源",
            "cmd": "kubectl create -f %{URL}%",
            "params": {
              "URL": {
                "type": "string",
                "required": true,
                "description": "远程资源 URL    ",
                "example": "https://example.com/deploy.yaml",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create url"
          },
          {
            "name": "创建资源并等待超时",
            "cmd": "kubectl create -f %{文件}% --timeout=%{超时时间}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "YAML 文件路径     ",
                "example": "deployment.yaml",
                "notes": "必填"
              },
              "超时时间": {
                "type": "string",
                "required": false,
                "description": "超时时间         ",
                "example": "30s",
                "notes": "选填"
              }
            },
            "keyword": "kubectl create timeout"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "YAML 文件路径     ",
            "example": "deployment.yaml",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "kubectl apply 应用配置",
      "keyword": "kubectl apply 应用",
      "description": "应用或更新资源配置。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
