              }
            },
            "keyword": "kubectl create namespace labels"
          },
          {
            "name": "创建命名空间并指定资源配额",
            "cmd": "kubectl create namespace %{名称}% --quota=cpu=%{CPU}%,memory=%{内存}%",
            "params": {
              "名称": {
                "type": "string",
