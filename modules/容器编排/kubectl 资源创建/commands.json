              },
              "内存": {
                "type": "string",
                "required": false,
                "description": "内存配额           ",
                "example": "20Gi",
                "notes": "选填"
              }
            },
            "keyword": "kubectl create namespace quotas"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "命名空间名称     ",
            "example": "my-namespace",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "kubectl create 从文件创建",
      "keyword": "kubectl create file 创建",
      "description": "从 YAML/JSON 文件创建 Kubernetes 资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl create -f %{文件}%",
        "extensions": [
          {
            "name": "从目录批量创建",
            "cmd": "kubectl create -f %{目录}%/",
