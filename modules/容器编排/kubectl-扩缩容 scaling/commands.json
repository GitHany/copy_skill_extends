{
  "module": "容器编排/kubectl-扩缩容 scaling",
  "version": "2.0",
  "description": "Kubernetes 扩缩容，涵盖kubectl Scaling的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "kubectl scale 扩缩容",
      "keyword": "kubectl scale 扩缩容",
      "description": "调整副本数。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl scale deployment %{名称}% --replicas=%{数量}%",
        "extensions": [
          {
            "name": "扩容到指定副本数",
            "cmd": "kubectl scale deployment %{部署名}% --replicas=%{副本数}%",
            "params": {
              "部署名": {
                "type": "string",
                "required": true,
                "description": "Deployment名称",
                "example": "myapp",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "目标副本数",
                "example": "10",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale replicas"
          },
          {
            "name": "缩容到最小实例",
            "cmd": "kubectl scale deployment %{部署名}% --replicas=1",
            "params": {
              "部署名": {
                "type": "string",
                "required": true,
                "description": "Deployment名称",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale min"
          },
          {
            "name": "批量扩缩容多个资源",
            "cmd": "kubectl scale %{资源类型}% %{资源名}% --replicas=%{副本数}%",
            "params": {
              "资源类型": {
                "type": "string",
                "required": true,
                "description": "资源类型",
                "example": "deployment",
                "notes": "必填"
              },
              "资源名": {
                "type": "string",
                "required": true,
                "description": "资源名称",
                "example": "myapp",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "目标副本数",
                "example": "3",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale batch"
          },
          {
            "name": "查看当前副本数",
            "cmd": "kubectl get deployment %{部署名}% -o jsonpath='{.spec.replicas}'",
            "params": {
              "部署名": {
                "type": "string",
                "required": true,
                "description": "Deployment名称",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale current replicas"
          },
          {
            "name": "零副本缩容",
            "cmd": "kubectl scale deployment %{部署名}% --replicas=0",
            "params": {
              "部署名": {
                "type": "string",
                "required": true,
                "description": "Deployment名称",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale zero replicas"
          },
          {
            "name": "扩缩容StatefulSet",
            "cmd": "kubectl scale statefulset %{状态集名}% --replicas=%{副本数}%",
            "params": {
              "状态集名": {
                "type": "string",
                "required": true,
                "description": "StatefulSet名称",
                "example": "mystatefulset",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "目标副本数",
                "example": "3",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale statefulset"
          },
          {
            "name": "扩缩容ReplicaSet",
            "cmd": "kubectl scale replicaset %{副本集名}% --replicas=%{副本数}%",
            "params": {
              "副本集名": {
                "type": "string",
                "required": true,
                "description": "ReplicaSet名称",
                "example": "myreplicaset",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "目标副本数",
                "example": "5",
                "notes": "必填"
              }
            },
            "keyword": "kubectl scale replicaset"
          },
          {
            "name": "条件扩缩容",
            "cmd": "kubectl scale deployment %{部署名}% --replicas=%{副本数}% --current-replicas=%{当前副本}%",
            "params": {
              "部署名": {
                "type": "string",
                "required": true,
                "description": "Deployment名称",
                "example": "myapp",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "目标副本数",
                "example": "10",
                "notes": "必填"
              },
              "当前副本": {
                "type": "string",
                "required": true,
                "description": "当前副本数条件",
                "example": "3",
                "notes": "必填，只有当副本数匹配时才执行"
              }
            },
            "keyword": "kubectl scale conditional"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "Deployment 名",
            "example": "myapp",
            "notes": "必填"
          },
          "数量": {
            "type": "string",
            "required": true,
            "description": "副本数",
            "example": "5",
            "notes": "必填"
          }
        }
      }
    }
  ]
}