{
  "module": "容器编排/Docker-登录仓库 login",
  "version": "2.0",
  "description": "Docker 镜像仓库登录，涵盖Docker login的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "docker login 登录仓库",
      "keyword": "docker login 登录",
      "description": "登录 Docker 仓库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker login %{仓库}%",
        "extensions": [
          {
            "name": "登录默认仓库",
            "cmd": "docker login",
            "params": {},
            "keyword": "docker login default"
          },
          {
            "name": "使用用户名登录",
            "cmd": "docker login -u %{用户名}%",
            "params": {
              "用户名": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "admin",
                "notes": "必填"
              }
            },
            "keyword": "docker login username"
          },
          {
            "name": "交互式密码登录",
            "cmd": "docker login -p %{密码}% %{仓库}%",
            "params": {
              "密码": {
                "type": "string",
                "required": true,
                "description": "密码",
                "example": "password123",
                "notes": "必填"
              },
              "仓库": {
                "type": "string",
                "required": false,
                "description": "仓库地址",
                "example": "docker.io",
                "notes": "可选"
              }
            },
            "keyword": "docker login password"
          },
          {
            "name": "登录阿里云仓库",
            "cmd": "docker login --username %{用户名}% registry.cn-hangzhou.aliyuncs.com",
            "params": {
              "用户名": {
                "type": "string",
                "required": true,
                "description": "阿里云用户名",
                "example": "admin",
                "notes": "必填"
              }
            },
            "keyword": "docker login aliyun"
          }
        ],
        "params": {
          "仓库": {
            "type": "string",
            "required": true,
            "description": "仓库地址",
            "example": "docker.io",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "docker logout 登出",
      "keyword": "docker logout 登出",
      "description": "登出 Docker 仓库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker logout %{仓库}%",
        "extensions": [
          {
            "name": "登出默认仓库",
            "cmd": "docker logout",
            "params": {},
            "keyword": "docker logout default"
          },
          {
            "name": "登出指定仓库",
            "cmd": "docker logout %{仓库}%",
            "params": {
              "仓库": {
                "type": "string",
                "required": true,
                "description": "仓库地址",
                "example": "docker.io",
                "notes": "必填"
              }
            },
            "keyword": "docker logout specific"
          },
          {
            "name": "登出阿里云仓库",
            "cmd": "docker logout registry.cn-hangzhou.aliyuncs.com",
            "params": {},
            "keyword": "docker logout aliyun"
          },
          {
            "name": "登出所有已登录仓库",
            "cmd": "docker logout --all",
            "params": {},
            "keyword": "docker logout all"
          }
        ],
        "params": {
          "仓库": {
            "type": "string",
            "required": true,
            "description": "仓库地址",
            "example": "docker.io",
            "notes": "必填"
          }
        }
      }
    }
  ]
}