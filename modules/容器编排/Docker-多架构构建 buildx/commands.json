    {
      "name": "docker buildx prune 清理缓存",
      "description": "清理 BuildKit 构建缓存，释放磁盘空间。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "params": {
        "清除全部": {
          "type": "boolean",
          "required": false,
          "description": "清除所有构建缓存",
          "example": "-a",
          "notes": "谨慎使用，会清除所有缓存"
        }
      },
      "keyword": "docker buildx prune",
      "dirPath": "/容器编排/",
      "data": {
        "cmd": "",
        "extensions": [
          {
            "name": "清除所有构建缓存",
            "cmd": "docker buildx prune --all",
            "params": {},
            "keyword": "docker buildx prune --all"
          },
          {
            "name": "清除特定构建器缓存",
            "cmd": "docker buildx prune --builder mybuilder",
            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "目标构建器名称",
                "example": "mybuilder",
                "notes": "必填"
              }
            },
            "keyword": "docker buildx prune --builder"
          },
          {
            "name": "清除指定时间前的缓存",
            "cmd": "docker buildx prune --filter \"until=24h\"",
            "params": {
              "时间": {
                "type": "string",
                "required": true,
                "description": "清除此时间之前的缓存",
                "example": "24h",
                "notes": "必填，格式如24h、72h、168h"
              }
            },
            "keyword": "docker buildx prune --filter"
          },
          {
            "name": "显示清除空间详情",
            "cmd": "docker buildx prune --verbose",
            "params": {},
            "keyword": "docker buildx prune --verbose"
          }
        ],
        "params": {}
      }
    },
