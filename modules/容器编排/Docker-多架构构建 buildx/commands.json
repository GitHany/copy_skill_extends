    {
      "name": "docker buildx build 多平台构建",
      "description": "使用 buildx 进行多平台 Docker 镜像构建，支持交叉编译和高级构建选项。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "params": {
        "镜像名称": {
          "type": "string",
