{
  "module": "容器编排/Docker-多架构构建 buildx",
  "version": "2.0",
  "description": "Docker buildx命令集合，涵盖Docker buildx的常用操作和最佳实践",
  "commands": [
    {
      "name": "docker buildx ls 列出构建器",
      "description": "列出所有可用的 buildx 构建器及其状态。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "params": {},
      "keyword": "docker buildx ls",
      "dirPath": "/容器编排/",
      "data": {
        "cmd": "",
        "extensions": [
          {
            "name": "显示所有构建器详细信息",
            "cmd": "docker buildx ls --all",
            "params": {},
            "keyword": "docker buildx ls --all"
          },
          {
            "name": "只显示活跃的构建器",
            "cmd": "docker buildx ls --filter type=active",
            "params": {},
            "keyword": "docker buildx ls --filter"
          },
          {
            "name": "格式化输出构建器列表",
            "cmd": "docker buildx ls --format \"table {{.Name}}\\t{{.Driver}}\\t{{.Status}}\"",
            "params": {},
            "keyword": "docker buildx ls --format"
          },
          {
            "name": "显示详细驱动信息",
            "cmd": "docker buildx ls -v",
            "params": {},
            "keyword": "docker buildx ls -v"
          }
        ],
        "params": {}
      }
    },
    {
      "name": "docker buildx create 创建构建器",
      "description": "创建新的 buildx 构建器实例，支持 docker-container、kubernetes 等驱动",
      "params": {
        "构建器名": {
          "type": "string",
          "required": false,
          "description": "构建器名称",
          "example": "mybuilder",
          "notes": "可选，不指定则自动生成"
        },
        "驱动类型": {
          "type": "string",
          "required": false,
          "description": "构建器驱动类型",
          "example": "docker-container",
          "notes": "可选：docker-container、kubernetes、remote"
        }
      },
      "keyword": "docker buildx create",
      "dirPath": "/容器编排/",
      "data": {
        "cmd": "",
        "extensions": [
          {
            "name": "创建指定驱动的构建器",
            "cmd": "docker buildx create --name mybuilder --driver docker-container",
            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "要创建的构建器名称",
                "example": "mybuilder",
                "notes": "必填"
              },
              "驱动类型": {
                "type": "string",
                "required": true,
                "description": "构建器驱动类型",
                "example": "docker-container",
                "notes": "必填：docker-container、kubernetes、remote"
              }
            },
            "keyword": "docker buildx create --driver"
          },
          {
            "name": "创建构建器并设为默认",
            "cmd": "docker buildx create --name mybuilder --default",
            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "要创建的构建器名称",
                "example": "mybuilder",
                "notes": "必填"
              }
            },
            "keyword": "docker buildx create --default"
          },
          {
            "name": "使用现有节点创建构建器",
            "cmd": "docker buildx create --node mynode --name mybuilder existing",
            "params": {
              "节点名": {
                "type": "string",
                "required": true,
                "description": "节点名称",
                "example": "mynode",
                "notes": "必填"
              },
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "要创建的构建器名称",
                "example": "mybuilder",
                "notes": "必填"
              }
            },
            "keyword": "docker buildx create --node"
          },
          {
            "name": "创建远程构建器",
            "cmd": "docker buildx create --driver remote --name remote-builder tcp://remote:2375",
            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "远程构建器名称",
                "example": "remote-builder",
                "notes": "必填"
              },
              "远程地址": {
                "type": "string",
                "required": true,
                "description": "远程 BuildKit 地址",
                "example": "tcp://remote:2375",
                "notes": "必填"
              }
            },
            "keyword": "docker buildx create remote"
          },
          {
            "name": "创建 Kubernetes 构建器",
            "cmd": "docker buildx create --driver kubernetes --name k8s-builder --platform linux/amd64,linux/arm64",
            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "Kubernetes构建器名称",
                "example": "k8s-builder",
                "notes": "必填"
              },
              "平台": {
                "type": "string",
                "required": false,
                "description": "支持的平台",
                "example": "linux/amd64,linux/arm64",
                "notes": "可选"
              }
            },
            "keyword": "docker buildx create kubernetes"
          }
        ],
        "params": {}
      }
    },
