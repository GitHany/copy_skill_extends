            "params": {
              "构建器名": {
                "type": "string",
                "required": true,
                "description": "目标构建器名称",
                "example": "mybuilder",
                "notes": "必填"
              }
            },
            "keyword": "docker buildx use --default"
          },
          {
            "name": "切换到默认构建器",
