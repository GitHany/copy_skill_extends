{
  "module": "容器编排/Kubernetes ConfigMap 与 Secret",
  "version": "2.0",
  "description": "Kubernetes ConfigMap 与 Secret命令集合",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "kubectl create configmap 创建 ConfigMap",
      "keyword": "kubectl configmap 创建",
      "description": "创建 ConfigMap。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl create configmap %{名称}% --from-literal=%{键}%=%{值}%",
        "extensions": [
          {
            "name": "从文件创建",
            "cmd": "kubectl create configmap %{名称}% --from-file=%{文件}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "ConfigMap 名    ",
                "example": "app-config",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件路径           ",
                "example": "config.properties",
                "notes": "必填"
              }
            },
            "keyword": "kubectl configmap file"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "ConfigMap 名称   ",
            "example": "my-config",
            "notes": "必填"
          },
          "键": {
            "type": "string",
            "required": true,
            "description": "键名             ",
            "example": "DB_HOST",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "值              ",
            "example": "localhost",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "kubectl create secret 创建 Secret",
      "keyword": "kubectl secret 创建",
      "description": "创建 Secret。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl create secret generic %{名称}% --from-literal=%{键}%=%{值}%",
        "extensions": [
          {
            "name": "从文件创建",
            "cmd": "kubectl create secret tls %{名称}% --cert=%{证书}% --key=%{密钥}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Secret 名       ",
                "example": "tls-cert",
                "notes": "必填"
              },
              "证书": {
                "type": "string",
                "required": true,
                "description": "证书文件           ",
                "example": "cert.pem",
                "notes": "必填"
              },
              "密钥": {
                "type": "string",
                "required": true,
                "description": "密钥文件           ",
                "example": "key.pem",
                "notes": "必填"
              }
            },
            "keyword": "kubectl secret tls"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "Secret 名称      ",
            "example": "my-secret",
            "notes": "必填"
          },
          "键": {
            "type": "string",
            "required": true,
            "description": "键名             ",
            "example": "password",
            "notes": "必填"
          },
          "值": {
            "type": "string",
            "required": true,
            "description": "值              ",
            "example": "secret123",
            "notes": "必填"
          }
        }
      }
    }
  ]
}