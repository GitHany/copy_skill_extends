{
  "module": "容器编排/Docker-删除容器 rm",
  "version": "2.0",
  "description": "Docker 容器删除命令。删除一个或多个已停止的容器，清除不需要的容器以释放资源。与 docker stop 不同，rm 是彻底删除容器及其配置。常见场景：清理测试容器、删除已完成的临时容器、清理开发环境。",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "docker rm 删除容器",
      "keyword": "docker rm 删除",
      "description": "删除已停止的容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker rm %{容器}%",
        "extensions": [
          {
            "name": "docker rm -f 强制删除运行中容器",
            "description": "强制删除正在运行的容器                   ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "cmd": "docker rm %{容器}%"
          },
          {
            "name": "docker rm 批量删除",
            "description": "同时删除多个容器                      ",
            "params": {
              "容器列表": {
                "type": "string",
                "required": true,
                "description": "多个容器名（空格分隔）    ",
                "example": "container1 container2",
                "notes": "必填"
              }
            },
            "cmd": "docker rm %{容器}%"
          },
          {
            "name": "docker rm -v 删除关联卷",
            "description": "删除容器及其关联的数据卷                  ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "db",
                "notes": "必填"
              }
            },
            "cmd": "docker rm %{容器}%"
          },
          {
            "name": "docker rm --link 删除链接",
            "description": "删除容器时同时删除网络链接                 ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "webapp",
                "notes": "必填"
              }
            },
            "cmd": "docker rm %{容器}%"
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器             ",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}