            "cmd": "docker-compose down --rmi %{all_local}% %{volumes}%",
            "params": {
              "all_local": {
                "type": "string",
                "required": false,
                "description": "               ",
                "example": "",
                "notes": "可选"
              },
              "volumes": {
                "type": "flag",
                "required": false,
                "description": "-v 同时移除数据卷     ",
                "example": "-v",
                "notes": "可选"
              }
            }
          },
          {
            "name": "清除全部",
            "keyword": "docker-compose down -v --rmi all",
            "description": "停止服务、移除容器、数据卷、镜像              ",
            "cmd": "docker-compose down -v --rmi all",
            "params": {}
          }
        ]
