  "commands": [
    {
      "name": "docker-compose up",
      "keyword": "docker compose up",
      "description": "启动 Docker Compose 服务（前台或后台）。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker-compose up%{detached}% %{project_name}%",
        "params": {},
        "extensions": [
          {
            "name": "重建启动",
            "keyword": "docker-compose up --build",
            "description": "强制重新构建并启动服务                   ",
            "cmd": "docker-compose up --build%{detached}%",
            "params": {
              "detached": {
                "type": "flag",
                "required": false,
                "description": "-d 后台运行模式      ",
                "example": "-d",
                "notes": "可选"
              }
            }
          },
          {
            "name": "强制重建",
            "keyword": "docker-compose up --force-recreate",
            "description": "强制重新创建容器                      ",
            "cmd": "docker-compose up --force-recreate%{detached}%",
            "params": {
              "detached": {
                "type": "flag",
                "required": false,
                "description": "-d 后台运行模式      ",
                "example": "-d",
                "notes": "可选"
              }
            }
          },
          {
            "name": "指定文件",
            "keyword": "docker-compose -f",
            "description": "使用指定的 compose 文件              ",
            "cmd": "docker-compose -f %{file}% up%{detached}%",
            "params": {
              "file": {
                "type": "string",
                "required": false,
                "description": "               ",
                "example": "",
                "notes": "可选"
              },
              "detached": {
                "type": "flag",
                "required": false,
                "description": "-d 后台运行模式      ",
                "example": "-d",
                "notes": "可选"
              }
            }
          }
        ]
      },
      "dirPath": "/容器编排/"
    },
    {
