{
  "module": "容器编排/Docker-导出容器 export",
  "version": "2.0",
  "description": "Docker 容器导出导入，涵盖Docker export的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "docker export 导出容器",
      "keyword": "docker export 导出",
      "description": "导出容器为 tar 文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker export %{容器}% -o %{文件}%",
        "extensions": [
          {
            "name": "标准输出导出",
            "description": "使用 -o 或重定向到标准输出，配合管道或压缩",
            "cmd": "docker export %{容器}% | gzip > %{文件}%.gz"
          },
          {
            "name": "导出所有文件系统",
            "description": "导出容器完整文件系统快照",
            "cmd": "docker export -o %{文件}% %{容器}%"
          },
          {
            "name": "不包含日志",
            "description": "导出时不包含容器内已存在的日志数据",
            "cmd": "docker export %{容器}% -o %{文件}%"
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器             ",
            "example": "myapp",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "输出文件           ",
            "example": "container.tar",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "docker import 导入",
      "keyword": "docker import 导入",
      "description": "导入 tar 为镜像。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker import %{文件}% %{镜像}%",
        "extensions": [
          {
            "name": "导入并设置作者",
            "description": "使用 --change 应用 Dockerfile 命令并设置作者",
            "cmd": "docker import --change \"ENV DEBUG=false\" %{文件}% %{镜像}%"
          },
          {
            "name": "导入带变更说明",
            "description": "通过标准输入导入并添加变更元数据",
            "cmd": "cat %{文件}% | docker import - %{镜像}%:%{标签}%"
          },
          {
            "name": "导入并执行 cmd",
            "description": "导入时指定默认执行的命令",
            "cmd": "docker import --change \"CMD [\\\"/bin/sh\\\", \\\"-c\\\"]\" %{文件}% %{镜像}%"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件             ",
            "example": "container.tar",
            "notes": "必填"
          },
          "镜像": {
            "type": "string",
            "required": true,
            "description": "镜像名            ",
            "example": "myimage:latest",
            "notes": "必填"
          }
        }
      }
    }
  ]
}