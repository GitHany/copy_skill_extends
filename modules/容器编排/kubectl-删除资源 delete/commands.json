{
  "module": "容器编排/kubectl-删除资源 delete",
  "version": "2.0",
  "description": "kubectl 删除资源，涵盖kubectl delete的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "kubectl delete 删除资源",
      "keyword": "kubectl delete 删除",
      "description": "删除 Kubernetes 资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl delete %{类型}% %{名称}%",
        "extensions": [
          {
            "name": "强制删除",
            "cmd": "kubectl delete %{类型}% %{名称}% --grace-period=0",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "类型             ",
                "example": "pod",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "名称             ",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete force"
          },
          {
            "name": "删除全部",
            "cmd": "kubectl delete %{类型}% --all",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "类型             ",
                "example": "pods",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete all"
          },
          {
            "name": "级联删除",
            "cmd": "kubectl delete %{类型}% %{名称}% --cascade=%{级联类型}%",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "deployment",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "资源名称         ",
                "example": "myapp",
                "notes": "必填"
              },
              "级联类型": {
                "type": "string",
                "required": false,
                "description": "级联类型         ",
                "example": "foreground",
                "notes": "选填，可选值: foreground, background, orphan"
              }
            },
            "keyword": "kubectl delete cascade"
          },
          {
            "name": "忽略不存在",
            "cmd": "kubectl delete %{类型}% %{名称}% --ignore-not-found=true",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "pod",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "资源名称         ",
                "example": "my-pod",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete ignore-not-found"
          },
          {
            "name": "等待删除完成",
            "cmd": "kubectl delete %{类型}% %{名称}% --wait=true",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "deployment",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "资源名称         ",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete wait"
          },
          {
            "name": "按标签选择器删除",
            "cmd": "kubectl delete %{类型}% -l %{标签选择器}%",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "pods",
                "notes": "必填"
              },
              "标签选择器": {
                "type": "string",
                "required": true,
                "description": "标签选择器       ",
                "example": "app=myapp",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete label selector"
          },
          {
            "name": "删除指定命名空间的资源",
            "cmd": "kubectl delete %{类型}% %{名称}% -n %{命名空间}%",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "pod",
                "notes": "必填"
              },
              "名称": {
                "type": "string",
                "required": true,
                "description": "资源名称         ",
                "example": "my-pod",
                "notes": "必填"
              },
              "命名空间": {
                "type": "string",
                "required": false,
                "description": "命名空间         ",
                "example": "default",
                "notes": "选填"
              }
            },
            "keyword": "kubectl delete namespace"
          },
          {
            "name": "删除所有命名空间的资源",
            "cmd": "kubectl delete %{类型}% --all --all-namespaces",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "资源类型         ",
                "example": "pods",
                "notes": "必填"
              }
            },
            "keyword": "kubectl delete all-namespaces"
          }
        ],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "资源类型           ",
            "example": "deployment",
            "notes": "必填"
          },
          "名称": {
            "type": "string",
            "required": true,
            "description": "资源名称           ",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}