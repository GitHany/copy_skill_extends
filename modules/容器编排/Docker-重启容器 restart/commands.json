{
  "module": "容器编排/Docker-重启容器 restart",
  "version": "2.0",
  "description": "重启一个或多个 Docker 容器。相当于关闭再打开。开发中常用！当你修改了容器配置、需要让新代码生效、或者容器卡住了想重置状态时用。常见场景：代码更新后重启、应用异常恢复、定时重启释放内存。",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "docker restart 重启容器",
      "keyword": "docker restart 重启",
      "description": "重启容器让新配置生效（开发必备）。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker restart %{容器}%",
        "extensions": [
          {
            "name": "docker restart 批量重启多个容器",
            "description": "同时重启多个容器（空格分隔）                ",
            "params": {
              "容器列表": {
                "type": "string",
                "required": true,
                "description": "多个容器名（空格分隔）    ",
                "example": "container1 container2 container3",
                "notes": "必填"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart -t 设置停止超时",
            "description": "设置强制 kill 前的等待时间（默认 10 秒）     ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "必填"
              },
              "超时秒数": {
                "type": "string",
                "required": false,
                "description": "超时秒数           ",
                "example": "30",
                "notes": "可选：设为 0 表示立即停止"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 重启前优雅停止",
            "description": "先等容器完成当前请求再重启                 ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "webapp",
                "notes": "让已有连接处理完"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 查看重启状态",
            "description": "查看容器是否成功重启                    ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "检查运行状态和日志"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 查看重启次数",
            "description": "查看容器重启了多少次                    ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "多次重启说明有问题"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 重启后验证健康",
            "description": "确认容器重启后正常运行                   ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "检查端口和日志"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 查看重启日志",
            "description": "查看容器最近的启动/停止日志                ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "排查重启原因"
              }
            },
            "cmd": "docker restart %{容器}%"
          },
          {
            "name": "docker restart 自动定时重启",
            "description": "设置容器自动定时重启（用 cron 或 watchdog） ",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器名            ",
                "example": "myapp",
                "notes": "配合外部定时器使用"
              }
            },
            "cmd": "docker restart %{容器}%"
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器名或 ID        ",
            "example": "myapp",
            "notes": "必填"
          }
        }
      }
    }
  ]
}