{
  "module": "容器编排/Docker-删除镜像 rmi",
  "version": "2.0",
  "description": "Docker 镜像删除命令（Remove Images）。删除本地存储的一个或多个镜像，释放磁盘空间。注意：rmi 删除的是镜像而非容器，如果镜像正被容器使用则无法删除。入门提示：删除前可先用 docker images 查看本地有哪些镜像。新手常见错误：混淆 docker rm（删容器）和 docker rmi（删镜像）。",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "docker rmi 删除镜像",
      "keyword": "docker rmi 删除",
      "description": "删除本地镜像。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker rmi %{镜像}%",
        "extensions": [
          {
            "name": "docker rmi -f 强制删除镜像",
            "description": "强制删除正在被容器使用的镜像（谨慎使用，可能导致容器无法正常运行）",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名或ID（前三位即可）  ",
                "example": "nginx:latest",
                "notes": "必填：可输入镜像名、ID或标签"
              },
              "镜像列表": {
                "type": "string",
                "required": false,
                "description": "多个镜像名（用空格分隔）   ",
                "example": "nginx:latest ubuntu:20.04",
                "notes": "可选：同时删除多个镜像"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker rmi 批量删除镜像",
            "description": "同时删除多个镜像，释放更多磁盘空间             ",
            "params": {
              "镜像列表": {
                "type": "string",
                "required": true,
                "description": "多个镜像名（空格分隔）    ",
                "example": "image1:v1 image2:latest myapp:prod",
                "notes": "必填：建议先 docker images 确认要删除的镜像"
              },
              "强制删除": {
                "type": "string",
                "required": false,
                "description": "是否强制删除         ",
                "example": "是",
                "notes": "可选：加上 -f 强制删除"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker rmi --no-prune 保留未标记镜像",
            "description": "删除时不清理没有被任何标签引用的中间层镜像（适合构建场景） ",
            "params": {
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像名            ",
                "example": "myapp:build",
                "notes": "必填：通常用于清理旧版本构建镜像"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker image prune 清理 dangling 镜像",
            "description": "删除所有未被使用的悬空镜像（dangling images，没有标签且未被容器引用）",
            "params": {
              "是否确认": {
                "type": "string",
                "required": false,
                "description": "确认执行清理         ",
                "example": "是",
                "notes": "可选：不加 -f 会提示确认"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker image prune -a 清理所有未使用镜像",
            "description": "删除所有未被任何容器使用的镜像（谨慎使用，会清理历史版本） ",
            "params": {
              "是否确认": {
                "type": "string",
                "required": false,
                "description": "确认执行清理         ",
                "example": "是",
                "notes": "可选：会删除所有未使用的镜像，释放大量空间"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker rmi $(docker images -q) 批量删除所有本地镜像",
            "description": "删除本地所有镜像（危险操作，慎用）             ",
            "params": {
              "是否确认": {
                "type": "string",
                "required": false,
                "description": "必须确认才能执行       ",
                "example": "确认删除",
                "notes": "必填：此操作不可恢复"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          },
          {
            "name": "docker images 查看本地镜像",
            "description": "查看本地所有镜像（删除前常用此命令确认）          ",
            "params": {
              "过滤条件": {
                "type": "string",
                "required": false,
                "description": "按仓库或标签过滤       ",
                "example": "nginx",
                "notes": "可选：如 docker images ubuntu 过滤特定镜像"
              }
            },
            "cmd": "docker rmi %{镜像}%"
          }
        ],
        "params": {
          "镜像": {
            "type": "string",
            "required": true,
            "description": "镜像名或ID         ",
            "example": "nginx:latest",
            "notes": "必填"
          }
        }
      }
    }
  ]
}