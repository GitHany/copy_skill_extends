{
  "module": "容器编排/K8s-部署管理 Deployment",
  "version": "2.0",
  "description": "Kubernetes Deployment命令集合",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "kubectl create deployment 创建",
      "keyword": "kubectl deployment 创建",
      "description": "创建 Deployment。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl create deployment %{名称}% --image=%{镜像}%",
        "extensions": [
          {
            "name": "指定副本数",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}% --replicas=%{副本数}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx:latest",
                "notes": "必填"
              },
              "副本数": {
                "type": "string",
                "required": true,
                "description": "副本数量",
                "example": "3",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create deployment replicas"
          },
          {
            "name": "指定命名空间",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}% -n %{命名空间}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx:latest",
                "notes": "必填"
              },
              "命名空间": {
                "type": "string",
                "required": true,
                "description": "命名空间",
                "example": "default",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create deployment namespace"
          },
          {
            "name": "指定资源限制",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}% --limits=%{资源限制}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx:latest",
                "notes": "必填"
              },
              "资源限制": {
                "type": "string",
                "required": true,
                "description": "资源限制",
                "example": "cpu=500m,memory=128Mi",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create deployment limits"
          },
          {
            "name": "指定环境变量",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}% --env=%{环境变量}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx:latest",
                "notes": "必填"
              },
              "环境变量": {
                "type": "string",
                "required": true,
                "description": "环境变量",
                "example": "NODE_ENV=production",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create deployment env"
          },
          {
            "name": "指定端口",
            "cmd": "kubectl create deployment %{名称}% --image=%{镜像}% --port=%{端口}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              },
              "镜像": {
                "type": "string",
                "required": true,
                "description": "镜像",
                "example": "nginx:latest",
                "notes": "必填"
              },
              "端口": {
                "type": "string",
                "required": true,
                "description": "端口",
                "example": "8080",
                "notes": "必填"
              }
            },
            "keyword": "kubectl create deployment port"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "Deployment名",
            "example": "nginx",
            "notes": "必填"
          },
          "镜像": {
            "type": "string",
            "required": true,
            "description": "镜像",
            "example": "nginx:latest",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/容器编排/",
      "name": "kubectl rollout status 状态",
      "keyword": "kubectl rollout 状态",
      "description": "查看部署状态。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl rollout status deployment/%{名称}%",
        "extensions": [
          {
            "name": "监听变化",
            "cmd": "kubectl rollout status deployment/%{名称}% -w",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "kubectl rollout status watch"
          },
          {
            "name": "查看历史",
            "cmd": "kubectl rollout history deployment/%{名称}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "kubectl rollout history"
          },
          {
            "name": "暂停 rollout",
            "cmd": "kubectl rollout pause deployment/%{名称}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "kubectl rollout pause"
          },
          {
            "name": "恢复 rollout",
            "cmd": "kubectl rollout resume deployment/%{名称}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "kubectl rollout resume"
          },
          {
            "name": "回滚到上一版本",
            "cmd": "kubectl rollout undo deployment/%{名称}%",
            "params": {
              "名称": {
                "type": "string",
                "required": true,
                "description": "Deployment名",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "kubectl rollout undo"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "Deployment名",
            "example": "nginx",
            "notes": "必填"
          }
        }
      }
    }
  ]
}