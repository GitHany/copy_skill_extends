{
  "module": "容器编排/kubectl-集群信息 cluster-info",
  "version": "2.0",
  "description": "Display cluster control plane status - API Server, Etcd, Dashboard endpoints.",
  "commands": [
    {
      "dirPath": "/容器编排/",
      "name": "kubectl cluster-info",
      "keyword": "kubectl cluster-info status endpoint",
      "description": "View cluster components and access addresses",
      "data": {
        "cmd": "kubectl cluster-info",
        "extensions": [
          {
            "name": "Dump all info",
            "cmd": "kubectl cluster-info dump",
            "params": {},
            "keyword": "kubectl cluster-info dump"
          },
          {
            "name": "View component logs",
            "cmd": "kubectl cluster-info dump --all-centers | head -100",
            "params": {},
            "keyword": "kubectl cluster-info logs"
          },
          {
            "name": "Component status",
            "cmd": "kubectl get componentstatuses 2>/dev/null || kubectl get cs",
            "params": {},
            "keyword": "kubectl componentstatuses"
          },
          {
            "name": "Cluster version",
            "cmd": "kubectl version --short",
            "params": {},
            "keyword": "kubectl version short"
          },
          {
            "name": "API Server endpoints",
            "cmd": "kubectl get endpoints kubernetes",
            "params": {},
            "keyword": "kubectl endpoints kubernetes"
          },
          {
            "name": "Etcd health",
            "cmd": "kubectl get cs | grep -i etcd",
            "params": {},
            "keyword": "kubectl etcd health"
          },
          {
            "name": "Control plane nodes",
            "cmd": "kubectl get nodes -l node-role.kubernetes.io/control-plane",
            "params": {},
            "keyword": "kubectl control plane nodes"
          }
        ],
        "params": {}
      }
    }
  ]
}