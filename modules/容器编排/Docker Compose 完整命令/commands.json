{
  "module": "容器编排/Docker Compose 完整命令",
  "version": "2.0",
  "description": "Docker Compose 完整命令命令集合",
  "commands": [
    {
      "cmd": "docker compose up -d",
      "extensions": [
        {
          "name": "重新构建",
          "cmd": "docker compose up -d --build",
          "params": {},
          "keyword": "docker compose build"
        },
        {
          "name": "指定文件",
          "cmd": "docker compose -f %{文件}% up -d",
          "params": {
            "文件": {
              "type": "string",
              "required": true,
              "description": "Compose 文件",
              "example": "docker-compose.prod.yml",
              "notes": "必填"
            }
          },
          "keyword": "docker compose file"
        },
        {
          "name": "扩展服务",
          "cmd": "docker compose up -d --scale %{服务}% = %{数量}%",
          "params": {
            "服务": {
              "type": "string",
              "required": true,
              "description": "服务名",
              "example": "web",
              "notes": "必填"
            },
            "数量": {
              "type": "string",
              "required": true,
              "description": "实例数",
              "example": "3",
              "notes": "必填"
            }
          },
          "keyword": "docker compose scale"
        },
        {
          "name": "强制删除",
          "cmd": "docker compose down --rmi all -v",
          "params": {},
          "keyword": "docker compose down remove"
        },
        {
          "name": "查看帮助",
          "cmd": "docker compose up --help",
          "params": {},
          "keyword": "docker compose help"
        },
        {
          "name": "多文件组合",
          "cmd": "docker compose -f %{文件1}% -f %{文件2}% up -d",
          "params": {
            "文件1": {
              "type": "string",
              "required": true,
              "description": "第一个Compose文件",
              "example": "docker-compose.base.yml",
              "notes": "必填"
            },
            "文件2": {
              "type": "string",
              "required": true,
              "description": "第二个Compose文件",
              "example": "docker-compose.prod.yml",
              "notes": "必填"
            }
          },
          "keyword": "docker compose multiple files"
        },
        {
          "name": "移除孤立资源",
          "cmd": "docker compose up -d --remove-orphans",
          "params": {},
          "keyword": "docker compose remove orphans"
        },
        {
          "name": "无缓存构建",
          "cmd": "docker compose build --no-cache",
          "params": {},
          "keyword": "docker compose build no cache"
        },
        {
          "name": "容器内执行命令",
          "cmd": "docker compose exec %{服务}% %{命令}%",
          "params": {
            "服务": {
              "type": "string",
              "required": true,
              "description": "服务名称",
              "example": "web",
              "notes": "必填"
            },
            "命令": {
              "type": "string",
              "required": true,
              "description": "要执行的命令",
              "example": "ls -la",
              "notes": "必填"
            }
          },
          "keyword": "docker compose exec"
        },
        {
          "name": "查看服务依赖关系",
          "cmd": "docker compose ps --format %{格式}%",
          "params": {
            "格式": {
              "type": "string",
              "required": true,
              "description": "输出格式",
              "example": "table {{.Name}}\\t{{.Status}}",
              "notes": "必填"
            }
          },
          "keyword": "docker compose ps format"
        },
        {
          "name": "健康检查服务",
          "cmd": "docker compose ps --status %{状态}%",
          "params": {
            "状态": {
              "type": "string",
              "required": true,
              "description": "服务状态",
              "example": "running",
              "notes": "必填"
            }
          },
          "keyword": "docker compose ps status"
        },
        {
          "name": "强制重新创建容器",
          "cmd": "docker compose up -d --force-recreate",
          "params": {},
          "keyword": "docker compose force recreate"
        },
        {
          "name": "独立构建服务",
          "cmd": "docker compose build %{服务}%",
          "params": {
            "服务": {
              "type": "string",
              "required": false,
              "description": "服务名称",
              "example": "web",
              "notes": "可选"
            }
          },
          "keyword": "docker compose build service"
        }
      ],
      "params": {},
      "dirPath": "/容器编排/",
      "name": "Docker Compose 完整命令 命令",
      "keyword": "Docker Compose 完整命令 命令",
      "description": "Docker Compose 完整命令 命令的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    }
  ]
}