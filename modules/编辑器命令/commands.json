{
  "module": "编辑器命令/编辑器命令",
  "version": "1.0",
  "description": "开发编辑器与 IDE 命令集合，涵盖 Vim/Neovim、VSCode CLI、JetBrains、终端工具及代码质量工具",
  "commands": [
    {
      "dirPath": "/编辑器命令/",
      "name": "nvim 启动 Neovim",
      "keyword": "nvim neovim 启动",
      "description": "启动 Neovim 编辑器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "nvim %{文件名}%",
        "extensions": [
          {
            "name": "Neovim 极简模式",
            "cmd": "nvim --clean %{文件名}%",
            "params": {
              "文件名": {
                "type": "string",
                "required": false,
                "description": "要打开的文件路径       ",
                "example": "src/main.js",
                "notes": "可选"
              }
            },
            "keyword": "nvim 极简模式"
          },
          {
            "name": "Neovim 只读模式",
            "cmd": "nvim -R %{文件名}%",
            "params": {
              "文件名": {
                "type": "string",
                "required": false,
                "description": "要打开的文件路径       ",
                "example": "README.md",
                "notes": "可选"
              }
            },
            "keyword": "nvim 只读"
          },
          {
            "name": "显示版本",
            "cmd": "nvim --version",
            "params": {},
            "keyword": "nvim 版本"
          }
        ],
        "params": {
          "文件名": {
            "type": "string",
            "required": false,
            "description": "要打开的文件路径       ",
            "example": "src/app.js",
            "notes": "可选"
          }
        }
      }
    },
