    {
      "dirPath": "/编辑器命令/",
      "name": "Vim 搜索与替换",
      "keyword": "vim 搜索 替换",
      "description": "Vim/Neovim 搜索与替换命令。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "/%{字符串}%",
        "extensions": [
          {
            "name": "向上搜索",
            "cmd": "?%{字符串}%",
            "params": {
              "字符串": {
                "type": "string",
                "required": true,
                "description": "要搜索的字符串        ",
                "example": "function",
                "notes": "可选"
              }
            },
            "keyword": "vim 向上搜索"
          },
          {
            "name": "跳到下一个匹配",
            "cmd": "n",
            "params": {},
            "keyword": "vim 下一个匹配"
          },
          {
            "name": "跳到上一个匹配",
            "cmd": "N",
            "params": {},
            "keyword": "vim 上一个匹配"
          },
          {
            "name": "替换当前行第一个匹配",
            "cmd": ":s/%{旧字符串}%/%{新字符串}%/",
            "params": {
              "旧字符串": {
                "type": "string",
                "required": true,
                "description": "要被替换的字符串       ",
                "example": "foo",
                "notes": "可选"
              },
              "新字符串": {
                "type": "string",
                "required": true,
                "description": "替换后的字符串        ",
                "example": "bar",
                "notes": "可选"
              }
            },
            "keyword": "vim 替换当前行"
          },
          {
            "name": "替换当前行所有匹配",
            "cmd": ":s/%{旧字符串}%/%{新字符串}%/g",
            "params": {
              "旧字符串": {
                "type": "string",
                "required": true,
                "description": "要被替换的字符串       ",
                "example": "foo",
                "notes": "可选"
              },
              "新字符串": {
                "type": "string",
                "required": true,
                "description": "替换后的字符串        ",
                "example": "bar",
                "notes": "可选"
              }
            },
            "keyword": "vim 替换当前行全部"
          },
          {
            "name": "替换文件中所有匹配",
            "cmd": ":%s/%{旧字符串}%/%{新字符串}%/g",
            "params": {
              "旧字符串": {
                "type": "string",
                "required": true,
                "description": "要被替换的字符串       ",
                "example": "foo",
                "notes": "可选"
              },
              "新字符串": {
                "type": "string",
                "required": true,
                "description": "替换后的字符串        ",
                "example": "bar",
                "notes": "可选"
              }
            },
            "keyword": "vim 替换全部"
          },
          {
            "name": "替换文件所有匹配（逐个确认）",
            "cmd": ":%s/%{旧字符串}%/%{新字符串}%/gc",
            "params": {
              "旧字符串": {
                "type": "string",
                "required": true,
                "description": "要被替换的字符串       ",
                "example": "foo",
                "notes": "可选"
              },
              "新字符串": {
                "type": "string",
                "required": true,
                "description": "替换后的字符串        ",
                "example": "bar",
                "notes": "可选"
              }
            },
            "keyword": "vim 替换确认"
          }
        ],
        "params": {
          "字符串": {
            "type": "string",
            "required": true,
            "description": "要搜索的字符串        ",
            "example": "TODO",
            "notes": "常用"
          }
        }
      }
    },
