{
  "module": "Terraform",
  "version": "2.0",
  "description": "HashiCorp Terraform 基础设施即代码工具",
  "commands": [
    {
      "dirPath": "/Terraform/",
      "name": "terraform init 初始化",
      "keyword": "terraform init 初始化",
      "description": "初始化 Terraform 工作目录。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "terraform init",
        "extensions": [
          {
            "name": "指定后端",
            "cmd": "terraform init -backend-config=%{配置}%",
            "params": {
              "配置": {
                "type": "string",
                "required": true,
                "description": "后端配置",
                "example": "backend.hcl",
                "notes": "必填"
              }
            },
            "keyword": "terraform init backend"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/Terraform/",
      "name": "terraform plan 预览计划",
      "keyword": "terraform plan 计划",
      "description": "预览将要创建的变更。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "terraform plan",
        "extensions": [
          {
            "name": "输出到文件",
            "cmd": "terraform plan -out=%{文件}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "输出文件",
                "example": "plan.tfplan",
                "notes": "必填"
              }
            },
            "keyword": "terraform plan out"
          }
        ],
        "params": {}
      }
    },
    {
