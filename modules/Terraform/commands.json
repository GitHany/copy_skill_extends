      "data": {
        "cmd": "terraform apply",
        "extensions": [
          {
            "name": "自动批准",
            "cmd": "terraform apply -auto-approve",
            "params": {},
            "keyword": "terraform apply auto"
          },
          {
            "name": "应用计划文件",
            "cmd": "terraform apply %{计划文件}%",
            "params": {
              "计划文件": {
                "type": "string",
                "required": true,
                "description": "计划文件",
                "example": "plan.tfplan",
                "notes": "必填"
              }
            },
            "keyword": "terraform apply plan"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/Terraform/",
      "name": "terraform destroy 销毁资源",
      "keyword": "terraform destroy 销毁",
      "description": "销毁 Terraform 管理的所有资源。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "terraform destroy",
        "extensions": [
          {
            "name": "自动批准销毁",
            "cmd": "terraform destroy -auto-approve",
            "params": {},
            "keyword": "terraform destroy auto"
          }
        ],
        "params": {}
      }
    },
    {
