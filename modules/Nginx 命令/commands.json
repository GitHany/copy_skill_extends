{
  "module": "Nginx 命令",
  "version": "2.0",
  "description": "Nginx Web 服务器命令，涵盖Nginx 命令的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Nginx 命令/",
      "name": "nginx 启动服务",
      "keyword": "nginx 启动",
      "description": "启动 Nginx。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "nginx",
        "extensions": [
          {
            "name": "测试配置",
            "cmd": "nginx -t",
            "params": {},
            "keyword": "nginx test"
          },
          {
            "name": "指定配置",
            "cmd": "nginx -c %{配置}%",
            "params": {
              "配置": {
                "type": "string",
                "required": true,
                "description": "配置文件",
                "example": "/etc/nginx/nginx.conf",
                "notes": "必填"
              }
            },
            "keyword": "nginx config"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/Nginx 命令/",
      "name": "nginx -s 信号控制",
      "keyword": "nginx 信号",
      "description": "发送信号到 Nginx。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "nginx -s %{信号}%",
        "extensions": [],
        "params": {
          "信号": {
            "type": "string",
            "required": true,
            "description": "信号类型",
            "example": "reload",
            "notes": "必填"
          }
        }
      }
    }
  ]
}