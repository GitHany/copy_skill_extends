{
  "module": "Docker exec",
  "version": "2.0",
  "description": "Docker 容器内命令执行，涵盖Docker exec的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Docker exec/",
      "name": "docker exec 执行命令",
      "keyword": "docker exec 执行",
      "description": "在容器中执行命令。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker exec %{容器}% %{命令}%",
        "extensions": [
          {
            "name": "交互式执行",
            "cmd": "docker exec -it %{容器}% /bin/bash",
            "params": {
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器",
                "example": "myapp",
                "notes": "必填"
              }
            },
            "keyword": "docker exec it"
          },
          {
            "name": "以用户执行",
            "cmd": "docker exec -u %{用户}% %{容器}% %{命令}%",
            "params": {
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户",
                "example": "root",
                "notes": "必填"
              },
              "容器": {
                "type": "string",
                "required": true,
                "description": "容器",
                "example": "myapp",
                "notes": "必填"
              },
              "命令": {
                "type": "string",
                "required": true,
                "description": "命令",
                "example": "ls",
                "notes": "必填"
              }
            },
            "keyword": "docker exec user"
          }
        ],
        "params": {
          "容器": {
            "type": "string",
            "required": true,
            "description": "容器名称或 ID",
            "example": "myapp",
            "notes": "必填"
          },
          "命令": {
            "type": "string",
            "required": true,
            "description": "要执行的命令",
            "example": "ls -la",
            "notes": "必填"
          }
        }
      }
    }
  ]
}