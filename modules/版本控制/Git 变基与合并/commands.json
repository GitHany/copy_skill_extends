            "信息": {
              "type": "string",
              "required": true,
              "description": "提交信息",
              "example": "Squash merge feature branch",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash message"
        },
        {
          "name": "中止squash",
          "cmd": "git merge --abort",
          "params": {},
          "keyword": "git merge squash abort"
        },
        {
          "name": "详细输出",
          "cmd": "git merge --squash %{分支}% --verbose",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash verbose"
        },
        {
          "name": "显示差异统计",
          "cmd": "git merge --squash %{分支}% --stat",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash stat"
        },
        {
          "name": "Squash后提交",
          "cmd": "git merge --squash %{分支}% && git commit",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash commit"
        },
        {
          "name": "Squash指定消息文件",
          "cmd": "git merge --squash %{分支}% -F %{文件}%",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            },
            "文件": {
              "type": "string",
              "required": true,
              "description": "消息文件路径",
              "example": "commit_msg.txt",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash file"
        },
        {
          "name": "Squash含签名",
          "cmd": "git merge --squash %{分支}% -S",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash sign"
        },
        {
          "name": "Squash后打标签",
          "cmd": "git merge --squash %{分支}% && git tag -a %{标签}% -m \"%{说明}%\"",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            },
            "标签": {
              "type": "string",
              "required": true,
              "description": "标签名",
              "example": "v1.0.0",
              "notes": "必填"
            },
            "说明": {
              "type": "string",
              "required": true,
              "description": "标签说明",
              "example": "Squash merge feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash tag"
        },
        {
          "name": "Squash合并前压缩",
          "cmd": "git merge --squash %{分支}% -s recursive -X ours",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash recursive ours"
        }
      ],
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    },
    {
      "name": "继续变基",
      "cmd": "git rebase --continue",
      "params": {},
      "keyword": "git rebase continue",
      "dirPath": "/版本控制/",
      "description": "继续变基的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "extensions": [
        {
          "name": "变基时执行测试",
          "cmd": "git rebase --exec \"%{命令}%\"",
          "params": {
            "命令": {
              "type": "string",
              "required": true,
              "description": "要执行的命令",
              "example": "npm test",
              "notes": "必填"
            }
          },
          "keyword": "git rebase exec test"
        },
        {
          "name": "变基时自动解决冲突",
          "cmd": "git rebase --strategy-option=theirs --continue",
          "params": {},
          "keyword": "git rebase strategy theirs"
        },
        {
          "name": "跳过当前提交",
          "cmd": "git rebase --skip",
          "params": {},
          "keyword": "git rebase skip"
        },
        {
          "name": "中止变基",
          "cmd": "git rebase --abort",
          "params": {},
          "keyword": "git rebase abort"
        },
        {
          "name": "交互式变基",
          "cmd": "git rebase -i %{基准}%",
          "params": {
            "基准": {
              "type": "string",
              "required": true,
              "description": "基准提交",
              "example": "HEAD~3",
              "notes": "必填"
            }
          },
          "keyword": "git rebase interactive"
        },
        {
          "name": "在提交前编辑",
          "cmd": "git rebase -i %{基准}% --wip",
          "params": {
            "基准": {
              "type": "string",
              "required": true,
              "description": "基准提交",
              "example": "HEAD~3",
              "notes": "必填"
            }
          },
          "keyword": "git rebase edit"
        },
        {
          "name": "自动变基",
          "cmd": "git rebase --autosquash %{基准}%",
          "params": {
            "基准": {
              "type": "string",
              "required": true,
              "description": "基准提交",
              "example": "HEAD~5",
              "notes": "必填"
            }
          },
          "keyword": "git rebase autosquash"
        },
