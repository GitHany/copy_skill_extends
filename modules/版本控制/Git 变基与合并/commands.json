              "type": "string",
              "required": true,
              "description": "旧的基准提交",
              "example": "HEAD~3",
              "notes": "必填"
            }
          },
          "keyword": "git rebase onto"
        },
        {
          "name": "变基时执行Shell",
          "cmd": "git rebase --exec %{命令}%",
          "params": {
            "命令": {
              "type": "string",
              "required": true,
              "description": "Shell命令",
              "example": "make test",
              "notes": "必填"
