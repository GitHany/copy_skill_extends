            "基准": {
              "type": "string",
              "required": true,
              "description": "基准提交",
              "example": "origin/main",
              "notes": "必填"
            }
          },
          "keyword": "git rebase push"
        },
        {
          "name": "变基运行前检查",
          "cmd": "git rebase --verify --continue",
          "params": {},
          "keyword": "git rebase verify"
        }
