          },
          "keyword": "git rebase exec shell"
        },
        {
          "name": "强制变基",
          "cmd": "git rebase --force-rebase %{基准}%",
          "params": {
            "基准": {
              "type": "string",
              "required": true,
              "description": "基准提交",
              "example": "origin/main",
              "notes": "必填"
            }
          },
          "keyword": "git rebase force"
        },
        {
          "name": "变基时保留提交者",
          "cmd": "git rebase --committer-date-is-author-date --continue",
