            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge squash autosquash"
        },
        {
          "name": "带提交信息",
          "cmd": "git merge --squash %{分支}% -m \"%{信息}%\"",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
