{
  "module": "版本控制/Git 变基与合并",
  "version": "2.0",
  "description": "Git 变基与合并命令集合，涵盖Git 变基与合并的常用操作和最佳实践",
  "commands": [
    {
      "name": "禁止快进",
      "cmd": "git merge --no-ff %{分支}%",
      "params": {
        "分支": {
          "type": "string",
          "required": true,
          "description": "分支名",
          "example": "feature",
          "notes": "必填"
        }
      },
      "keyword": "git merge noff",
      "dirPath": "/版本控制/",
      "description": "禁止快进的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "extensions": [
        {
          "name": "带提交信息",
          "cmd": "git merge --no-ff %{分支}% -m \"%{信息}%\"",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            },
            "信息": {
              "type": "string",
              "required": true,
              "description": "提交信息",
              "example": "Merge branch feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff message"
        },
        {
          "name": "仅获取远程更新",
          "cmd": "git merge --no-ff %{分支}% --no-commit",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "origin/main",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff no commit"
        },
        {
          "name": "创建合并提交含签名",
          "cmd": "git merge --no-ff %{分支}% -S",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff sign"
        },
        {
          "name": "强制合并日志",
          "cmd": "git merge --no-ff %{分支}% --log --edit",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff log edit"
        },
        {
          "name": "详细输出",
          "cmd": "git merge --no-ff %{分支}% --verbose",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff verbose"
        },
        {
          "name": "中止合并",
          "cmd": "git merge --abort",
          "params": {},
          "keyword": "git merge abort"
        },
        {
          "name": "保留提交记录",
          "cmd": "git merge --no-ff %{分支}% --log=%{数量}%",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            },
            "数量": {
              "type": "string",
              "required": false,
              "description": "显示的提交数",
              "example": "20",
              "notes": "选填"
            }
          },
          "keyword": "git merge noff log"
        },
        {
          "name": "签名验证",
          "cmd": "git merge --no-ff %{分支}% --verify-signatures",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff verify"
        },
        {
          "name": "三方合并",
          "cmd": "git merge --no-ff %{分支}% --no-edit",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff no edit"
        },
        {
          "name": "合并后清理分支",
          "cmd": "git merge --no-ff %{分支}% && git branch -d %{分支}%",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff delete branch"
        },
        {
          "name": "强制禁用fast-forward",
          "cmd": "git merge --no-ff --ff %{分支}%",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff no ff"
        },
        {
          "name": "Squash合并到当前分支",
          "cmd": "git merge --no-ff --squash %{分支}%",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "feature",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff squash"
        },
        {
          "name": "合并后立即推送",
          "cmd": "git merge --no-ff %{分支}% && git push",
          "params": {
            "分支": {
              "type": "string",
              "required": true,
              "description": "分支名",
              "example": "main",
              "notes": "必填"
            }
          },
          "keyword": "git merge noff push"
        }
      ],
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    },
    {
      "name": "squash 合并",
