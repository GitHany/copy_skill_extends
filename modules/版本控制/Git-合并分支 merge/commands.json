{
  "module": "版本控制/Git-合并分支 merge",
  "version": "2.0",
  "description": "Git 合并分支 — 将一个分支的更改合并到当前分支。用于功能完成后合并到主分支、协作时整合他人工作、或发布前整合开发分支。常见场景：功能开发完毕合并到 develop、分支开发完成后合并回 main、修复分支合并到 release 分支。",
  "commands": [
    {
      "dirPath": "/版本控制/",
      "name": "git merge 合并",
      "keyword": "git merge 合并",
      "description": "合并分支到当前分支。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git merge %{分支}%",
        "extensions": [
          {
            "name": "合并时创建提交",
            "cmd": "git merge --no-ff %{分支}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "要合并的分支         ",
                "example": "develop",
                "notes": "使用 --no-ff 强制创建合并提交，保留分支历史"
              }
            },
            "keyword": "git merge no fast forward"
          },
          {
            "name": "压缩合并",
            "cmd": "git merge --squash %{分支}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "要合并的分支         ",
                "example": "feature/login",
                "notes": "将分支的所有提交压缩为一个提交后再合并"
              }
            },
            "keyword": "git merge squash"
          },
          {
            "name": "中止合并",
            "cmd": "git merge --abort",
            "params": {},
            "keyword": "git merge abort 取消"
          },
          {
            "name": "查看合并状态",
            "cmd": "git merge --status",
            "params": {},
            "keyword": "git merge status 状态"
          },
          {
            "name": "合并并指定提交信息",
            "cmd": "git merge -m \"%{信息}%\" %{分支}%",
            "params": {
              "信息": {
                "type": "string",
                "required": true,
                "description": "合并提交的信息        ",
                "example": "Merge feature/login into develop",
                "notes": "用于自定义合并提交的说明"
              }
            },
            "keyword": "git merge message"
          },
          {
            "name": "仅预演不执行",
            "cmd": "git merge --no-commit --no-ff %{分支}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "目标分支           ",
                "example": "develop",
                "notes": "模拟合并效果，但不会真正执行"
              }
            },
            "keyword": "git merge dry run 预览"
          },
          {
            "name": "强制合并（允许无关历史）",
            "cmd": "git merge --allow-unrelated-histories %{分支}%",
            "params": {
              "分支": {
                "type": "string",
                "required": true,
                "description": "目标分支           ",
                "example": "main",
                "notes": "当两个仓库没有共同祖先时使用，如初始化子模块后"
              }
            },
            "keyword": "git merge unrelated histories"
          }
        ],
        "params": {
          "分支": {
            "type": "string",
            "required": true,
            "description": "目标分支名          ",
            "example": "develop",
            "notes": "必填，要合并到的分支"
          }
        }
      }
    }
  ]
}