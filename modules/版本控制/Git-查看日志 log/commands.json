{
  "module": "版本控制/Git-查看日志 log",
  "version": "3.0",
  "description": "Git log 用于查看项目的提交历史记录，了解谁在什么时候做了什么修改、为什么合并了某个分支。它是代码审查、追踪 Bug、生成变更日志的必备工具。支持多种展示格式，可以按作者、时间、提交信息过滤。常见场景：查看项目历史、了解代码变更、查找特定提交、生成变更日志、追踪 Bug 引入。",
  "commands": [
    {
      "dirPath": "/版本控制/",
      "name": "git log 日志",
      "keyword": "git log 日志",
      "description": "查看提交历史。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git log --oneline",
        "extensions": [
          {
            "name": "git log -n 限制条目数",
            "description": "只显示最近 N 条提交                   ",
            "params": {
              "数量": {
                "type": "string",
                "required": false,
                "description": "显示条数           ",
                "example": "10",
                "notes": "可选"
              }
            },
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --graph 图形化显示",
            "description": "以图形方式显示分支和合并历史                ",
            "params": {},
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --author 按作者过滤",
            "description": "只显示指定作者的提交                    ",
            "params": {
              "作者": {
                "type": "string",
                "required": true,
                "description": "作者名或邮箱         ",
                "example": "John",
                "notes": "必填"
              }
            },
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --since --until 时间范围",
            "description": "显示指定时间范围内的提交                  ",
            "params": {
              "开始时间": {
                "type": "string",
                "required": false,
                "description": "开始时间           ",
                "example": "2024-01-01",
                "notes": "可选"
              },
              "结束时间": {
                "type": "string",
                "required": false,
                "description": "结束时间           ",
                "example": "2024-12-31",
                "notes": "可选"
              }
            },
            "cmd": "git log --oneline"
          },
          {
            "name": "git log -p 显示补丁",
            "description": "显示每个提交的具体更改内容                 ",
            "params": {},
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --oneline 简洁格式",
            "description": "每行显示一个提交的单行信息                 ",
            "params": {},
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --stat 文件统计",
            "description": "显示每次提交涉及的文件列表和改动统计            ",
            "params": {},
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --format 自定义格式",
            "description": "自定义输出格式，常用于脚本集成               ",
            "params": {
              "格式字符串": {
                "type": "string",
                "required": false,
                "description": "格式占位符          ",
                "example": "%h %an %s",
                "notes": "可选：%H完整哈希 %h缩写 %an作者 %s摘要 %d分支"
              }
            },
            "cmd": "git log --oneline"
          },
          {
            "name": "git log --all --graph --oneline 全图",
            "description": "显示所有分支的完整图形化历史                ",
            "params": {},
            "cmd": "git log --oneline"
          }
        ],
        "params": {}
      }
    }
  ]
}