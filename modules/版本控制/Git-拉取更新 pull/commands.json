{
  "module": "版本控制/Git-拉取更新 pull",
  "version": "2.0",
  "description": "Git 拉取合并 — 从远程仓库拉取代码并自动合并到当前分支。相当于 git fetch + git merge。是保持本地代码与远程同步的主要方式。常见场景：每天开始工作前同步代码、推送前先拉取他人更新、协作时整合远程分支的更改。",
  "commands": [
    {
      "dirPath": "/版本控制/",
      "name": "git pull 拉取",
      "keyword": "git pull 拉取",
      "description": "拉取并合并远程更新。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git pull %{远程}% %{分支}%",
        "extensions": [
          {
            "name": "拉取并变基（保持线性历史）",
            "cmd": "git pull --rebase %{远程}% %{分支}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库           ",
                "example": "origin",
                "notes": "使用 rebase 代替 merge，避免多余合并提交"
              }
            },
            "keyword": "git pull rebase 变基"
          },
          {
            "name": "仅拉取最新（不合并）",
            "cmd": "git fetch %{远程}% %{分支}%",
            "params": {
              "远程": {
                "type": "string",
                "required": false,
                "description": "远程仓库           ",
                "example": "origin",
                "notes": "只下载更新，不合并，适合查看更新后再决定"
              }
            },
            "keyword": "git fetch only 获取"
          },
          {
            "name": "拉取所有远程分支",
            "cmd": "git pull --all",
            "params": {},
            "keyword": "git pull all branches"
          },
          {
            "name": "强制覆盖本地（危险）",
            "cmd": "git pull --force",
            "params": {},
            "keyword": "git pull force overwrite 强制"
          },
          {
            "name": "拉取时创建合并提交",
            "cmd": "git pull --no-rebase",
            "params": {},
            "keyword": "git pull no rebase merge"
          },
          {
            "name": "查看拉取后的变更统计",
            "cmd": "git pull --stat",
            "params": {},
            "keyword": "git pull stat statistics"
          },
          {
            "name": "拉取特定标签",
            "cmd": "git pull origin tag %{标签}%",
            "params": {
              "标签": {
                "type": "string",
                "required": true,
                "description": "标签名            ",
                "example": "v1.0.0",
                "notes": "拉取指定标签的代码"
              }
            },
            "keyword": "git pull tag 标签"
          }
        ],
        "params": {
          "远程": {
            "type": "string",
            "required": false,
            "description": "远程仓库名称         ",
            "example": "origin",
            "notes": "可选，默认 origin"
          },
          "分支": {
            "type": "string",
            "required": false,
            "description": "远程分支名          ",
            "example": "main",
            "notes": "可选，默认当前分支跟踪的远程分支"
          }
        }
      }
    }
  ]
}