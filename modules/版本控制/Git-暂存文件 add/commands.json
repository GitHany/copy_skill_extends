{
  "module": "版本控制/Git-暂存文件 add",
  "version": "2.0",
  "description": "Git add命令集合，涵盖Git add的常用操作和最佳实践",
  "commands": [
    {
      "cmd": "git add .",
      "extensions": [
        {
          "name": "git add 暂存指定文件",
          "description": "暂存指定的单个或多个文件",
          "params": {
            "文件路径": {
              "type": "string",
              "required": true,
              "description": "要添加的文件路径",
              "example": "src/index.js",
              "notes": "必填，支持相对路径和绝对路径"
            },
            "多个文件": {
              "type": "string",
              "required": false,
              "description": "同时暂存多个文件",
              "example": "src/a.js src/b.js",
              "notes": "可选，用空格分隔多个文件"
            }
          },
          "keyword": "git add file"
        },
        {
          "name": "git add -A 暂存所有（包括删除）",
          "description": "暂存所有更改，包括已删除的文件（适用于新克隆的仓库或确保完整暂存）",
          "params": {},
          "keyword": "git add all"
        },
        {
          "name": "git add -u 暂存已跟踪文件",
          "description": "仅暂存已跟踪文件的更改（不包括新创建的文件），适合只提交修改和删除",
          "params": {},
          "keyword": "git add update"
        },
        {
          "name": "git add -p 交互式暂存",
          "description": "交互式暂存，可以逐个文件或逐块选择性地暂存更改，适合提交部分修改",
          "params": {},
          "keyword": "git add patch"
        },
        {
          "name": "git add --dry-run 预览暂存",
          "description": "预览将要暂存的文件，但不实际执行暂存操作",
          "params": {},
          "keyword": "git add dry run"
        },
        {
          "name": "git add 暂存目录",
          "description": "暂存整个目录及其子目录中的所有更改",
          "params": {
            "目录路径": {
              "type": "string",
              "required": true,
              "description": "目录路径",
              "example": "src/",
              "notes": "必填，递归添加目录下所有文件"
            }
          },
          "keyword": "git add directory"
        },
        {
          "name": "git add 通配符批量添加",
          "description": "使用通配符批量添加匹配的文件，如所有同类型文件",
          "params": {
            "通配符": {
              "type": "string",
              "required": true,
              "description": "文件通配符",
              "example": "*.js",
              "notes": "必填，如 *.js 匹配所有 JS 文件"
            },
            "示例": {
              "type": "string",
              "required": false,
              "description": "完整示例",
              "example": "git add *.css",
              "notes": "添加所有 CSS 文件"
            }
          },
          "keyword": "git add glob"
        },
        {
          "name": "git add -f 强制添加被忽略的文件",
          "description": "强制添加被 .gitignore 忽略的文件，适用于需要提交特殊文件的情况",
          "params": {
            "文件路径": {
              "type": "string",
              "required": true,
              "description": "要强制添加的文件路径",
              "example": "secret.json",
              "notes": "必填"
            }
          },
          "keyword": "git add force ignore"
        },
        {
          "name": "git add 暂存所有修改过的同类文件",
          "description": "暂存所有已跟踪的同类文件更改，适合批量更新某种类型的文件",
          "params": {
            "扩展名": {
              "type": "string",
              "required": true,
              "description": "文件扩展名",
              "example": "txt",
              "notes": "必填，不带点号"
            }
          },
          "keyword": "git add modified files"
        },
        {
          "name": "git add 暂存隐藏目录中的文件",
          "description": "暂存隐藏目录（以点开头）中的文件，如配置文件",
          "params": {
            "目录名": {
              "type": "string",
              "required": true,
              "description": "隐藏目录名称",
              "example": ".config",
              "notes": "必填"
            }
          },
          "keyword": "git add hidden directory"
        },
        {
          "name": "git add 暂存空目录占位",
          "description": "在空目录中添加 .gitkeep 文件并暂存，用于确保空目录被提交",
          "params": {
            "目录路径": {
              "type": "string",
              "required": true,
              "description": "空目录路径",
              "example": "logs",
              "notes": "必填"
            }
          },
          "keyword": "git add empty directory"
        },
        {
          "name": "git add -i 交互式菜单",
          "description": "打开交互式暂存菜单，可选择要暂存的文件或对更改进行补丁式操作",
          "params": {},
          "keyword": "git add interactive menu"
        },
        {
          "name": "git add --update 简写",
          "cmd": "git add -u",
          "description": "仅暂存已跟踪文件的更改（不包括新创建的文件），适合只提交修改和删除",
          "params": {},
          "keyword": "git add update short"
        },
        {
          "name": "git add -v 显示详细输出",
          "description": "显示暂存操作的详细输出，包括添加的文件列表",
          "params": {},
          "keyword": "git add verbose"
        },
        {
          "name": "git add 暂存空目录占位",
          "description": "在空目录中添加 .gitkeep 文件并暂存，用于确保空目录被提交",
          "params": {
            "目录路径": {
              "type": "string",
              "required": true,
              "description": "空目录路径",
              "example": "logs",
              "notes": "必填"
            }
          },
          "keyword": "git add empty directory placeholder"
        },
        {
          "name": "git add 暂存修改的已跟踪文件",
          "description": "暂存所有已跟踪文件的修改，不包括新文件",
          "cmd": "git add -u",
          "params": {},
          "keyword": "git add modified tracked"
        },
        {
          "name": "git add 交互式选择文件",
          "description": "交互式选择要暂存的文件",
          "cmd": "git add -i",
          "params": {},
          "keyword": "git add interactive select"
        },
        {
          "name": "交互式暂存补丁",
          "cmd": "git add -p",
          "description": "交互式选择文件块进行暂存",
          "params": {},
          "keyword": "git add patch interactive"
        },
        {
          "name": "暂存并查看差异",
          "cmd": "git add -v %{文件路径}%",
          "params": {
            "文件路径": {
              "type": "string",
              "required": false,
              "description": "文件路径",
              "example": "src/app.js",
              "notes": "可选"
            }
          },
          "keyword": "git add verbose diff"
        },
        {
          "name": "强制暂存被忽略文件",
          "cmd": "git add -f %{文件路径}%",
          "params": {
            "文件路径": {
              "type": "string",
              "required": true,
              "description": "被忽略的文件路径",
              "example": "secret.json",
              "notes": "必填"
            }
          },
          "keyword": "git add force ignore"
        },
        {
          "name": "暂存更新部分文件",
          "cmd": "git add -u %{目录路径}%",
          "params": {
            "目录路径": {
              "type": "string",
              "required": false,
              "description": "目录路径",
              "example": "src/",
              "notes": "可选"
            }
          },
          "keyword": "git add update partial"
        },
        {
          "name": "仅暂存新文件",
          "cmd": "git add --intent-to-add %{文件路径}%",
          "params": {
            "文件路径": {
              "type": "string",
              "required": true,
              "description": "新文件路径",
              "example": "new-file.js",
              "notes": "必填"
            }
          },
          "keyword": "git add intent add new"
        }
      ],
      "params": {},
      "dirPath": "/版本控制/",
      "name": "Git add 命令",
      "keyword": "Git add 命令",
      "description": "Git add 命令的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    }
  ]
}