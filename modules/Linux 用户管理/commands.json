{
  "module": "Linux 用户管理",
  "version": "2.0",
  "description": "Linux 用户管理命令集合，涵盖Linux 用户管理的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux 用户管理/",
      "name": "useradd 创建用户",
      "keyword": "useradd 用户",
      "description": "创建新用户。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "useradd -m %{用户}%",
        "extensions": [
          {
            "name": "指定 UID",
            "cmd": "useradd -u %{uid}% -m %{用户}%",
            "params": {
              "uid": {
                "type": "string",
                "required": true,
                "description": "UID",
                "example": "1001",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "newuser",
                "notes": "必填"
              }
            },
            "keyword": "useradd uid"
          },
          {
            "name": "添加到组",
            "cmd": "useradd -G %{组}% -m %{用户}%",
            "params": {
              "组": {
                "type": "string",
                "required": true,
                "description": "组",
                "example": "sudo",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户",
                "example": "newuser",
                "notes": "必填"
              }
            },
            "keyword": "useradd group"
          }
        ],
        "params": {
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户名",
            "example": "developer",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Linux 用户管理/",
      "name": "usermod 修改用户",
      "keyword": "usermod 修改",
      "description": "修改用户属性。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "usermod -aG %{组}% %{用户}%",
        "extensions": [],
        "params": {
          "组": {
            "type": "string",
            "required": true,
            "description": "组",
            "example": "docker",
            "notes": "必填"
          },
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户",
            "example": "developer",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Linux 用户管理/",
      "name": "userdel 删除用户",
      "keyword": "userdel 删除",
      "description": "删除用户。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "userdel -r %{用户}%",
        "extensions": [],
        "params": {
          "用户": {
            "type": "string",
            "required": true,
            "description": "用户名",
            "example": "olduser",
            "notes": "必填"
          }
        }
      }
    }
  ]
}