{
  "module": "Git rm",
  "version": "2.0",
  "description": "Git 删除文件 - 从 Git 仓库中删除文件并取消跟踪。同时删除工作目录中的文件，适合清理不需要的文件。注意：使用 --cached 选项可以只取消跟踪但不删除本地文件。",
  "commands": [
    {
      "dirPath": "/Git rm/",
      "name": "git rm 删除文件",
      "keyword": "git rm 删除",
      "description": "删除并取消跟踪文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "git rm %{文件}%",
        "extensions": [
          {
            "name": "删除单个文件",
            "cmd": "git rm %{文件}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件路径",
                "example": "old.txt",
                "notes": "必填"
              }
            }
          },
          {
            "name": "删除多个文件",
            "cmd": "git rm %{文件1}% %{文件2}%",
            "params": {
              "文件1": {
                "type": "string",
                "required": true,
                "description": "第一个文件路径",
                "example": "file1.txt",
                "notes": "必填"
              },
              "文件2": {
                "type": "string",
                "required": true,
                "description": "第二个文件路径",
                "example": "file2.txt",
                "notes": "必填"
              }
            }
          },
          {
            "name": "递归删除目录",
            "cmd": "git rm -r %{目录}%",
            "params": {
              "目录": {
                "type": "string",
                "required": true,
                "description": "目录路径",
                "example": "logs/",
                "notes": "删除目录及其所有文件"
              }
            }
          },
          {
            "name": "仅取消跟踪（保留文件）",
            "cmd": "git rm --cached %{文件}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件路径",
                "example": "secret.txt",
                "notes": "从 Git 删除但不删除本地文件"
              }
            }
          },
          {
            "name": "强制删除已修改的文件",
            "cmd": "git rm -f %{文件}%",
            "params": {
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件路径",
                "example": "config.yml",
                "notes": "强制删除，无法恢复"
              }
            }
          },
          {
            "name": "删除所有匹配的文件",
            "cmd": "git rm '**/*.log'",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "文件模式",
                "example": "*.log",
                "notes": "使用通配符删除多个文件"
              }
            }
          },
          {
            "name": "交互式删除",
            "cmd": "git rm -i",
            "params": {}
          },
          {
            "name": "删除空目录",
            "cmd": "git rm -r --dry-run %{目录}%",
            "params": {
              "目录": {
                "type": "string",
                "required": true,
                "description": "目录路径",
                "example": "empty_folder/",
                "notes": "先预览将要删除的内容"
              }
            }
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件路径",
            "example": "old.txt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}