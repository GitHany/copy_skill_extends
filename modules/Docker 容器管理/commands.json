{
  "module": "Docker 容器管理",
  "version": "2.0",
  "description": "Docker 容器管理命令集合，涵盖Docker 容器管理的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Docker 容器管理/",
      "name": "docker run 创建容器",
      "keyword": "docker run 创建",
      "description": "创建并启动容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker run -d --name %{名称}% %{镜像}%",
        "extensions": [],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "容器名",
            "example": "myapp",
            "notes": "必填"
          },
          "镜像": {
            "type": "string",
            "required": true,
            "description": "镜像名",
            "example": "nginx",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/Docker 容器管理/",
      "name": "docker ps 列出容器",
      "keyword": "docker ps 列表",
      "description": "列出容器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "docker ps",
        "extensions": [],
        "params": {}
      }
    }
  ]
}