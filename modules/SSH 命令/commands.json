{
  "module": "SSH 命令",
  "version": "2.0",
  "description": "SSH 远程登录和文件传输命令，涵盖SSH 命令的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/SSH 命令/",
      "name": "ssh 远程登录",
      "keyword": "ssh 登录",
      "description": "SSH 远程登录服务器。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ssh %{用户名}%@%{主机}%",
        "extensions": [
          {
            "name": "指定端口",
            "cmd": "ssh -p %{端口}% %{用户}%@%{主机}%",
            "params": {
              "端口": {
                "type": "string",
                "required": true,
                "description": "SSH 端口",
                "example": "2222",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "root",
                "notes": "必填"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机地址",
                "example": "server.com",
                "notes": "必填"
              }
            },
            "keyword": "ssh port"
          },
          {
            "name": "使用密钥",
            "cmd": "ssh -i %{密钥文件}% %{用户}%@%{主机}%",
            "params": {
              "密钥文件": {
                "type": "string",
                "required": true,
                "description": "私钥文件",
                "example": "~/.ssh/id_rsa",
                "notes": "必填"
              },
              "用户": {
                "type": "string",
                "required": true,
                "description": "用户名",
                "example": "ubuntu",
                "notes": "必填"
              },
              "主机": {
                "type": "string",
                "required": true,
                "description": "主机",
                "example": "host.com",
                "notes": "必填"
              }
            },
            "keyword": "ssh key"
          }
        ],
        "params": {
          "用户名": {
            "type": "string",
            "required": true,
            "description": "SSH 用户名",
            "example": "root",
            "notes": "必填"
          },
          "主机": {
            "type": "string",
            "required": true,
            "description": "主机地址或 IP",
            "example": "192.168.1.100",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SSH 命令/",
      "name": "scp 远程复制",
      "keyword": "scp 复制",
      "description": "通过 SSH 复制文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "scp %{源文件}% %{目标}%",
        "extensions": [
          {
            "name": "递归复制目录",
            "cmd": "scp -r %{目录}% %{目标}%",
            "params": {
              "目录": {
                "type": "string",
                "required": true,
                "description": "源目录",
                "example": "./mydir",
                "notes": "必填"
              },
              "目标": {
                "type": "string",
                "required": true,
                "description": "目标位置",
                "example": "user@host:/remote/path",
                "notes": "必填"
              }
            },
            "keyword": "scp recursive"
          }
        ],
        "params": {
          "源文件": {
            "type": "string",
            "required": true,
            "description": "源文件路径",
            "example": "file.txt",
            "notes": "必填"
          },
          "目标": {
            "type": "string",
            "required": true,
            "description": "目标位置",
            "example": "user@host:/path/",
            "notes": "必填"
          }
        }
      }
    }
  ]
}