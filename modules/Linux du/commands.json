{
  "module": "Linux du",
  "version": "2.0",
  "description": "Linux du (disk usage) 磁盘使用统计命令。分析文件和目录占用的磁盘空间，帮助找出哪些文件或目录消耗了最多的存储空间。常用场景：清理大文件、排查磁盘满、评估存储需求。支持多种输出格式和排序方式。",
  "commands": [
    {
      "dirPath": "/Linux du/",
      "name": "du 磁盘使用",
      "keyword": "du 磁盘",
      "description": "估算文件空间使用。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "du -sh %{目录}%",
        "extensions": [
          {
            "name": "显示目录总大小",
            "description": "显示目录占用的总空间，人性化显示(KB/MB/GB)",
            "params": {
              "目录": {
                "example": "/var/log",
                "notes": "目录路径"
              }
            },
            "cmd": "du -sh %{目录}%"
          },
          {
            "name": "显示所有子目录大小",
            "description": "列出目录下每个子目录的大小",
            "params": {
              "目录": {
                "example": "/home",
                "notes": "目录路径"
              }
            },
            "cmd": "du -h %{目录}% | sort -h"
          },
          {
            "name": "查找最大的文件目录",
            "description": "找出当前目录下占用空间最大的10个文件或目录",
            "params": {
              "目录": {
                "example": ".",
                "notes": "当前目录"
              }
            },
            "cmd": "du -sh * | sort -rh | head -10"
          },
          {
            "name": "显示文件大小",
            "description": "显示文件而非目录的磁盘使用情况",
            "params": {
              "文件": {
                "example": "/var/log/syslog",
                "notes": "文件路径"
              }
            },
            "cmd": "du -h %{文件}%"
          },
          {
            "name": "排除特定目录",
            "description": "计算磁盘使用但排除某些目录，如排除tmp",
            "params": {
              "目录": {
                "example": "/home",
                "notes": "目录路径"
              },
              "排除": {
                "example": "tmp",
                "notes": "排除的目录名"
              }
            },
            "cmd": "du -h --exclude=%{排除}% %{目录}%"
          },
          {
            "name": "只显示总计",
            "description": "只显示总计，不显示子目录明细",
            "params": {
              "目录": {
                "example": "/opt",
                "notes": "目录"
              }
            },
            "cmd": "du -sh %{目录}%"
          },
          {
            "name": "显示块数计数",
            "description": "用块数而不是字节显示存储使用",
            "params": {
              "目录": {
                "example": ".",
                "notes": "目录"
              }
            },
            "cmd": "du -s %{目录}%"
          },
          {
            "name": "设置深度",
            "description": "只显示指定深度级别的信息",
            "params": {
              "目录": {
                "example": "/",
                "notes": "目录"
              },
              "深度": {
                "example": "1",
                "notes": "目录深度"
              }
            },
            "cmd": "du -h --max-depth=%{深度}% %{目录}%"
          }
        ],
        "params": {
          "目录": {
            "type": "string",
            "required": false,
            "description": "目录",
            "example": ".",
            "notes": "可选"
          }
        }
      }
    }
  ]
}