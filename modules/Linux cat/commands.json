{
  "module": "Linux cat",
  "version": "2.0",
  "description": "Linux cat 文件查看命令。连接并显示文件内容到标准输出，是最常用的文本文件查看工具。用于快速查看文件内容、合并多个文件、创建新文件、显示行号。适合查看配置文件、日志文件、脚本内容。注意：大文件用less更合适。",
  "commands": [
    {
      "dirPath": "/Linux cat/",
      "name": "cat 查看文件",
      "keyword": "cat 查看",
      "description": "查看文件内容。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "cat %{文件}%",
        "extensions": [
          {
            "name": "显示行号",
            "description": "为每一行添加行号，便于代码阅读和调试",
            "params": {
              "文件": {
                "example": "script.py",
                "notes": "文件名"
              }
            },
            "cmd": "cat -n %{文件}%"
          },
          {
            "name": "显示行尾符号",
            "description": "显示换行符为$符号，方便检查空行",
            "params": {
              "文件": {
                "example": "data.txt",
                "notes": "文件名"
              }
            },
            "cmd": "cat -A %{文件}%"
          },
          {
            "name": "压缩连续空行",
            "description": "将多个连续空行压缩为一行，使输出更紧凑",
            "params": {
              "文件": {
                "example": "log.txt",
                "notes": "文件名"
              }
            },
            "cmd": "cat -s %{文件}%"
          },
          {
            "name": "合并多个文件",
            "description": "将多个文件内容合并到一个文件",
            "params": {
              "输出文件": {
                "example": "combined.txt",
                "notes": "目标文件"
              },
              "文件列表": {
                "example": "file1.txt file2.txt file3.txt",
                "notes": "源文件列表"
              }
            },
            "cmd": "cat %{文件列表}% > %{输出文件}%"
          },
          {
            "name": "追加内容到文件",
            "description": "将内容追加到已存在文件的末尾",
            "params": {
              "内容": {
                "example": "new line",
                "notes": "要追加的内容"
              },
              "文件": {
                "example": "notes.txt",
                "notes": "目标文件"
              }
            },
            "cmd": "cat >> %{文件}% << EOF\n%{内容}%\nEOF"
          },
          {
            "name": "创建文件",
            "description": "使用输入重定向创建新文件",
            "params": {
              "内容": {
                "example": "Hello World",
                "notes": "文件内容"
              },
              "文件": {
                "example": "hello.txt",
                "notes": "新文件名"
              }
            },
            "cmd": "cat > %{文件}% << EOF\n%{内容}%\nEOF"
          },
          {
            "name": "查看不可见字符",
            "description": "显示文件中的空格、制表符等不可见字符",
            "params": {
              "文件": {
                "example": "config.cfg",
                "notes": "文件名"
              }
            },
            "cmd": "cat -v %{文件}%"
          },
          {
            "name": "翻页查看大文件",
            "description": "如果文件很长，自动分页显示",
            "params": {
              "文件": {
                "example": "large.log",
                "notes": "文件名"
              }
            },
            "cmd": "cat %{文件}% | more"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件",
            "example": "README.md",
            "notes": "必填"
          }
        }
      }
    }
  ]
}