      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    },
    {
      "name": "查看最近日志",
      "cmd": "journalctl -n %{数量}% -u %{服务}%",
      "params": {
        "数量": {
          "type": "string",
          "required": true,
          "description": "日志条数",
          "example": "50",
          "notes": "必填"
        },
        "服务": {
          "type": "string",
          "required": true,
          "description": "服务名称",
          "example": "nginx",
          "notes": "必填"
        }
      },
      "keyword": "journalctl lines",
      "dirPath": "/Linux 系统管理/",
