          "notes": "必填"
        }
      },
      "keyword": "systemctl status",
      "dirPath": "/Linux 系统管理/",
      "description": "查看状态的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    },
    {
      "name": "启用开机启动",
      "cmd": "systemctl enable %{服务}%",
      "params": {
        "服务": {
          "type": "string",
          "required": true,
          "description": "服务名称",
          "example": "nginx",
          "notes": "必填"
