{
  "module": "Kubernetes Service",
  "version": "2.0",
  "description": "Kubernetes Service 服务管理",
  "commands": [
    {
      "dirPath": "/Kubernetes Service/",
      "name": "kubectl expose service 暴露",
      "keyword": "kubectl expose 暴露",
      "description": "暴露 Deployment 为 Service。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl expose deployment %{名称}% --port=%{端口}% --target-port=%{目标端口}% --type=%{类型}%",
        "extensions": [],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "Deployment 名",
            "example": "nginx",
            "notes": "必填"
          },
          "端口": {
            "type": "string",
            "required": true,
            "description": "服务端口",
            "example": "80",
            "notes": "必填"
          },
          "目标端口": {
            "type": "string",
            "required": true,
            "description": "容器端口",
            "example": "8080",
            "notes": "必填"
          },
          "类型": {
            "type": "string",
            "required": true,
            "description": "Service 类型",
            "example": "LoadBalancer",
            "notes": "必填"
          }
        }
      }
    }
  ]
}