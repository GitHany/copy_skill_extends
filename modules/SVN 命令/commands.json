{
  "module": "SVN 命令",
  "version": "2.0",
  "description": "Subversion 版本控制系统命令，涵盖SVN 命令的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/SVN 命令/",
      "name": "svn checkout 检出仓库",
      "keyword": "svn checkout 检出",
      "description": "从 SVN 仓库检出工作副本。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn checkout %{仓库URL}%",
        "extensions": [
          {
            "name": "检出到指定目录",
            "cmd": "svn checkout %{仓库URL}% %{目录}%",
            "params": {
              "仓库URL": {
                "type": "string",
                "required": true,
                "description": "SVN 仓库 URL",
                "example": "https://svn.example.com/repo",
                "notes": "必填"
              },
              "目录": {
                "type": "string",
                "required": true,
                "description": "目标目录",
                "example": "myproject",
                "notes": "必填"
              }
            },
            "keyword": "svn checkout 目录"
          }
        ],
        "params": {
          "仓库URL": {
            "type": "string",
            "required": true,
            "description": "SVN 仓库 URL",
            "example": "https://svn.example.com/repo/trunk",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn commit 提交更改",
      "keyword": "svn commit 提交",
      "description": "将更改提交到仓库。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn commit -m %{提交信息}%",
        "extensions": [
          {
            "name": "提交指定文件",
            "cmd": "svn commit -m %{提交信息}% %{文件}%",
            "params": {
              "提交信息": {
                "type": "string",
                "required": true,
                "description": "提交说明",
                "example": "Fix bug #123",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件路径",
                "example": "src/main.py",
                "notes": "必填"
              }
            },
            "keyword": "svn commit 文件"
          }
        ],
        "params": {
          "提交信息": {
            "type": "string",
            "required": true,
            "description": "提交说明信息",
            "example": "Add new feature",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn update 更新工作副本",
      "keyword": "svn update 更新",
      "description": "更新工作副本到最新版本。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn update",
        "extensions": [
          {
            "name": "更新到指定版本",
            "cmd": "svn update -r %{版本号}%",
            "params": {
              "版本号": {
                "type": "string",
                "required": true,
                "description": "版本号",
                "example": "100",
                "notes": "必填"
              }
            },
            "keyword": "svn update 版本"
          }
        ],
        "params": {}
      }
    },
    {
