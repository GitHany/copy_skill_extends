    {
      "dirPath": "/SVN 命令/",
      "name": "svn copy 复制分支",
      "keyword": "svn copy 复制",
      "description": "创建分支或标签。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn copy %{源URL}% %{目标URL}% -m %{提交信息}%",
        "extensions": [],
        "params": {
          "源URL": {
            "type": "string",
            "required": true,
            "description": "源 URL",
            "example": "^/trunk",
            "notes": "必填"
