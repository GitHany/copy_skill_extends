      "keyword": "svn add 添加",
      "description": "添加文件或目录到版本控制。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn add %{文件}%",
        "extensions": [],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件或目录路径",
            "example": "newfile.txt",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn delete 删除文件",
      "keyword": "svn delete 删除",
      "description": "删除文件并标记删除。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn delete %{文件}%",
        "extensions": [],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件路径",
            "example": "oldfile.txt",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn status 查看状态",
      "keyword": "svn status 状态",
      "description": "查看工作副本状态。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn status",
        "extensions": [
          {
            "name": "显示详细状态",
            "cmd": "svn status -v",
            "params": {},
            "keyword": "svn status verbose"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn log 查看日志",
      "keyword": "svn log 日志",
      "description": "查看提交历史日志。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn log",
        "extensions": [
          {
            "name": "限制日志数量",
            "cmd": "svn log -l %{数量}%",
            "params": {
              "数量": {
                "type": "string",
                "required": true,
                "description": "日志条数",
                "example": "10",
                "notes": "必填"
              }
            },
            "keyword": "svn log limit"
          }
        ],
        "params": {}
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn diff 查看差异",
      "keyword": "svn diff 差异",
      "description": "查看文件更改差异。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn diff %{文件}%",
        "extensions": [
          {
            "name": "比较特定版本",
            "cmd": "svn diff -r %{版本1}%:%{版本2}%",
            "params": {
              "版本1": {
                "type": "string",
                "required": true,
                "description": "版本1",
                "example": "100",
                "notes": "必填"
              },
              "版本2": {
                "type": "string",
                "required": true,
                "description": "版本2",
                "example": "101",
                "notes": "必填"
              }
            },
            "keyword": "svn diff 版本"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": false,
            "description": "文件路径",
            "example": "file.txt",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn revert 还原更改",
      "keyword": "svn revert 还原",
      "description": "还原工作副本的更改。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn revert %{文件}%",
        "extensions": [],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件或目录",
            "example": "modified.txt",
            "notes": "必填"
          }
        }
      }
    },
    {
      "dirPath": "/SVN 命令/",
      "name": "svn merge 合并更改",
      "keyword": "svn merge 合并",
      "description": "合并分支或版本。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "svn merge %{仓库URL}%",
        "extensions": [],
        "params": {
          "仓库URL": {
            "type": "string",
            "required": true,
            "description": "合并来源 URL",
            "example": "^/branches/feature",
            "notes": "必填"
