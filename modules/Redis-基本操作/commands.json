    {
      "dirPath": "/Redis 命令/基本操作/",
      "name": "redis ping 测试连接",
      "keyword": "redis ping",
      "description": "测试 Redis 连接是否正常。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "redis-cli ping",
        "extensions": [
          {
            "name": "带密码连接",
            "cmd": "redis-cli -a %{密码}% ping",
            "params": {
              "密码": {
                "type": "string",
                "required": true,
                "description": "Redis 密码",
                "example": "yourpassword",
                "notes": "可选"
              }
            },
            "keyword": "redis 密码"
          },
          {
            "name": "指定主机连接",
            "cmd": "redis-cli -h %{主机}% ping",
            "params": {
              "主机": {
                "type": "string",
                "required": true,
                "description": "Redis 服务器地址",
                "example": "127.0.0.1",
                "notes": "可选"
              }
            },
            "keyword": "redis 主机"
          },
          {
            "name": "指定端口连接",
            "cmd": "redis-cli -p %{端口}% ping",
            "params": {
              "端口": {
                "type": "integer",
                "required": true,
                "description": "Redis 端口号",
                "example": "6379",
                "notes": "可选"
              }
            },
            "keyword": "redis 端口"
          }
        ],
        "params": {}
      }
    },
