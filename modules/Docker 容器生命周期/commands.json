{
  "module": "Docker 容器生命周期",
  "version": "2.0",
  "description": "Docker 容器生命周期命令集合，涵盖Docker 容器生命周期的常用操作和最佳实践",
  "commands": [
    {
      "name": "后台运行",
      "cmd": "docker run -d --name %{名称}% -p %{宿主机端口}%:%{容器端口}% %{镜像}%",
      "params": {
        "名称": {
          "type": "string",
          "required": true,
          "description": "容器名",
          "example": "web",
          "notes": "必填"
        },
        "宿主机端口": {
          "type": "string",
          "required": true,
          "description": "宿主机端口",
          "example": "8080",
          "notes": "必填"
        },
        "容器端口": {
          "type": "string",
          "required": true,
          "description": "容器端口",
          "example": "80",
          "notes": "必填"
        },
        "镜像": {
          "type": "string",
          "required": true,
          "description": "镜像",
          "example": "nginx",
          "notes": "必填"
        }
      },
      "keyword": "docker run detached",
      "dirPath": "/Docker 容器生命周期/",
      "description": "后台运行的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [],
        "params": {}
      }
    }
  ]
}