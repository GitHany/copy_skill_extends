{
  "module": "kubectl get",
  "version": "2.0",
  "description": "kubectl 鑾峰彇璧勬簮，涵盖kubectl get的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/kubectl get/",
      "name": "kubectl get 鑾峰彇璧勬簮",
      "keyword": "kubectl get 鑾峰彇",
      "description": "鑾峰彇 Kubernetes 璧勬簮。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "kubectl get %{绫诲瀷}%",
        "extensions": [
          {
            "name": "鍏ㄩ儴鍛藉悕绌洪棿",
            "cmd": "kubectl get %{绫诲瀷}% --all-namespaces",
            "params": {
              "绫诲瀷": {
                "type": "string",
                "required": true,
                "description": "璧勬簮绫诲瀷",
                "example": "pods",
                "notes": "蹇呭～"
              }
            },
            "keyword": "kubectl get all"
          },
          {
            "name": "瀹借〃鏍煎紡",
            "cmd": "kubectl get %{绫诲瀷}% -o wide",
            "params": {
              "绫诲瀷": {
                "type": "string",
                "required": true,
                "description": "绫诲瀷",
                "example": "pods",
                "notes": "蹇呭～"
              }
            },
            "keyword": "kubectl get wide"
          }
        ],
        "params": {
          "绫诲瀷": {
            "type": "string",
            "required": true,
            "description": "璧勬簮绫诲瀷",
            "example": "pods",
            "notes": "蹇呭～"
          }
        }
      }
    }
  ]
}