{
  "module": "Linux系统/Linux-快速搜索 locate",
  "version": "2.0",
  "description": "Linux locate 文件快速查找命令。基于预构建的数据库快速搜索文件， 比find快很多。适用于需要频繁查找文件的场景，如快速定位配置文件、查找代码文件。注意：新建文件后可能需要updatedb更新数据库。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "locate 快速查找",
      "keyword": "locate 查找",
      "description": "快速定位文件。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "locate %{文件名}%",
        "extensions": [
          {
            "name": "查找单个文件",
            "description": "快速定位文件，支持通配符                  ",
            "params": {
              "文件名": {
                "example": "*.txt",
                "notes": "文件名模式",
                "description": "               "
              }
            },
            "cmd": "locate %{文件名}%"
          },
          {
            "name": "精确匹配",
            "description": "查找完全匹配文件名的文件                  ",
            "params": {
              "文件名": {
                "example": "config.json",
                "notes": "精确文件名",
                "description": "               "
              }
            },
            "cmd": "locate -l 1 \"%{文件名}%\""
          },
          {
            "name": "限制结果数量",
            "description": "限制搜索结果的数量                     ",
            "params": {
              "数量": {
                "example": "10",
                "notes": "结果数",
                "description": "               "
              },
              "文件名": {
                "example": "log",
                "notes": "关键词",
                "description": "               "
              }
            },
            "cmd": "locate -l %{数量}% %{文件名}%"
          },
          {
            "name": "忽略大小写",
            "description": "搜索时忽略大小写                      ",
            "params": {
              "文件名": {
                "example": "README",
                "notes": "文件名",
                "description": "               "
              }
            },
            "cmd": "locate -i %{文件名}%"
          },
          {
            "name": "显示数据库路径",
            "description": "显示locate使用的数据库文件位置            ",
            "params": {},
            "cmd": "locate -e"
          },
          {
            "name": "验证文件存在",
            "description": "搜索后验证结果文件是否真实存在               ",
            "params": {
              "文件名": {
                "example": "app.py",
                "notes": "文件名",
                "description": "               "
              }
            },
            "cmd": "locate -P %{文件名}%"
          },
          {
            "name": "显示统计信息",
            "description": "显示数据库中的文件统计信息                 ",
            "params": {},
            "cmd": "locate --statistics"
          },
          {
            "name": "更新数据库",
            "description": "手动更新文件位置数据库                   ",
            "params": {},
            "cmd": "sudo updatedb"
          }
        ],
        "params": {
          "文件名": {
            "type": "string",
            "required": true,
            "description": "文件名            ",
            "example": "*.txt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}