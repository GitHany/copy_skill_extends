{
  "module": "Linux系统/Linux-查看尾部 tail",
  "version": "2.0",
  "description": "Linux tail 文件尾部查看命令。显示文件的最后部分，默认显示最后10行。用于查看日志文件的最新条目、监控文件变化、分析数据文件的末尾。是服务器运维和调试的必备工具。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "tail 查看尾部",
      "keyword": "tail 尾部",
      "description": "查看文件结尾内容。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "tail -n %{行}% %{文件}%",
        "extensions": [
          {
            "name": "查看最后N行",
            "description": "显示文件最后N行内容                    ",
            "params": {
              "行": {
                "example": "20",
                "notes": "行数",
                "description": "               "
              },
              "文件": {
                "example": "app.log",
                "notes": "文件名",
                "description": "               "
              }
            },
            "cmd": "tail -n %{行}% %{文件}%"
          },
          {
            "name": "实时监控文件",
            "description": "持续显示文件新增内容，类似tail -f          ",
            "params": {
              "文件": {
                "example": "/var/log/syslog",
                "notes": "日志文件",
                "description": "               "
              }
            },
            "cmd": "tail -f %{文件}%"
          },
          {
            "name": "监控多个文件",
            "description": "同时监控多个日志文件的新增内容               ",
            "params": {
              "文件1": {
                "example": "error.log",
                "notes": "文件1",
                "description": "               "
              },
              "文件2": {
                "example": "access.log",
                "notes": "文件2",
                "description": "               "
              }
            },
            "cmd": "tail -f %{文件1}% %{文件2}%"
          },
          {
            "name": "显示字节数",
            "description": "按字节数而非行数显示文件尾部                ",
            "params": {
              "字节": {
                "example": "1024",
                "notes": "字节数",
                "description": "               "
              },
              "文件": {
                "example": "data.bin",
                "notes": "文件",
                "description": "               "
              }
            },
            "cmd": "tail -c %{字节}% %{文件}%"
          },
          {
            "name": "显示所有行",
            "description": "从第N行开始显示到文件结尾                 ",
            "params": {
              "行": {
                "example": "100",
                "notes": "起始行",
                "description": "               "
              },
              "文件": {
                "example": "largefile.txt",
                "notes": "文件",
                "description": "               "
              }
            },
            "cmd": "tail -n +%{行}% %{文件}%"
          },
          {
            "name": "静默模式",
            "description": "持续监控但不显示文件名标题                 ",
            "params": {
              "文件": {
                "example": "/var/log/nginx.log",
                "notes": "文件",
                "description": "               "
              }
            },
            "cmd": "tail -q -f %{文件}%"
          },
          {
            "name": "倒序显示行",
            "description": "从后往前显示文件内容                    ",
            "params": {
              "文件": {
                "example": "log.txt",
                "notes": "文件",
                "description": "               "
              }
            },
            "cmd": "tac %{文件}%"
          },
          {
            "name": "配合grep过滤",
            "description": "只显示包含特定关键词的行                  ",
            "params": {
              "行": {
                "example": "100",
                "notes": "行数",
                "description": "               "
              },
              "模式": {
                "example": "ERROR",
                "notes": "匹配模式",
                "description": "               "
              },
              "文件": {
                "example": "/var/log/app.log",
                "notes": "文件",
                "description": "               "
              }
            },
            "cmd": "tail -n %{行}% %{文件}% | grep %{模式}%"
          }
        ],
        "params": {
          "行": {
            "type": "string",
            "required": true,
            "description": "行数             ",
            "example": "50",
            "notes": "必填"
          },
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件             ",
            "example": "log.txt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}