{
  "module": "Linux系统/Linux-终端会话 screen",
  "version": "2.0",
  "description": "Linux screen 终端会话管理工具。创建多个虚拟终端，在断开连接时保持会话活跃。允许多个窗口、会话共享、后台运行。非常适合需要长时间运行的任务、远程协作、教程演示。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "screen 会话管理",
      "keyword": "screen 会话",
      "description": "管理终端会话。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "screen -S %{名称}%",
        "extensions": [
          {
            "name": "创建命名会话",
            "description": "创建一个带名称的screen会话              ",
            "params": {
              "名称": {
                "example": "myproject",
                "notes": "会话名称",
                "description": "               "
              }
            },
            "cmd": "screen -S %{名称}%"
          },
          {
            "name": "列出所有会话",
            "description": "显示当前存在的所有screen会话             ",
            "params": {},
            "cmd": "screen -ls"
          },
          {
            "name": "恢复会话",
            "description": "重新连接到已存在的screen会话             ",
            "params": {
              "名称": {
                "example": "myproject",
                "notes": "会话名或PID",
                "description": "               "
              }
            },
            "cmd": "screen -r %{名称}%"
          },
          {
            "name": "分离当前会话",
            "description": "将screen会话放到后台，保留运行状态          ",
            "params": {},
            "cmd": "screen -d"
          },
          {
            "name": "创建并进入",
            "description": "创建新会话并立即进入                    ",
            "params": {
              "名称": {
                "example": "work",
                "notes": "会话名",
                "description": "               "
              }
            },
            "cmd": "screen %{名称}%"
          },
          {
            "name": "远程共享会话",
            "description": "允许其他人加入查看同一screen会话           ",
            "params": {
              "名称": {
                "example": "tutorial",
                "notes": "会话名",
                "description": "               "
              }
            },
            "cmd": "screen -x %{名称}%"
          },
          {
            "name": "创建独立会话",
            "description": "创建一个完全独立的会话，不受其他screen影响      ",
            "params": {
              "名称": {
                "example": "detached",
                "notes": "会话名",
                "description": "               "
              }
            },
            "cmd": "screen -dmS %{名称}%"
          },
          {
            "name": "关闭会话",
            "description": "优雅地关闭一个screen会话               ",
            "params": {
              "名称": {
                "example": "myproject",
                "notes": "会话名",
                "description": "               "
              }
            },
            "cmd": "screen -S %{名称}% -X quit"
          }
        ],
        "params": {
          "名称": {
            "type": "string",
            "required": true,
            "description": "会话名            ",
            "example": "myproject",
            "notes": "必填"
          }
        }
      }
    }
  ]
}