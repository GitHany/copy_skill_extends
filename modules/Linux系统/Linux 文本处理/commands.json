{
  "module": "Linux系统/Linux 文本处理",
  "version": "2.0",
  "description": "Linux 文本处理命令集合，涵盖Linux 文本处理的常用操作和最佳实践",
  "commands": [
    {
      "name": "忽略大小写",
      "cmd": "grep -i %{模式}% %{文件}%",
      "params": {
        "模式": {
          "type": "string",
          "required": true,
          "description": "模式",
          "example": "warning",
          "notes": "必填"
        },
        "文件": {
          "type": "string",
          "required": true,
          "description": "文件",
          "example": "app.log",
          "notes": "必填"
        }
      },
      "keyword": "grep ignore",
      "dirPath": "/Linux系统/",
      "description": "忽略大小写的详细说明。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "",
        "extensions": [
          {
            "name": "递归搜索目录",
            "cmd": "grep -ri %{模式}% %{目录}%",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "搜索模式",
                "example": "error",
                "notes": "必填"
              },
              "目录": {
                "type": "string",
                "required": true,
                "description": "搜索目录",
                "example": "/var/log",
                "notes": "必填"
              }
            },
            "keyword": "grep recursive ignore-case"
          },
          {
            "name": "显示行号",
            "cmd": "grep -in %{模式}% %{文件}%",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "搜索模式",
                "example": "warning",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件名",
                "example": "app.log",
                "notes": "必填"
              }
            },
            "keyword": "grep line number"
          },
          {
            "name": "只显示文件名",
            "cmd": "grep -il %{模式}% %{文件}%",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "搜索模式",
                "example": "error",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件或目录",
                "example": "*.log",
                "notes": "必填"
              }
            },
            "keyword": "grep filename only"
          },
          {
            "name": "统计匹配行数",
            "cmd": "grep -ic %{模式}% %{文件}%",
            "params": {
              "模式": {
                "type": "string",
                "required": true,
                "description": "搜索模式",
                "example": "error",
                "notes": "必填"
              },
              "文件": {
                "type": "string",
                "required": true,
                "description": "文件名",
                "example": "app.log",
                "notes": "必填"
              }
            },
            "keyword": "grep count"
          }
        ],
        "params": {}
      }
    }
  ]
}