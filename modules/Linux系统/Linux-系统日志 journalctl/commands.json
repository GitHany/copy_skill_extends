{
  "module": "Linux系统/Linux-系统日志 journalctl",
  "version": "2.0",
  "description": "Systemd 日志管理，涵盖Linux journalctl的常用操作和最佳实践",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "journalctl 查看日志",
      "keyword": "journalctl 日志",
      "description": "查看 systemd 日志。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "journalctl -u %{服务}%",
        "extensions": [
          {
            "name": "跟踪日志",
            "cmd": "journalctl -fu %{服务}%",
            "params": {
              "服务": {
                "type": "string",
                "required": true,
                "description": "服务             ",
                "example": "nginx",
                "notes": "必填"
              }
            },
            "keyword": "journalctl follow"
          }
        ],
        "params": {
          "服务": {
            "type": "string",
            "required": true,
            "description": "服务名称           ",
            "example": "docker",
            "notes": "必填"
          }
        }
      }
    }
  ]
}