{
  "module": "Linux系统/Linux-创建链接 ln",
  "version": "2.0",
  "description": "Linux ln 链接创建命令。创建文件或目录的链接，快捷方式。两种类型：硬链接（同一文件的多个名字）和符号链接（类似快捷方式指向路径）。用于简化长路径访问、多个位置使用同一文件、版本管理。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "ln 创建链接",
      "keyword": "ln 链接",
      "description": "创建硬链接或符号链接。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "ln -s %{目标}% %{链接名}%",
        "extensions": [
          {
            "name": "创建符号链接",
            "description": "创建指向目标文件的符号链接（快捷方式）           ",
            "params": {
              "目标": {
                "example": "/usr/local/app",
                "notes": "目标文件或目录",
                "description": "               "
              },
              "链接名": {
                "example": "app-link",
                "notes": "链接名称",
                "description": "               "
              }
            },
            "cmd": "ln -s %{目标}% %{链接名}%"
          },
          {
            "name": "创建硬链接",
            "description": "创建硬链接，多个名字指向同一文件              ",
            "params": {
              "目标": {
                "example": "/data/file.txt",
                "notes": "目标文件",
                "description": "               "
              },
              "链接名": {
                "example": "file_backup",
                "notes": "链接名",
                "description": "               "
              }
            },
            "cmd": "ln %{目标}% %{链接名}%"
          },
          {
            "name": "覆盖已有链接",
            "description": "创建链接时如果已存在同名链接，先删除再创建         ",
            "params": {
              "目标": {
                "example": "/var/log",
                "notes": "目标",
                "description": "               "
              },
              "链接名": {
                "example": "logs",
                "notes": "链接名",
                "description": "               "
              }
            },
            "cmd": "ln -sf %{目标}% %{链接名}%"
          },
          {
            "name": "创建目录符号链接",
            "description": "为目录创建符号链接，方便访问                ",
            "params": {
              "目标": {
                "example": "/var/www/html",
                "notes": "目标目录",
                "description": "               "
              },
              "链接名": {
                "example": "webroot",
                "notes": "链接名",
                "description": "               "
              }
            },
            "cmd": "ln -s %{目标}% %{链接名}%"
          },
          {
            "name": "查看链接目标",
            "description": "查看符号链接指向的实际路径                 ",
            "params": {
              "链接名": {
                "example": "link_name",
                "notes": "链接名",
                "description": "               "
              }
            },
            "cmd": "readlink %{链接名}%"
          },
          {
            "name": "批量创建链接",
            "description": "为目录下所有文件创建符号链接到指定目录           ",
            "params": {
              "源目录": {
                "example": "./bin",
                "notes": "源目录",
                "description": "               "
              },
              "目标目录": {
                "example": "/usr/local/bin",
                "notes": "链接存放目录",
                "description": "               "
              }
            },
            "cmd": "for f in %{源目录}%/*; do ln -s \"$f\" %{目标目录}%/; done"
          },
          {
            "name": "创建链接并验证",
            "description": "创建链接后验证链接是否有效                 ",
            "params": {
              "目标": {
                "example": "/opt/application",
                "notes": "目标",
                "description": "               "
              },
              "链接名": {
                "example": "app",
                "notes": "链接",
                "description": "               "
              }
            },
            "cmd": "ln -s %{目标}% %{链接名}% && ls -la %{链接名}%"
          },
          {
            "name": "强制创建链接",
            "description": "如果链接已存在则覆盖，无确认提示              ",
            "params": {
              "目标": {
                "example": "/usr/share/app",
                "notes": "目标",
                "description": "               "
              },
              "链接名": {
                "example": "app",
                "notes": "链接名",
                "description": "               "
              }
            },
            "cmd": "ln -snf %{目标}% %{链接名}%"
          }
        ],
        "params": {
          "目标": {
            "type": "string",
            "required": true,
            "description": "目标文件           ",
            "example": "/path/to/file",
            "notes": "必填"
          },
          "链接名": {
            "type": "string",
            "required": true,
            "description": "链接名            ",
            "example": "link",
            "notes": "必填"
          }
        }
      }
    }
  ]
}