{
  "module": "Linux系统/Linux-下载文件 wget",
  "version": "2.0",
  "description": "Linux wget 非交互式文件下载工具。支持 HTTP/HTTPS/FTP 协议，可以递归下载整个网站、自动重试、断点续传。后台下载、限速下载、代理支持。适合下载文件、镜像网站、获取远程资源。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "wget 下载文件",
      "keyword": "wget 下载",
      "description": "非交互式下载工具。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "wget %{URL}%",
        "extensions": [
          {
            "name": "下载单个文件",
            "description": "下载指定URL的文件                    ",
            "params": {
              "URL": {
                "example": "https://example.com/file.tar.gz",
                "notes": "下载地址",
                "description": "               "
              }
            },
            "cmd": "wget %{URL}%"
          },
          {
            "name": "指定保存名称",
            "description": "下载后将文件保存为指定名称                 ",
            "params": {
              "名称": {
                "example": "latest.tar.gz",
                "notes": "保存文件名",
                "description": "               "
              },
              "URL": {
                "example": "https://example.com/file.tar.gz",
                "notes": "URL",
                "description": "               "
              }
            },
            "cmd": "wget -O %{名称}% %{URL}%"
          },
          {
            "name": "后台下载",
            "description": "在后台进行下载，不占用终端                 ",
            "params": {
              "URL": {
                "example": "https://example.com/large.zip",
                "notes": "URL",
                "description": "               "
              }
            },
            "cmd": "wget -b %{URL}%"
          },
          {
            "name": "限速下载",
            "description": "限制下载速度防止占用太多带宽                ",
            "params": {
              "速度": {
                "example": "500K",
                "notes": "限速值",
                "description": "               "
              },
              "URL": {
                "example": "https://example.com/file.iso",
                "notes": "URL",
                "description": "               "
              }
            },
            "cmd": "wget --limit-rate=%{速度}% %{URL}%"
          },
          {
            "name": "断点续传",
            "description": "从已中断的下载处继续下载                  ",
            "params": {
              "URL": {
                "example": "https://example.com/bigfile.zip",
                "notes": "URL",
                "description": "               "
              }
            },
            "cmd": "wget -c %{URL}%"
          },
          {
            "name": "下载多个文件",
            "description": "从文件读取多个URL批量下载                ",
            "params": {
              "文件": {
                "example": "urls.txt",
                "notes": "URL列表文件",
                "description": "               "
              }
            },
            "cmd": "wget -i %{文件}%"
          },
          {
            "name": "递归下载网站",
            "description": "完整镜像整个网站                      ",
            "params": {
              "网站": {
                "example": "https://example.com",
                "notes": "网站地址",
                "description": "               "
              }
            },
            "cmd": "wget -r -l 2 %{网站}%"
          },
          {
            "name": "跳过已存在文件",
            "description": "不重复下载已存在的文件                   ",
            "params": {
              "URL": {
                "example": "https://example.com/file.zip",
                "notes": "URL",
                "description": "               "
              }
            },
            "cmd": "wget -nc %{URL}%"
          }
        ],
        "params": {
          "URL": {
            "type": "string",
            "required": true,
            "description": "下载地址           ",
            "example": "https://example.com/file.tar.gz",
            "notes": "必填"
          }
        }
      }
    }
  ]
}