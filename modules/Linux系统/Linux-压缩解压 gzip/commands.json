{
  "module": "Linux系统/Linux-压缩解压 gzip",
  "version": "2.0",
  "description": "Linux gzip 压缩解压工具。使用 Lempel-Ziv (DEFLATE) 算法压缩文件，压缩后原文件会被替换为 .gz 文件。压缩比通常在 60-70%，适合文本文件、日志、代码压缩。是服务器上节省磁盘空间的常用工具。",
  "commands": [
    {
      "dirPath": "/Linux系统/",
      "name": "gzip 压缩文件",
      "keyword": "gzip 压缩",
      "description": "使用 Lempel-Ziv (DEFLATE) 算法压缩文件，压缩后原文件会被替换为 .gz 文件。压缩比通常在 60-70%，适合文本文件压缩",
      "data": {
        "cmd": "gzip %{文件}%",
        "extensions": [
          {
            "name": "解压文件",
            "description": "解压 .gz 压缩文件，压缩包被删除恢复原文件       ",
            "params": {
              "文件": {
                "example": "file.txt.gz",
                "notes": "压缩文件路径",
                "description": "               "
              }
            },
            "cmd": "gunzip %{文件}%"
          },
          {
            "name": "保持原文件压缩",
            "description": "压缩后保留原始文件，只生成 .gz 包           ",
            "params": {
              "文件": {
                "example": "data.txt",
                "notes": "要压缩的文件",
                "description": "               "
              }
            },
            "cmd": "gzip -k %{文件}%"
          },
          {
            "name": "设置压缩级别",
            "description": "1最快最低压缩率，9最慢最高压缩率，默认6         ",
            "params": {
              "级别": {
                "example": "9",
                "notes": "1-9压缩级别",
                "description": "               "
              },
              "文件": {
                "example": "logs.txt",
                "notes": "要压缩的文件",
                "description": "               "
              }
            },
            "cmd": "gzip -%{级别}% %{文件}%"
          },
          {
            "name": "递归压缩目录",
            "description": "压缩目录下所有文件，每个文件单独压缩            ",
            "params": {
              "目录": {
                "example": "./logs",
                "notes": "目录路径",
                "description": "               "
              }
            },
            "cmd": "gzip -r %{目录}%"
          },
          {
            "name": "查看压缩文件内容",
            "description": "不解压直接查看压缩文件内的内容               ",
            "params": {
              "文件": {
                "example": "access.log.gz",
                "notes": "压缩文件",
                "description": "               "
              }
            },
            "cmd": "zcat %{文件}%"
          },
          {
            "name": "压缩文件测试",
            "description": "验证压缩文件完整性，检查是否损坏              ",
            "params": {
              "文件": {
                "example": "backup.gz",
                "notes": "压缩文件",
                "description": "               "
              }
            },
            "cmd": "gzip -t %{文件}%"
          },
          {
            "name": "显示压缩信息",
            "description": "压缩后显示压缩前后大小和压缩比               ",
            "params": {
              "文件": {
                "example": "document.txt",
                "notes": "要压缩的文件",
                "description": "               "
              }
            },
            "cmd": "gzip -l %{文件}%"
          },
          {
            "name": "强制压缩覆盖",
            "description": "如果 .gz 文件已存在则直接覆盖             ",
            "params": {
              "文件": {
                "example": "data.csv",
                "notes": "要压缩的文件",
                "description": "               "
              }
            },
            "cmd": "gzip -f %{文件}%"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "要压缩的文件路径       ",
            "example": "data.txt",
            "notes": "必填。gzip 会自动在文件名后加 .gz 扩展名"
          }
        }
      }
    }
  ]
}