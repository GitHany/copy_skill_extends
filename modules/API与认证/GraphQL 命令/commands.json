            "notes": "常用"
          },
          "值3": {
            "type": "string",
            "required": false,
            "description": "枚举值            ",
            "example": "PENDING",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Interface 定义",
      "keyword": "graphql interface 接口",
      "description": "定义 GraphQL Interface 接口类型。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "interface %{interface名称}% { %{字段1}%: %{类型1}% %{字段2}%: %{类型2}% }",
