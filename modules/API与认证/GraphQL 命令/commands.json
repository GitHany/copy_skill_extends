{
  "module": "API与认证/GraphQL 命令",
  "version": "1.0",
  "description": "GraphQL 命令 模块命令集合，覆盖 GraphQL 核心、服务器、客户端、代码生成和操作分析",
  "commands": [
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Schema 定义 Query 类型",
      "keyword": "graphql schema query",
      "description": "定义 GraphQL Schema 中的 Query 类型（查询入口）",
      "data": {
        "cmd": "type %{类型名称}% { %{字段1}%: %{类型1}% %{字段2}%: %{类型2}% }",
        "extensions": [
          {
            "name": "带参数的查询字段",
            "cmd": "%{字段名}%(%{参数名}%: %{参数类型}%): %{返回类型}%",
            "params": {
              "字段名": {
                "type": "string",
                "required": true,
                "description": "查询字段名称         ",
                "example": "user",
                "notes": "常用"
              },
              "参数名": {
                "type": "string",
                "required": true,
                "description": "参数名称           ",
                "example": "id",
                "notes": "常用"
              },
              "参数类型": {
                "type": "string",
                "required": true,
                "description": "参数类型           ",
                "example": "ID",
                "notes": "常用"
              },
              "返回类型": {
                "type": "string",
                "required": true,
                "description": "返回类型           ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql query 参数字段"
          },
          {
            "name": "数组返回类型",
            "cmd": "%{字段名}%: [%{元素类型}%!]!",
            "params": {
              "字段名": {
                "type": "string",
                "required": true,
                "description": "字段名称           ",
                "example": "users",
                "notes": "常用"
              },
              "元素类型": {
                "type": "string",
                "required": true,
                "description": "数组元素类型         ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql query 数组类型"
          }
        ],
        "params": {
          "类型名称": {
            "type": "string",
            "required": true,
            "description": "类型名称           ",
            "example": "Query",
            "notes": "常用"
          },
          "字段1": {
            "type": "string",
            "required": true,
            "description": "字段名称           ",
            "example": "id",
            "notes": "常用"
          },
          "类型1": {
            "type": "string",
            "required": true,
            "description": "字段类型           ",
            "example": "ID",
            "notes": "常用"
          },
          "字段2": {
            "type": "string",
            "required": false,
            "description": "字段名称           ",
            "example": "name",
            "notes": "可选"
          },
          "类型2": {
            "type": "string",
            "required": false,
            "description": "字段类型           ",
            "example": "String",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Schema 定义 Mutation 类型",
      "keyword": "graphql schema mutation",
      "description": "定义 GraphQL Schema 中的 Mutation 类型（变更入口）",
      "data": {
        "cmd": "type Mutation { %{mutation名称}%(%{参数}%): %{返回类型}% }",
        "extensions": [
          {
            "name": "创建数据 Mutation",
            "cmd": "create%{实体名}%(%{输入字段}%): %{返回类型}%",
            "params": {
              "实体名": {
                "type": "string",
                "required": true,
                "description": "实体名称           ",
                "example": "User",
                "notes": "常用"
              },
              "输入字段": {
                "type": "string",
                "required": true,
                "description": "输入字段           ",
                "example": "name: String!",
                "notes": "常用"
              },
              "返回类型": {
                "type": "string",
                "required": true,
                "description": "返回类型           ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql mutation 创建"
          },
          {
            "name": "更新数据 Mutation",
            "cmd": "update%{实体名}%(%{id}%: ID! %{更新字段}%): %{返回类型}%",
            "params": {
              "实体名": {
                "type": "string",
                "required": true,
                "description": "实体名称           ",
                "example": "User",
                "notes": "常用"
              },
              "id": {
                "type": "string",
                "required": true,
                "description": "主键字段           ",
                "example": "id",
                "notes": "常用"
              },
              "更新字段": {
                "type": "string",
                "required": true,
                "description": "更新字段           ",
                "example": "name: String",
                "notes": "常用"
              },
              "返回类型": {
                "type": "string",
                "required": true,
                "description": "返回类型           ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql mutation 更新"
          },
          {
            "name": "删除数据 Mutation",
            "cmd": "delete%{实体名}%(%{id}%: ID!): Boolean",
            "params": {
              "实体名": {
                "type": "string",
                "required": true,
                "description": "实体名称           ",
                "example": "User",
                "notes": "常用"
              },
              "id": {
                "type": "string",
                "required": true,
                "description": "主键字段           ",
                "example": "id",
                "notes": "常用"
              }
            },
            "keyword": "graphql mutation 删除"
          }
        ],
        "params": {
          "mutation名称": {
            "type": "string",
            "required": true,
            "description": "Mutation 名称    ",
            "example": "createUser",
            "notes": "常用"
          },
          "参数": {
            "type": "string",
            "required": true,
            "description": "参数列表           ",
            "example": "name: String!",
            "notes": "常用"
          },
          "返回类型": {
            "type": "string",
            "required": true,
            "description": "返回类型           ",
            "example": "User",
            "notes": "常用"
          }
        }
      }
    },
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Schema 定义 Subscription 类型",
      "keyword": "graphql schema subscription",
      "description": "定义 GraphQL Schema 中的 Subscription 类型（实时订阅入口）",
      "data": {
        "cmd": "type Subscription { %{subscription名称}%(%{参数}%): %{返回类型}% }",
        "extensions": [
          {
            "name": "监听数据变化",
            "cmd": "%{实体名}%Created: %{实体名}%",
            "params": {
              "实体名": {
                "type": "string",
                "required": true,
                "description": "实体名称           ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql subscription 创建事件"
          },
          {
            "name": "监听更新事件",
            "cmd": "%{实体名}%Updated: %{实体名}%",
            "params": {
              "实体名": {
                "type": "string",
                "required": true,
                "description": "实体名称           ",
                "example": "User",
                "notes": "常用"
              }
            },
            "keyword": "graphql subscription 更新事件"
          }
        ],
        "params": {
          "subscription名称": {
            "type": "string",
            "required": true,
            "description": "Subscription 名称",
            "example": "userAdded",
            "notes": "常用"
          },
          "参数": {
            "type": "string",
            "required": false,
            "description": "订阅参数           ",
            "example": "roomId: ID",
            "notes": "可选"
          },
          "返回类型": {
            "type": "string",
            "required": true,
            "description": "返回类型           ",
            "example": "User",
            "notes": "常用"
          }
        }
      }
    },
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Input 类型定义",
      "keyword": "graphql input 类型",
      "description": "定义 GraphQL Input 类型（用于 Mutations 输入参数）",
      "data": {
        "cmd": "input %{input名称}% { %{字段1}%: %{类型1}% %{字段2}%: %{类型2}% }",
        "extensions": [
          {
            "name": "嵌套 Input 类型",
            "cmd": "input %{input名称}% { %{字段}%: %{嵌套input}%! }",
            "params": {
              "input名称": {
                "type": "string",
                "required": true,
                "description": "Input 类型名称     ",
                "example": "CreateUserInput",
                "notes": "常用"
              },
              "字段": {
                "type": "string",
                "required": true,
                "description": "字段名称           ",
                "example": "profile",
                "notes": "可选"
              },
              "嵌套input": {
                "type": "string",
                "required": true,
                "description": "嵌套的 Input 类型   ",
                "example": "ProfileInput",
                "notes": "可选"
              }
            },
            "keyword": "graphql input 嵌套"
          }
        ],
        "params": {
          "input名称": {
            "type": "string",
            "required": true,
            "description": "Input 类型名称     ",
            "example": "CreateUserInput",
            "notes": "常用"
          },
          "字段1": {
            "type": "string",
            "required": true,
            "description": "字段名称           ",
            "example": "name",
            "notes": "常用"
          },
          "类型1": {
            "type": "string",
            "required": true,
            "description": "字段类型           ",
            "example": "String!",
            "notes": "常用"
          },
          "字段2": {
            "type": "string",
            "required": false,
            "description": "字段名称           ",
            "example": "email",
            "notes": "可选"
          },
          "类型2": {
            "type": "string",
            "required": false,
            "description": "字段类型           ",
            "example": "String",
            "notes": "可选"
          }
        }
      }
    },
    {
      "dirPath": "/API与认证/",
      "name": "GraphQL Enum 类型定义",
      "keyword": "graphql enum 类型",
      "description": "定义 GraphQL Enum 枚举类型。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "enum %{enum名称}% { %{值1}% %{值2}% %{值3}% }",
        "extensions": [
          {
            "name": "Enum 用作字段类型",
            "cmd": "%{字段名}%: %{enum名称}%",
            "params": {
              "字段名": {
                "type": "string",
                "required": true,
                "description": "字段名称           ",
                "example": "status",
                "notes": "常用"
              },
              "enum名称": {
                "type": "string",
                "required": true,
                "description": "Enum 类型名称      ",
                "example": "UserStatus",
                "notes": "常用"
              }
            },
            "keyword": "graphql enum 字段类型"
          }
        ],
        "params": {
          "enum名称": {
            "type": "string",
            "required": true,
            "description": "Enum 类型名称      ",
            "example": "UserStatus",
            "notes": "常用"
          },
          "值1": {
            "type": "string",
            "required": true,
            "description": "枚举值            ",
