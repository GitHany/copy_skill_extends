    {
      "dirPath": "/API与认证/",
      "name": "graphql-tools Schema 合并",
      "keyword": "graphql-tools 合并 schema",
      "description": "使用 graphql-tools 的 mergeSchemas 合并多个子 Schema",
      "data": {
        "cmd": "import { mergeSchemas } from '@graphql-tools/schema'; const schema = mergeSchemas({ schemas: [%{schema1}%, %{schema2}%] });",
        "extensions": [
          {
            "name": "Schema 委托",
            "cmd": "import { delegateToSchema } from '@graphql-tools/delegate'; delegateToSchema({ schema: %{targetSchema}%, operation: 'query', fieldName: '%{field}%', args: %{args}%, context: %{ctx}%, info: %{info}% });",
            "params": {
              "targetSchema": {
                "type": "string",
                "required": true,
                "description": "目标 Schema 名称   ",
                "example": "userSchema",
                "notes": "常用"
              },
              "field": {
                "type": "string",
                "required": true,
                "description": "字段名称           ",
                "example": "user",
                "notes": "常用"
              },
              "args": {
                "type": "string",
                "required": true,
                "description": "参数字对象          ",
                "example": "{ id: '1' }",
                "notes": "常用"
              },
              "ctx": {
                "type": "string",
                "required": true,
                "description": "上下文对象变量名       ",
                "example": "ctx",
                "notes": "可选"
              },
              "info": {
                "type": "string",
                "required": true,
                "description": "GraphQL 执行信息变量名",
                "example": "info",
                "notes": "可选"
              }
            },
            "keyword": "graphql-tools 委托 schema"
          },
          {
            "name": "Schema 转换",
            "cmd": "import { transformSchema } from '@graphql-tools/delegate'; import { RenameTypes } from '@graphql-tools/wrap'; const transformed = transformSchema(%{schema}%, [new RenameTypes(%{renamer}%)]);",
            "params": {
              "schema": {
                "type": "string",
                "required": true,
                "description": "源 Schema 变量名   ",
                "example": "schema",
                "notes": "常用"
              },
              "renamer": {
                "type": "string",
                "required": true,
                "description": "类型重命名函数        ",
                "example": "(name) => `_${name}`",
                "notes": "可选"
              }
            },
            "keyword": "graphql-tools schema 转换"
          }
        ],
        "params": {
          "schema1": {
            "type": "string",
            "required": true,
            "description": "第一个 Schema 变量名 ",
            "example": "userSchema",
            "notes": "常用"
          },
          "schema2": {
            "type": "string",
            "required": true,
            "description": "第二个 Schema 变量名 ",
            "example": "postSchema",
            "notes": "常用"
          }
        }
      }
    },
