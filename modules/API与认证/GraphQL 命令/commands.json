    {
      "dirPath": "/API与认证/",
      "name": "Apollo Client 初始化",
      "keyword": "apollo client 初始化",
      "description": "在客户端项目中初始化 Apollo Client。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm install @apollo/client graphql",
        "extensions": [
          {
            "name": "创建 Apollo Client 实例",
            "cmd": "import { ApolloClient, InMemoryCache } from '@apollo/client'; const client = new ApolloClient({ uri: '%{graphql端点}%', cache: new InMemoryCache() });",
            "params": {
              "graphql端点": {
                "type": "string",
                "required": true,
                "description": "GraphQL 服务端点 URL",
                "example": "http://localhost:4000/graphql",
                "notes": "常用"
              }
            },
            "keyword": "apollo client 实例"
          },
          {
            "name": "使用 useQuery Hook",
            "cmd": "const { data, loading, error } = useQuery(gql`%{gql查询}%`);",
            "params": {
              "gql查询": {
                "type": "string",
                "required": true,
                "description": "GraphQL 查询字符串  ",
                "example": "{ users { id name } }",
                "notes": "常用"
              }
            },
            "keyword": "apollo useQuery 查询"
          },
          {
