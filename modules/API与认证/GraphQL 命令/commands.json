              "类型2": {
                "type": "string",
                "required": true,
                "description": "第二个成员类型        ",
                "example": "Post",
                "notes": "常用"
              }
            },
            "keyword": "graphql union 联合类型"
          }
        ],
        "params": {
          "interface名称": {
            "type": "string",
            "required": true,
            "description": "接口名称           ",
            "example": "Node",
            "notes": "常用"
          },
          "字段1": {
            "type": "string",
            "required": true,
            "description": "字段名称           ",
            "example": "id",
            "notes": "常用"
          },
          "类型1": {
            "type": "string",
            "required": true,
            "description": "字段类型           ",
            "example": "ID!",
