{
  "module": "Node.js npm Scripts",
  "version": "2.0",
  "description": "Node.js 常用 npm scripts 命令",
  "commands": [
    {
      "dirPath": "/Node.js npm Scripts/",
      "name": "npm start 启动应用",
      "keyword": "npm start 启动",
      "description": "启动 Node.js 应用。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm start",
        "extensions": [],
        "params": {}
      }
    },
    {
      "dirPath": "/Node.js npm Scripts/",
      "name": "npm stop 停止应用",
      "keyword": "npm stop 停止",
      "description": "停止 Node.js 应用。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm stop",
        "extensions": [],
        "params": {}
      }
    },
    {
      "dirPath": "/Node.js npm Scripts/",
      "name": "npm restart 重启应用",
      "keyword": "npm restart 重启",
      "description": "重启 Node.js 应用。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm restart",
        "extensions": [],
        "params": {}
      }
    },
    {
      "dirPath": "/Node.js npm Scripts/",
      "name": "npm version 版本管理",
      "keyword": "npm version 版本",
      "description": "管理应用版本。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "npm version %{类型}%",
        "extensions": [
          {
            "name": "打标签",
            "cmd": "npm version %{类型}% -m \"%{消息}%\"",
            "params": {
              "类型": {
                "type": "string",
                "required": true,
                "description": "版本类型",
                "example": "patch",
                "notes": "必填"
              },
              "消息": {
                "type": "string",
                "required": true,
                "description": "提交消息",
                "example": "Release %s",
                "notes": "必填"
              }
            },
            "keyword": "npm version message"
          }
        ],
        "params": {
          "类型": {
            "type": "string",
            "required": true,
            "description": "版本更新类型",
            "example": "minor",
            "notes": "必填"
          }
        }
      }
    }
  ]
}