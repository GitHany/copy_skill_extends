{
  "module": "Linux touch",
  "version": "2.0",
  "description": "Linux touch 创建空文件命令。创建新的空文件，或更新已有文件的时间戳。是创建占位文件、初始化项目结构、测试文件写入的常用工具。也可用于标记文件为已访问。",
  "commands": [
    {
      "dirPath": "/Linux touch/",
      "name": "touch 创建文件",
      "keyword": "touch 创建",
      "description": "创建空文件或更新时间戳。该命令是相关技术栈中的常用操作，掌握其用法对于日常开发和运维工作非常重要",
      "data": {
        "cmd": "touch %{文件}%",
        "extensions": [
          {
            "name": "创建单个文件",
            "description": "创建一个新的空文件",
            "params": {
              "文件": {
                "example": "newfile.txt",
                "notes": "文件名"
              }
            },
            "cmd": "touch %{文件}%"
          },
          {
            "name": "创建多个文件",
            "description": "一次创建多个空文件",
            "params": {
              "文件": {
                "example": "file1.txt file2.txt file3.txt",
                "notes": "空格分隔的文件名"
              }
            },
            "cmd": "touch %{文件}%"
          },
          {
            "name": "更新访问时间",
            "description": "将文件的访问时间更新为当前时间",
            "params": {
              "文件": {
                "example": "existing.txt",
                "notes": "文件名"
              }
            },
            "cmd": "touch -a %{文件}%"
          },
          {
            "name": "更新修改时间",
            "description": "将文件的修改时间更新为当前时间",
            "params": {
              "文件": {
                "example": "config.cfg",
                "notes": "文件名"
              }
            },
            "cmd": "touch -m %{文件}%"
          },
          {
            "name": "设置特定时间",
            "description": "将文件时间戳设置为指定日期",
            "params": {
              "文件": {
                "example": "dated.txt",
                "notes": "文件名"
              },
              "时间": {
                "example": "20240115",
                "notes": "年月日"
              }
            },
            "cmd": "touch -t %{时间}% %{文件}%"
          },
          {
            "name": "不创建只更新",
            "description": "如果文件存在才更新时间，不存在则不创建",
            "params": {
              "文件": {
                "example": "existing.log",
                "notes": "文件名"
              }
            },
            "cmd": "touch -c %{文件}%"
          },
          {
            "name": "创建带内容文件",
            "description": "使用重定向创建有初始内容的文件",
            "params": {
              "内容": {
                "example": "initial content",
                "notes": "文件内容"
              },
              "文件": {
                "example": "README.md",
                "notes": "文件名"
              }
            },
            "cmd": "echo \"%{内容}%\" > %{文件}%"
          },
          {
            "name": "批量创建项目文件",
            "description": "一次性创建项目中需要的多个空文件",
            "params": {
              "文件列表": {
                "example": "index.html style.css app.js",
                "notes": "文件列表"
              }
            },
            "cmd": "touch %{文件列表}%"
          }
        ],
        "params": {
          "文件": {
            "type": "string",
            "required": true,
            "description": "文件名",
            "example": "newfile.txt",
            "notes": "必填"
          }
        }
      }
    }
  ]
}